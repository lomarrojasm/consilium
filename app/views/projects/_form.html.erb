<%# app/views/projects/_form.html.erb %>

<style>
  .manual-mode .stage-activities-option,
  .manual-mode .stage-position-option {
    display: none !important;
  }
  
  #template-options-container, #special-project-options {
    transition: all 0.3s ease;
  }
</style>

<%= form_with(model: [@client, @project], local: true, class: "needs-validation") do |f| %>
    
    <% if @project.errors.any? %>
        <div class="alert alert-danger border-0 mb-4 shadow-sm">
            <ul class="mb-0">
                <% @project.errors.full_messages.each do |msg| %>
                    <li><%= msg %></li>
                <% end %>
            </ul>
        </div>
    <% end %>

    <div class="row g-3">
        <div class="col-md-7">
            <div class="form-floating mb-3">
                <%= f.text_field :name, class: "form-control shadow-none", id: "projectName", placeholder: "Ej: Implementación", required: true %>
                <label for="projectName">Nombre del Proyecto</label>
            </div>
        </div>
        <div class="col-md-5">
            <div class="form-floating mb-3">
                <%= f.collection_select :responsible_id, 
                    User.where(client_id: @client.id).order(:first_name), 
                    :id, :full_name, 
                    { prompt: "" }, 
                    { class: "form-select shadow-none", id: "projectResponsible", required: true } %>
                <label for="projectResponsible">Responsable del Proyecto</label>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <div class="form-floating mb-3">
                <%= f.date_field :start_date, class: "form-control shadow-none", id: "projectStart", required: true %>
                <label for="projectStart">Fecha de Inicio</label>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-6">
             <div class="form-floating mb-3">
                <% if @project.new_record? %>
                    <input type="text" class="form-control bg-light text-muted border-0" value="EN ESPERA" readonly disabled>
                    <label>Estatus Inicial</label>
                <% else %>
                    <%= f.select :status, Project.statuses.keys.map { |s| [s.humanize.upcase, s] }, {}, { class: "form-select shadow-none", id: "editStatus" } %>
                    <label for="editStatus">Estatus Operativo</label>
                <% end %>
            </div>
        </div>

        <%# Selector para corregir el tipo de proyecto en EDICIÓN %>
        <% unless @project.new_record? %>
            <div class="col-md-6">
                 <div class="form-floating mb-3">
                    <%= f.select :project_type, Project.project_types.keys.map { |type| [type.humanize.upcase, type] }, {}, { class: "form-select shadow-none border-info border-opacity-50", id: "editProjectType" } %>
                    <label for="editProjectType" class="text-info fw-bold">Categoría de Proyecto</label>
                </div>
            </div>
        <% end %>
    </div>
    
    <div class="form-floating mb-4">
        <%= f.text_area :details, class: "form-control shadow-none", id: "projectDetails", style: "height: 120px", placeholder: "Objetivos..." %>
        <label for="projectDetails">Descripción y Objetivos Estratégicos</label>
    </div>

    <%# === SECCIÓN A: METODOLOGÍA Y TIPO (SOLO AL CREAR NUEVO PROYECTO) === %>
    <% if @project.new_record? %>
        <div class="bg-primary bg-opacity-10 p-3 rounded-3 mb-4 border border-primary border-opacity-25">
            <div class="form-check form-switch mb-2">
                <%= f.check_box :include_template, 
                    class: "form-check-input", 
                    role: "switch", 
                    checked: true, 
                    id: "includeTemplateSwitch",
                    onchange: "updateFormLogic()" %>
                <label class="form-check-label ms-2" for="includeTemplateSwitch">
                    <strong class="text-primary">Cargar Metodología Consilium</strong>
                    <p class="text-muted font-12 mb-0">Al activar, se generarán automáticamente las etapas y actividades estándar.</p>
                </label>
            </div>

            <%# Opción de Plantilla: Solo visible si Metodología está ON %>
            <div id="template-options-container">
                <hr class="border-primary border-opacity-25">
                <div class="mb-2">
                    <%= label_tag :template_year, "Generación de Plantilla (Año Histórico)", class: "form-label font-12 fw-bold text-primary mb-1" %>
                    <%= select_tag :template_year, options_for_select([
                        ['Sin año (Fechas actuales)', ''],
                        ['Generación 2026', '2026'],
                        ['Generación 2025', '2025'],
                        ['Generación 2024', '2024'],
                        ['Generación 2023', '2023'],
                        ['Generación 2022', '2022']
                    ]), class: "form-select shadow-sm border-0" %>
                </div>
            </div>

            <%# Opción de Proyecto Especial: Solo visible si Metodología está OFF %>
            <div id="special-project-options" style="display: none;">
                <hr class="border-primary border-opacity-25">
                <div class="mb-2">
                    <%= f.label :project_type, "Categoría de Proyecto Especial", class: "form-label font-12 fw-bold text-danger mb-1" %>
                    
                    <%# Este select se usa nativamente. Solo se apaga/enciende en JS %>
                    <%= f.select :project_type, 
                        Project.project_types.keys.reject { |k| k == 'metodologia' }.map { |type| [type.humanize.upcase, type] }, 
                        { prompt: "-- Seleccionar Especialidad --" }, 
                        { class: "form-select shadow-sm border-danger border-opacity-25", id: "projectTypeSelect", disabled: true } %>
                    
                    <small class="text-muted font-11">
                        <i class="ri-information-line me-1"></i>Obligatorio para proyectos que no siguen la metodología estándar.
                    </small>
                </div>
            </div>
        </div>
    <% end %>

    <%# === SECCIÓN B: ETAPAS DINÁMICAS MANUALES === %>
    <div class="card border border-light shadow-none mb-4" id="manual-stages-card">
        <div class="card-header bg-light bg-opacity-50 py-2 d-flex justify-content-between align-items-center">
            <h6 class="m-0 fw-bold text-dark"><i class="ri-stack-line me-1"></i> Etapas del Proyecto</h6>
        </div>
        
        <div class="card-body p-3" data-controller="nested-form" id="nested-form-wrapper">
            <p class="text-muted font-12 mb-3">
                <%= @project.new_record? ? "Agrega etapas manuales para personalizar el plan de trabajo." : "Edita el nombre y posición de las etapas actuales." %>
            </p>

            <div data-nested-form-target="container">
                <%= f.fields_for :stages do |stage_form| %>
                    <%= render "stage_fields", f: stage_form %>
                <% end %>
            </div>

            <template data-nested-form-target="template">
                <%= f.fields_for :stages, Stage.new, child_index: "NEW_RECORD" do |stage_form| %>
                    <%= render "stage_fields", f: stage_form %>
                <% end %>
            </template>

            <button type="button" class="btn btn-soft-secondary btn-sm w-100 border-dashed" data-action="click->nested-form#add">
                <i class="ri-add-circle-line me-1"></i> Agregar etapa manual
            </button>
        </div>
    </div>

    <%# === BOTONES DE GUARDADO === %>
    <div class="d-flex justify-content-between align-items-center pt-3 border-top">
        <% if @project.new_record? %>
            <%= link_to "Cancelar", client_path(@client), class: "btn btn-light px-4" %>
            <%= f.submit "Crear Proyecto", class: "btn btn-primary px-4 shadow" %>
        <% else %>
            <%= link_to "Volver al Proyecto", client_project_path(@client, @project), class: "btn btn-light px-4" %>
            <%= f.submit "Actualizar Proyecto", class: "btn btn-primary px-4 shadow" %>
        <% end %>
    </div>
<% end %>

<script>
    function updateFormLogic() {
        const checkbox = document.getElementById('includeTemplateSwitch');
        const templateContainer = document.getElementById('template-options-container');
        const specialContainer = document.getElementById('special-project-options');
        const nestedWrapper = document.getElementById('nested-form-wrapper');
        const projectTypeSelect = document.getElementById('projectTypeSelect');
        
        if (!checkbox) return; 

        if (checkbox.checked) {
            // MODO METODOLOGÍA
            if (templateContainer) templateContainer.style.display = 'block';
            if (specialContainer) specialContainer.style.display = 'none';
            if (nestedWrapper) nestedWrapper.classList.remove('manual-mode');
            
            // Bloquea el select para que su valor en blanco NO interfiera con el Controlador
            if (projectTypeSelect) {
                projectTypeSelect.disabled = true;
                projectTypeSelect.required = false;
            }
        } else {
            // MODO PROYECTO ESPECIAL
            if (templateContainer) templateContainer.style.display = 'none';
            if (specialContainer) specialContainer.style.display = 'block';
            if (nestedWrapper) nestedWrapper.classList.add('manual-mode');
            
            // Activa el select para que Rails lea qué especialidad eligió el usuario
            if (projectTypeSelect) {
                projectTypeSelect.disabled = false;
                projectTypeSelect.required = true;
            }
        }
    }

    document.addEventListener("turbo:load", function() {
        updateFormLogic();
    });
</script>