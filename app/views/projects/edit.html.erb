<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item"><%= link_to "Cliente", client_path(@client) %></li>
                    <li class="breadcrumb-item"><%= link_to @project.name, client_project_path(@client, @project) %></li>
                    <li class="breadcrumb-item active">Editar</li>
                </ol>
            </div>
            <h4 class="page-title">Editar Proyecto</h4>
        </div>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                
                <%= form_with(model: [@client, @project], local: true, class: "needs-validation") do |f| %>
                    
                    <% if @project.errors.any? %>
                        <div class="alert alert-danger">
                            <ul class="mb-0">
                                <% @project.errors.full_messages.each do |msg| %>
                                    <li><%= msg %></li>
                                <% end %>
                            </ul>
                        </div>
                    <% end %>

                    <div class="mb-3">
                        <%= f.label :name, "Nombre del Proyecto", class: "form-label" %>
                        <%= f.text_field :name, class: "form-control", required: true %>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <%= f.label :start_date, "Fecha de Inicio", class: "form-label" %>
                            <%= f.date_field :start_date, class: "form-control", required: true %>
                        </div>
                        <div class="col-md-6 mb-3">
                            <%= f.label :end_date, "Fecha Estimada Fin", class: "form-label" %>
                            <%= f.date_field :end_date, class: "form-control", required: true %>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <%= f.label :budget, "Presupuesto ($)", class: "form-label" %>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <%= f.number_field :budget, class: "form-control", step: "0.01" %>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <%= f.label :status, "Estatus Actual", class: "form-label" %>
                            <%= f.select :status, 
                                Project.statuses.keys.map { |s| [s.humanize.upcase, s] }, 
                                {}, 
                                { class: "form-select" } %>
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <%= f.label :details, "Descripción / Objetivos", class: "form-label" %>
                        <%= f.text_area :details, rows: 5, class: "form-control" %>
                    </div>

                    <div class="mb-4">
                        <%= f.label :files, "Adjuntar archivos adicionales", class: "form-label" %>
                        <%= f.file_field :files, multiple: true, class: "form-control" %>
                        <div class="form-text text-muted">
                            Nota: Subir archivos aquí no borrará los existentes. Para borrar archivos, hazlo desde la vista del proyecto.
                        </div>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-4">
                        <%= link_to "Cancelar", client_project_path(@client, @project), class: "btn btn-light" %>
                        
                        <div>
                            <%= link_to "Eliminar Proyecto", client_project_path(@client, @project), 
                                data: { turbo_method: :delete, turbo_confirm: "¿Estás seguro? Esto borrará todas las etapas y actividades." }, 
                                class: "btn btn-outline-danger me-2" %>
                            
                            <%= f.submit "Guardar Cambios", class: "btn btn-primary" %>
                        </div>
                    </div>
                <% end %>

            </div>
        </div>
    </div>
</div>