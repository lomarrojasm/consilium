<div class="row">
  <% if project.files.attached? %>
    <% project.files.each do |file| %>
      <div class="col-md-6 col-xxl-4">
        <div class="card mb-2 shadow-none border">
          <div class="p-2">
            <div class="row align-items-center">
              <div class="col-auto">
                <div class="avatar-sm">
                  <span class="avatar-title bg-primary-light text-primary rounded">
                    <%= file.filename.extension.upcase %>
                  </span>
                </div>
              </div>
              <div class="col ps-0">
                <a href="<%= url_for(file) %>" target="_blank" class="text-muted fw-bold text-truncate d-block">
                  <%= file.filename %>
                </a>
                <p class="mb-0 font-12"><%= number_to_human_size(file.byte_size) %></p>
              </div>
              <div class="col-auto">
                <%= link_to rails_blob_path(file, disposition: "attachment"), class: "btn btn-link font-16 text-muted", title: "Descargar" do %>
                  <i class="dripicons-download"></i>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <div class="col-12 text-center py-4">
      <div class="avatar-md mx-auto mb-2">
        <span class="avatar-title rounded-circle bg-light text-muted font-20">
            <i class="mdi mdi-attachment-off"></i>
        </span>
      </div>
      <p class="text-muted">No hay archivos adjuntos todavía.</p>
    </div>
  <% end %>
</div>