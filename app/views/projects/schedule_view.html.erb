<style>
  body { 
    background-color: #f4f5f7; 
    font-family: var(--bs-body-font-family);
  }

  /* Contenedor principal para permitir scroll */
  .schedule-container {
    max-width: 100%;
    overflow-x: auto; 
    background: white;
    border: 1px solid #e0e0e0;
    box-shadow: 0 0 10px rgba(0,0,0,0.05);
    max-height: 90vh; /* Altura máxima para permitir scroll vertical también */
  }

  .schedule-table { 
    font-size: 11px; 
    border-collapse: separate; 
    border-spacing: 0;
    min-width: 2000px; 
  }

  .schedule-table th, .schedule-table td { 
      border: 1px solid #dee2e6; 
      padding: 4px; 
      vertical-align: middle;
      height: 30px;
  }

  /* Encabezado Azul Oscuro (Etapa) */
  .header-stage { 
      background-color: #0d2e66 !important; 
      color: white; 
      text-align: left; 
      padding-left: 15px !important;
      font-weight: bold; 
      text-transform: uppercase;
      font-size: 13px;
      position: sticky;
      left: 0;
      z-index: 20; /* Mayor z-index para estar sobre todo */
  }

  /* COLUMNAS FIJAS (Sticky) */
  .sticky-col {
    position: sticky;
    background-color: white;
    z-index: 10;
    border-right: 2px solid #ccc !important;
  }
  
  /* Posiciones */
  .col-idx { left: 0; width: 40px; text-align: center; }
  .col-name { left: 40px; width: 300px; } 
  .col-doc  { left: 340px; width: 150px; }

  /* Encabezados de tabla pegajosos al hacer scroll vertical */
  thead th { position: sticky; top: 0; z-index: 15; background-color: #f8f9fa; }
  
  /* Ajuste para la intersección de headers y columnas fijas */
  thead th.sticky-col { z-index: 25; }

  /* Celdas especiales */
  .day-cell { width: 25px; min-width: 25px; text-align: center; font-size: 9px; color: #ccc; }
  .area-cell { width: 22px; text-align: center; font-size: 9px; font-weight: bold; }
  .area-active { background-color: #28a745; color: white; }
  .completed-day { background-color: #0acf97 !important; color: white !important; font-weight: bold; border: 1px solid #08a578; }
  .bg-light-gray { background-color: #e9ecef; }
  
  /* Separador de Mes */
  .month-separator {
      background-color: #eef2f7 !important;
      font-weight: bold;
      color: #313a46;
      border-top: 2px solid #dde2e7;
  }

  @media print {
    .schedule-container { overflow: visible; max-height: none; }
    .d-print-none { display: none !important; }
  }
</style>

<div class="container-fluid py-3">
  
  <div class="d-flex justify-content-between align-items-center mb-3 d-print-none">
    <div>
        <h4 class="m-0 text-primary fw-bold">Cronograma: <%= @project.name %></h4>
        <p class="text-muted small mb-0">Vista consolidada por Etapas y Meses (1-12).</p>
    </div>
    <div>
      <button onclick="window.print()" class="btn btn-secondary btn-sm me-2"><i class="mdi mdi-printer"></i> Imprimir</button>
      <button onclick="window.close()" class="btn btn-light btn-sm border">Cerrar</button>
    </div>
  </div>

  <div class="schedule-container">
    <table class="schedule-table">
      
      <thead>
        <tr class="bg-light text-center fw-bold">
            <th class="sticky-col col-idx">#</th>
            <th class="sticky-col col-name">Actividad</th>
            <th class="sticky-col col-doc">Documento</th>
            
            <% (1..31).each do |day| %>
                <th class="day-cell"><%= day %></th>
            <% end %>

            <th class="area-cell" title="Integral">I</th>
            <th class="area-cell" title="Dirección">D</th>
            <th class="area-cell" title="Finanzas">F</th>
            <th class="area-cell" title="Procesos">P</th>
            <th class="area-cell" title="Comercial">C</th>
            <th class="area-cell" title="RH">R</th>

            <th style="min-width: 90px;">Costo Total</th>
            <th style="min-width: 40px;">Hrs L</th>
            <th style="min-width: 40px;">Hrs S</th>
            <th style="min-width: 40px;">Hrs A</th>
        </tr>
      </thead>

      <tbody>
        <% @stages.each do |stage| %>
            
            <tr>
                <td colspan="44" class="header-stage sticky-col" style="left:0; width: 100%;">
                    <%= stage.name %>
                </td>
            </tr>

            <% (1..12).each do |current_month| %>
                
                <% month_activities = stage.activities.where(month: current_month).order(:week, :id) %>

                <% if month_activities.any? %>
                    
                    <tr class="month-separator">
                        <td class="sticky-col col-idx month-separator border-end-0"></td>
                        <td class="sticky-col col-name month-separator border-start-0 border-end-0 text-primary">
                            MES <%= current_month %>
                        </td>
                        <td class="sticky-col col-doc month-separator border-start-0"></td>
                        <td colspan="41" class="month-separator"></td>
                    </tr>

                    <% month_activities.each_with_index do |activity, index| %>
                        <tr>
                            <td class="sticky-col col-idx text-center bg-white"><%= index + 1 %></td>
                            <td class="sticky-col col-name bg-white text-truncate" title="<%= activity.name %>">
                                <%= activity.name %>
                            </td>
                            <td class="sticky-col col-doc bg-white text-truncate">
                                <%= activity.document_ref %>
                            </td>

                            <% (1..31).each do |day| %>
                                <% 
                                   is_completed_day = activity.completed? && activity.completed_day == day 
                                   
                                   # Lógica de Semanas (1-4)
                                   week_num = activity.week.to_i
                                   range_start = (week_num - 1) * 7 + 1
                                   range_end   = week_num >= 4 ? 31 : range_start + 6
                                   is_planned_day = day >= range_start && day <= range_end
                                %>
                                <td class="text-center 
                                    <%= 'completed-day' if is_completed_day %> 
                                    <%= 'bg-light-gray' if is_planned_day && !is_completed_day %>">
                                    <% if is_completed_day %>
                                        <i class="mdi mdi-check font-10 text-white"></i>
                                    <% end %>
                                </td>
                            <% end %>

                            <td class="<%= 'area-active' if activity.area == 'Integral' %>"></td>
                            <td class="<%= 'area-active' if activity.area == 'Dirección' %>"></td>
                            <td class="<%= 'area-active' if activity.area == 'Finanzas' %>"></td>
                            <td class="<%= 'area-active' if activity.area == 'Procesos' %>"></td>
                            <td class="<%= 'area-active' if activity.area == 'Comercial' %>"></td>
                            <td class="<%= 'area-active' if activity.area == 'RH' %>"></td>

                            <td class="text-end fw-bold font-10"><%= number_to_currency(activity.activity_cost) %></td>
                            <td class="text-center text-muted"><%= activity.leader_hours.to_f > 0 ? activity.leader_hours : '-' %></td>
                            <td class="text-center text-muted"><%= activity.senior_hours.to_f > 0 ? activity.senior_hours : '-' %></td>
                            <td class="text-center text-muted"><%= activity.analyst_hours.to_f > 0 ? activity.analyst_hours : '-' %></td>
                        </tr>
                    <% end %> <% end %> <% end %> <tr style="height: 20px; border: none; background-color: #f4f5f7;">
                <td colspan="44" style="border:none;"></td>
            </tr>

        <% end %> </tbody>
    </table>
  </div>
</div>