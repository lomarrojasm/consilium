<div class="nested-fields mb-3 p-3 border rounded bg-light bg-opacity-50" data-new-record="<%= f.object.new_record? %>">
  <div class="row align-items-center">
    
    <%# Si la etapa es NUEVA, mostramos el menú de plantillas %>
    <% if f.object.new_record? %>
      <div class="col-md-5">
        <%= f.label :name, "Nombre de la Etapa", class: "form-label font-12 fw-bold text-muted text-uppercase" %>
        <%= f.text_field :name, class: "form-control shadow-sm border-0", placeholder: "Ej: Etapa 5 - Optimización", required: true %>
      </div>
      
      <div class="col-md-2">
        <%= f.label :position, "Posición", class: "form-label font-12 fw-bold text-muted text-uppercase" %>
        <%= f.number_field :position, class: "form-control shadow-sm border-0", required: true %>
      </div>

      <div class="col-md-4">
        <%= f.label :template_stage_number, "Cargar Actividades (Plantilla)", class: "form-label font-12 fw-bold text-primary text-uppercase" %>
        <%= f.select :template_stage_number, options_for_select([
            ['No cargar (Dejar vacía)', ''], 
            ['Etapa 1 (Alinear)', '1'], 
            ['Etapa 2 (Ordenar)', '2'], 
            ['Etapa 3 (Estandarizar)', '3'], 
            ['Etapa 4 (Mejora)', '4'], 
            ['Etapa 5 (Optimización)', '5'], 
            ['Etapa 6 (Excelencia)', '6']
          ]), {}, class: "form-select shadow-sm border-primary border-opacity-50 text-primary bg-primary bg-opacity-10" %>
      </div>

    <%# Si la etapa YA EXISTE, mostramos el diseño normal %>
    <% else %>
      <div class="col-md-8">
        <%= f.label :name, "Nombre de la Etapa", class: "form-label font-12 fw-bold text-muted text-uppercase" %>
        <%= f.text_field :name, class: "form-control shadow-sm border-0", required: true %>
      </div>
      
      <div class="col-md-3">
        <%= f.label :position, "Posición", class: "form-label font-12 fw-bold text-muted text-uppercase" %>
        <%= f.number_field :position, class: "form-control shadow-sm border-0", required: true %>
      </div>
    <% end %>

    <div class="col-md-1 text-end mt-4">
      <%= f.hidden_field :_destroy %>
      <button type="button" class="btn btn-outline-danger btn-sm border-0" data-action="click->nested-form#remove" title="Eliminar etapa">
        <i class="ri-delete-bin-line font-18"></i>
      </button>
    </div>
  </div>
</div>