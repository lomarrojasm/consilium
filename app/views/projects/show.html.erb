<%# app/views/projects/show.html.erb %>

<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <div class="d-flex flex-wrap gap-2 justify-content-end">
                    <%= link_to schedule_view_client_project_path(@client, @project), 
                        class: "btn btn-info shadow-sm", target: "_blank" do %> 
                        <i class="ri-calendar-todo-line me-1"></i> <span class="d-none d-sm-inline">Ver Cronograma</span>
                    <% end %>
                    
                    <% if ['admin', 'lider'].include?(current_project_role) %>
                        <button type="button" class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#membersModal">
                            <i class="ri-group-line me-1"></i> <span class="d-none d-sm-inline">Equipo</span>
                        </button>
                        <%= link_to edit_client_project_path(@client, @project), class: "btn btn-light shadow-sm" do %>
                            <i class="ri-settings-3-line"></i>
                        <% end %>
                        <button type="button" class="btn btn-outline-danger shadow-sm" onclick="confirmDeleteProject()">
                            <i class="ri-delete-bin-line"></i>
                        </button>
                    <% end %>
                </div>
            </div>
            <h4 class="page-title">Detalle del Proyecto</h4>
            <ol class="breadcrumb m-0 d-none d-md-flex">
                <li class="breadcrumb-item"><%= link_to "Consilium", current_user.role == "admin" ? root_path : client_dashboard_path %></li>
                <li class="breadcrumb-item"><%= link_to "Clientes", clients_path if current_user.role == "admin" %></li> 
                <li class="breadcrumb-item"><%= link_to @client.company_name, client_path(@client) %></li>                  
                <li class="breadcrumb-item active text-truncate" style="max-width: 150px;"><%= @project.name %></li>
            </ol>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card bg-primary text-white border-0 mb-3 shadow">
            <div class="card-body">
                <div class="row align-items-center text-center text-md-start">
                    <div class="col-md-4">
                        <h3 class="mt-0 text-white"><%= @project.name %></h3>
                        <div class="d-flex align-items-center justify-content-center justify-content-md-start gap-2 flex-wrap">
                            <span class="badge bg-white text-primary px-2"><%= @client.company_name %></span>
                            <span class="badge bg-info-lighten text-info border border-info"><%= @project.status&.humanize&.upcase || "SIN ESTATUS" %></span>
                        </div>
                    </div>
                    <div class="col-md-2 mt-3 mt-md-0 responsive-border-start border-opacity-25">
                        <p class="mb-0 opacity-75 font-12 text-uppercase fw-bold">Presupuesto</p>
                        <h3 class="text-white my-0"><%= number_to_currency(@project.budget || 0) %></h3>
                    </div>
                    <div class="col-md-2 mt-3 mt-md-0 responsive-border-start border-opacity-25">
                        <p class="mb-0 opacity-75 font-12 text-uppercase fw-bold">Costo Real</p>
                        <h3 class="text-white my-0"><%= number_to_currency(@project.activities.sum(:activity_cost)) %></h3>
                    </div>
                    <div class="col-md-4 mt-3 mt-md-0 responsive-border-start border-opacity-25">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <p class="mb-0 opacity-75 font-12 text-uppercase fw-bold">Progreso General</p>
                            <p class="mb-0 font-14 fw-bold"><%= @project.progress_percentage %>%</p>
                        </div>
                        <div class="progress progress-sm bg-white bg-opacity-25" style="height: 8px;">
                            <div class="progress-bar bg-success" role="progressbar" style="width: <%= @project.progress_percentage %>%;"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-8">
        <% if current_user.role == 'admin' %>
            <div class="card mb-3 border-dashed shadow-none border-primary bg-light bg-opacity-10">
                <div class="card-body py-2 d-flex flex-column flex-sm-row justify-content-between align-items-sm-center gap-2">
                    <div>
                        <h6 class="m-0 fw-bold text-primary"><i class="ri-eye-off-line me-1"></i> Control de Etapas Secuenciales</h6>
                        <small class="text-muted">Si está activo, el cliente solo verá la siguiente etapa cuando la actual supere el 90%.</small>
                    </div>
                    <%= form_with(model: [@client, @project], local: true, class: "d-inline") do |f| %>
                        <div class="form-check form-switch m-0">
                            <%= f.check_box :sequential_stages, class: "form-check-input cursor-pointer", onchange: "this.form.submit()" %>
                            <label class="form-check-label fw-bold"><%= @project.sequential_stages ? "Activo" : "Inactivo" %></label>
                        </div>
                    <% end %>
                </div>
            </div>
        <% end %>

        <div class="card shadow-none border mb-3">
            <div class="card-body" style="min-height: 160px;">
                <h5 class="text-uppercase mt-0 mb-2 font-12 fw-bold text-muted">Descripción del Proyecto</h5>
                <p class="text-muted mb-0"><%= @project.details.present? ? @project.details : "Sin descripción detallada." %></p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-none border mb-2">
            <div class="card-body py-2">
                <h5 class="text-uppercase mt-0 mb-2 font-11 fw-bold text-primary"><i class="ri-shield-user-line me-1"></i> Responsable del Proyecto</h5>
                <div class="d-flex align-items-center">
                    <% if @project.responsible.present? %>
                        <div class="avatar-sm me-2">
                            <% if @project.responsible.avatar.attached? %>
                                <%= image_tag url_for(@project.responsible.avatar), class: "rounded-circle img-thumbnail", style: "width: 42px; height: 42px; object-fit: cover;" %>
                            <% else %>
                                <span class="avatar-title rounded-circle bg-primary text-white font-14 fw-bold">
                                    <%= @project.responsible.first_name[0] %><%= @project.responsible.last_name[0] %>
                                </span>
                            <% end %>
                        </div>
                        <div>
                            <h5 class="font-14 mb-0 fw-bold"><%= @project.responsible.full_name %></h5>
                            <p class="mb-0 text-muted font-12">Líder de Cuenta</p>
                        </div>
                    <% else %>
                        <p class="text-muted font-11 mb-0 italic">Responsable no asignado.</p>
                    <% end %>
                </div>
            </div>
        </div>

        <div class="card shadow-none border mb-3">
            <div class="card-body py-2">
                <h5 class="text-uppercase mt-0 mb-2 font-11 fw-bold text-muted">Equipo de Trabajo</h5>
                <div class="d-flex flex-wrap gap-1">
                    <% if @project.users.any? %>
                        <% @project.users.each do |member| %>
                            <div class="avatar-xs" data-bs-toggle="tooltip" title="<%= member.full_name %>">
                                <% if member.avatar.attached? %>
                                    <%= image_tag url_for(member.avatar), class: "rounded-circle border", style: "width: 28px; height: 28px; object-fit: cover;" %>
                                <% else %>
                                    <span class="avatar-title rounded-circle bg-soft-secondary text-secondary font-10 fw-bold">
                                        <%= member.first_name[0] %><%= member.last_name[0] %>
                                    </span>
                                <% end %>
                            </div>
                        <% end %>
                    <% else %>
                        <span class="text-muted font-11">Sin miembros adicionales.</span>
                    <% end %>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-2">
            <h4 class="header-title m-0 text-primary"><i class="ri-list-check-2 me-1"></i> Plan de Trabajo y Etapas</h4>
            <div class="d-flex flex-wrap gap-2">
                <%= link_to comments_client_project_path(@client, @project), class: "btn btn-sm btn-outline-primary" do %>
                    <i class="ri-chat-history-line me-1"></i> Bitácora (<%= @project.comments.count %>)
                <% end %>
                <% if ['admin', 'lider', 'senior', 'analista'].include?(current_project_role) %>
                    <%= link_to new_client_project_activity_path(@client, @project), class: "btn btn-sm btn-primary" do %>
                        <i class="ri-add-line"></i> Nueva Tarea
                    <% end %>
                <% end %>
            </div>
        </div>

        <div class="accordion custom-accordion mb-4" id="projectStages">
            <% @stages.each_with_index do |stage, index| %>
                <% 
                   is_unlocked = @project.stage_unlocked?(stage)
                   is_admin = current_user.role == 'admin'
                   should_show = is_admin || is_unlocked
                %>

                <% if should_show %>
                    <div class="card mb-2 border shadow-none <%= 'border-primary' if is_unlocked && stage.progress_percentage < 100 %>">
                        <div class="card-header d-flex justify-content-between align-items-center bg-white border-bottom py-2">
                            <a class="text-dark d-flex align-items-center flex-grow-1 <%= 'collapsed' unless index == 0 || (is_unlocked && stage.progress_percentage < 100) %>" 
                               data-bs-toggle="collapse" href="#stage-<%= stage.id %>">
                                
                                <% if stage.progress_percentage > 90 %>
                                    <i class="ri-checkbox-circle-fill me-2 text-success font-20"></i>
                                <% elsif is_unlocked %>
                                    <i class="ri-play-circle-line me-2 text-primary font-20"></i>
                                <% else %>
                                    <i class="ri-lock-line me-2 text-muted font-20"></i>
                                <% end %>

                                <h5 class="m-0 font-15 fw-bold me-3 text-truncate">
                                    <%= stage.name %>
                                    <% unless is_unlocked %>
                                        <span class="badge bg-soft-secondary text-muted font-10 ms-1 fw-normal d-none d-sm-inline">BLOQUEADA</span>
                                    <% end %>
                                </h5>

                                <div class="d-none d-md-flex align-items-center flex-grow-1" style="max-width: 200px;">
                                    <div class="progress progress-sm w-100 me-2" style="height: 6px;">
                                        <div class="progress-bar bg-success" role="progressbar" style="width: <%= stage.progress_percentage %>%;"></div>
                                    </div>
                                    <span class="font-12 fw-bold text-success"><%= stage.progress_percentage %>%</span>
                                </div>
                            </a>
                            
                            <% if ['admin', 'lider', 'senior'].include?(current_project_role) %>
                                <div class="dropdown">
                                    <a href="#" class="dropdown-toggle arrow-none card-drop" data-bs-toggle="dropdown"><i class="ri-more-2-fill text-muted"></i></a>
                                    <div class="dropdown-menu dropdown-menu-end shadow border-0">
                                        <%= link_to edit_client_project_stage_path(@client, @project, stage), class: "dropdown-item" do %>
                                            <i class="ri-edit-line me-1"></i> Editar Etapa
                                        <% end %>
                                        <% if ['admin', 'lider'].include?(current_project_role) %>
                                            <%= button_to client_project_stage_path(@client, @project, stage), method: :delete, class: "dropdown-item text-danger", form: { onsubmit: "return confirm('¿Borrar etapa?');" } do %>
                                                <i class="ri-delete-bin-line me-1"></i> Eliminar
                                            <% end %>
                                        <% end %>
                                    </div>
                                </div>
                            <% end %>
                        </div>

                        <div id="stage-<%= stage.id %>" class="collapse <%= 'show' if index == 0 || (is_unlocked && stage.progress_percentage < 100 && stage.progress_percentage > 0) %>">
                            <div class="card-body p-0">
                                <div class="table-responsive-sm">
                                    <table class="table table-centered table-hover mb-0 align-middle">
                                        <thead class="table-light text-muted font-11 uppercase">
                                            <tr>
                                                <th class="text-center px-1 px-md-2" style="width: 40px;" title="Estatus">St</th>
                                                <th style="min-width: 180px;">Actividad (Panel)</th>
                                                
                                                <th class="d-none d-lg-table-cell">Prog.</th>
                                                <th class="d-none d-lg-table-cell">Área</th>
                                                <th class="d-none d-md-table-cell">Responsable</th>
                                                
                                                <th class="text-center px-1 px-md-2" title="Evidencia"><i class="ri-file-list-3-line font-16 text-primary"></i></th>
                                                <th class="text-center px-1 px-md-2" title="Aprob. Cliente"><i class="ri-user-star-line font-16 text-primary"></i></th>
                                                <th class="text-center px-1 px-md-2" title="Aprob. Admin"><i class="ri-shield-check-line font-16 text-primary"></i></th>
                                                <th class="text-end px-1 px-md-2"><i class="ri-more-2-fill font-16"></i></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% stage.activities.order(:month, :week).each do |activity| %>
                                                <% is_finalized = activity.admin_approved && activity.user_approved %>
                                                
                                                <tr class="<%= 'bg-light-subtle' if activity.status == 'rejected' %> <%= 'bg-success bg-opacity-10' if is_finalized %>">
                                                    
                                                    <td class="text-center px-1 px-md-2">
                                                        <% if is_finalized %>
                                                            <a href="javascript:void(0);" onclick="verSeguimientoActividad('<%= activity.id %>')" class="text-success hover-primary" data-bs-toggle="tooltip" title="Finalizada - Clic para visualizar">
                                                                <i class="ri-eye-fill font-22"></i>
                                                            </a>
                                                        <% elsif activity.user_approved %>
                                                            <i class="ri-user-star-fill font-20 text-primary" data-bs-toggle="tooltip" title="Aprobado por Cliente - Esperando Consilium"></i>
                                                        <% elsif activity.evidence.attached? || activity.completed %>
                                                            <i class="ri-file-shield-2-fill font-20 text-info" data-bs-toggle="tooltip" title="Evidencia Subida - Esperando V.B. Cliente"></i>
                                                        <% elsif activity.status == 'rejected' %>
                                                            <i class="ri-close-circle-fill font-20 text-danger" data-bs-toggle="tooltip" title="Rechazada / Con Problemas"></i>
                                                        <% else %>
                                                            <i class="ri-time-line font-20 text-warning" data-bs-toggle="tooltip" title="En Proceso"></i>
                                                        <% end %>
                                                    </td>
                                                    
                                                    <td style="white-space: normal;">
                                                        <a href="javascript:void(0);" 
                                                           onclick="verSeguimientoActividad('<%= activity.id %>')"
                                                           class="<%= 'text-decoration-line-through text-muted italic' if is_finalized %> font-13 fw-bold text-body hover-primary d-block mb-1">
                                                            <i class="ri-dashboard-line me-1 text-primary"></i> <%= activity.name %>
                                                        </a>
                                                        
                                                        <div class="d-flex flex-wrap gap-1 d-lg-none mb-1">
                                                            <span class="badge bg-light text-dark border font-10">M<%= activity.month %>-S<%= activity.week %></span>
                                                            <span class="badge bg-light text-secondary border font-10"><%= activity.area %></span>
                                                            <% if activity.responsible.present? %>
                                                                <span class="badge bg-soft-info text-info font-10 d-md-none"><i class="ri-user-line"></i> <%= activity.responsible.first_name %></span>
                                                            <% end %>
                                                        </div>

                                                        <% if activity.evidence_uploaded_at %>
                                                            <div class="font-10 text-muted"><i class="ri-upload-cloud-line me-1"></i>Evid: <%= activity.evidence_uploaded_at.strftime("%d/%m/%y %H:%M") %></div>
                                                        <% end %>
                                                    </td>
                                                    
                                                    <td class="d-none d-lg-table-cell">
                                                        <span class="text-muted font-12 fw-bold">M<%= activity.month %></span>
                                                        <span class="badge badge-outline-secondary px-1 ms-1">S<%= activity.week %></span>
                                                    </td>
                                                    
                                                    <td class="d-none d-lg-table-cell">
                                                        <span class="font-10 text-uppercase text-secondary"><%= activity.area %></span>
                                                    </td>
                                                    
                                                    <td class="d-none d-md-table-cell">
                                                        <% if activity.responsible.present? %>
                                                            <div class="d-flex align-items-center">
                                                                <% if activity.responsible.avatar.attached? %>
                                                                    <%= image_tag url_for(activity.responsible.avatar), class: "rounded-circle me-2", style: "width: 24px; height: 24px; object-fit: cover;" %>
                                                                <% else %>
                                                                    <div class="avatar-xs me-2" style="width: 24px; height: 24px;">
                                                                        <span class="avatar-title rounded-circle bg-soft-info text-info font-10 fw-bold">
                                                                            <%= activity.responsible.first_name[0] %><%= activity.responsible.last_name[0] %>
                                                                        </span>
                                                                    </div>
                                                                <% end %>
                                                                <span class="font-12"><%= activity.responsible.first_name %></span>
                                                            </div>
                                                        <% else %>
                                                            <span class="text-muted font-11 italic">No asignado</span>
                                                        <% end %>
                                                    </td>
                                                    
                                                    <td class="text-center px-1 px-md-2">
                                                        <div class="d-flex align-items-center justify-content-center gap-1">
                                                            <% if activity.evidence.attached? %>
                                                                <%= link_to rails_blob_path(activity.evidence, disposition: "attachment"), class: "text-success", target: "_blank", data: { bs_toggle: "tooltip" }, title: "Descargar" do %>
                                                                    <i class="ri-file-check-line font-20"></i>
                                                                <% end %>
                                                            <% else %>
                                                                <i class="ri-file-history-line font-18 text-muted opacity-50"></i>
                                                            <% end %>
                                                            
                                                            <%# SIN RESTRICCIÓN DE ROL: El cliente (y tú en impersonate) ven este botón para subir evidencia %>
                                                            <% if !is_finalized || current_user.role == 'admin' %>
                                                                <button type="button" class="btn btn-sm btn-link text-muted p-0 hover-primary ms-1" 
                                                                        onclick="openUploadModal('<%= activity.id %>', '<%= activity.name %>')" 
                                                                        data-bs-toggle="tooltip" title="Subir Evidencia Rápida">
                                                                    <i class="ri-upload-2-line font-18"></i>
                                                                </button>
                                                            <% end %>
                                                        </div>
                                                    </td>

                                                    <td class="text-center px-1 px-md-2">
                                                        <div class="d-flex flex-column align-items-center">
                                                            <%= form_with url: toggle_user_approval_client_project_activity_path(@client, @project, activity), method: :patch, local: true do %>
                                                                <div class="form-check m-0">
                                                                    <input type="checkbox" class="form-check-input border-primary shadow-none cursor-pointer" 
                                                                           <%= 'checked' if activity.user_approved %> 
                                                                           onchange="this.form.submit()"
                                                                           <%= 'disabled' if (!activity.completed && !activity.evidence.attached?) || activity.admin_approved %>>
                                                                </div>
                                                            <% end %>
                                                            <% if activity.user_approved_at %>
                                                                <span class="font-9 text-muted mt-1 lh-1 fw-bold text-primary d-none d-sm-block"><%= activity.user_approved_at.strftime("%d/%m/%y") %></span>
                                                            <% end %>
                                                        </div>
                                                    </td>

                                                    <td class="text-center px-1 px-md-2">
                                                        <div class="d-flex flex-column align-items-center">
                                                            <%= form_with url: toggle_admin_approval_client_project_activity_path(@client, @project, activity), method: :patch, local: true do %>
                                                                <div class="form-check m-0">
                                                                    <%# PERFECTA SIMULACIÓN: Si estás en Impersonate, eres 'user', por lo que verás esto gris y deshabilitado. %>
                                                                    <input type="checkbox" class="form-check-input border-danger shadow-none cursor-pointer" 
                                                                           <%= 'checked' if activity.admin_approved %> 
                                                                           onchange="this.form.submit()"
                                                                           <%= 'disabled' unless current_user.role == 'admin' && activity.user_approved %>>
                                                                </div>
                                                            <% end %>
                                                            <% if activity.admin_approved_at %>
                                                                <span class="font-9 text-muted mt-1 lh-1 fw-bold text-danger d-none d-sm-block"><%= activity.admin_approved_at.strftime("%d/%m/%y") %></span>
                                                            <% end %>
                                                        </div>
                                                    </td>

                                                    <td class="text-end px-1 px-md-2">
                                                        <% if ['admin', 'lider', 'senior', 'analista'].include?(current_project_role) %>
                                                            <div class="dropdown">
                                                                <a href="#" class="text-muted dropdown-toggle arrow-none" data-bs-toggle="dropdown"><i class="ri-more-fill font-18"></i></a>
                                                                <div class="dropdown-menu dropdown-menu-end shadow border-0">
                                                                    <a href="javascript:void(0);" onclick="verSeguimientoActividad('<%= activity.id %>')" class="dropdown-item font-13 fw-bold text-primary">
                                                                        <i class="ri-eye-line me-1"></i> Abrir Panel
                                                                    </a>
                                                                    
                                                                    <% if !is_finalized || current_user.role == 'admin' %>
                                                                        <div class="dropdown-divider"></div>
                                                                        <%= link_to edit_client_project_activity_path(@client, @project, activity), class: "dropdown-item font-13" do %>
                                                                            <i class="ri-edit-line me-1"></i> Editar
                                                                        <% end %>
                                                                        <% if ['admin', 'lider'].include?(current_project_role) %>
                                                                            <%= link_to client_project_activity_path(@client, @project, activity), 
                                                                                data: { turbo_method: :delete, turbo_confirm: "¿Eliminar actividad?" }, class: "dropdown-item text-danger font-13" do %>
                                                                                <i class="ri-delete-bin-line me-1"></i> Eliminar
                                                                            <% end %>
                                                                        <% end %>
                                                                    <% end %>
                                                                </div>
                                                            </div>
                                                        <% end %>
                                                    </td>
                                                </tr>
                                            <% end %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                <% end %>
            <% end %>
        </div>
        
        <% if ['admin', 'lider', 'senior'].include?(current_project_role) %>
            <div class="text-center mb-4">
                <%= link_to new_client_project_stage_path(@client, @project), class: "btn btn-outline-primary btn-sm border-dashed w-100 py-2" do %>
                    <i class="ri-add-circle-line me-1"></i> Agregar Nueva Etapa de Proyecto
                <% end %>
            </div>
        <% end %>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card border shadow-none">
            <div class="card-header bg-white d-flex flex-wrap justify-content-between align-items-center py-2 gap-2">
                <h5 class="card-title m-0 font-14"><i class="ri-folder-zip-line me-1 text-primary"></i> Repositorio de Documentos</h5>
                <% if ['admin', 'lider', 'senior', 'analista'].include?(current_project_role) %>
                    <%= form_with(model: [@client, @project], local: true, html: { multipart: true, class: "d-flex gap-2 flex-grow-1 flex-md-grow-0" }) do |f| %>
                        <%= f.file_field :files, multiple: true, class: "form-control form-control-sm flex-grow-1", style: "max-width: 250px;" %>
                        <button type="submit" class="btn btn-sm btn-primary"><i class="ri-upload-cloud-2-line"></i></button>
                    <% end %>
                <% end %>
            </div>
            <div class="card-body p-3">
                <div class="row">
                    <% if @project.files.attached? %>
                        <% @project.files.each do |file| %>
                            <div class="col-md-3 col-sm-6 mb-2">
                                <div class="p-2 border rounded d-flex align-items-center justify-content-between bg-light bg-opacity-25 shadow-none">
                                    <div class="d-flex align-items-center overflow-hidden">
                                        <%= link_to rails_blob_path(file, disposition: "inline"), target: "_blank", class: "text-secondary me-2" do %>
                                            <i class="ri-file-line font-24"></i>
                                        <% end %>
                                        <div class="overflow-hidden">
                                            <%= link_to rails_blob_path(file, disposition: "inline"), target: "_blank", class: "text-body d-block" do %>
                                                <h6 class="font-12 mb-0 text-truncate fw-bold" title="<%= file.filename %>"><%= file.filename %></h6>
                                            <% end %>
                                            <small class="text-muted font-11"><%= number_to_human_size(file.byte_size) %></small>
                                        </div>
                                    </div>
                                    
                                    <div class="dropdown">
                                        <a href="#" class="dropdown-toggle arrow-none text-muted" data-bs-toggle="dropdown"><i class="ri-more-v-line"></i></a>
                                        <div class="dropdown-menu dropdown-menu-end shadow border-0">
                                            <%= link_to rails_blob_path(file, disposition: "inline"), target: "_blank", class: "dropdown-item font-12" do %>
                                                <i class="ri-eye-line me-1 text-primary"></i> Ver en línea
                                            <% end %>
                                            <%= link_to rails_blob_path(file, disposition: "attachment"), class: "dropdown-item font-12" do %>
                                                <i class="ri-download-line me-1 text-success"></i> Descargar
                                            <% end %>
                                            <% if ['admin', 'lider'].include?(current_project_role) %>
                                                <div class="dropdown-divider"></div>
                                                <%= button_to delete_file_client_project_path(@client, @project, attachment_id: file.id), 
                                                    method: :delete, 
                                                    class: "dropdown-item text-danger font-12", 
                                                    form: { onsubmit: "return confirm('¿Eliminar este archivo permanentemente?');" } do %>
                                                    <i class="ri-delete-bin-line me-1"></i> Eliminar
                                                <% end %>
                                            <% end %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% end %>
                    <% else %>
                        <div class="col-12 text-center py-4 text-muted">
                            <i class="ri-folder-open-line font-24 d-block mb-1 opacity-50"></i>
                            <p class="mb-0 font-13">No se han cargado documentos adicionales.</p>
                        </div>
                    <% end %>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="membersModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content shadow-lg border-0">
            <div class="modal-header">
                <h5 class="modal-title"><i class="ri-group-line me-1"></i> Equipo del Proyecto</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <% if ['admin', 'lider'].include?(current_project_role) %>
                    <div class="bg-light p-3 rounded mb-4">
                        <h6 class="fw-bold mb-3 font-13">Agregar Miembro</h6>
                        <%= form_with(url: client_project_project_members_path(@client, @project), scope: :project_member, local: true) do |f| %>
                            <div class="form-floating mb-3">
                                <%= f.collection_select :user_id, @eligible_users, :id, :full_name, { prompt: "" }, { class: "form-select", required: true } %>
                                <label>Seleccionar Usuario</label>
                            </div>
                            <div class="row g-2 align-items-center">
                                <div class="col-8">
                                    <div class="form-floating">
                                        <%= f.select :role, [['Líder', 'lider'], ['Senior', 'senior'], ['Analista', 'analista'], ['Espectador', 'espectador']], {}, class: "form-select" %>
                                        <label>Rol asignado</label>
                                    </div>
                                </div>
                                <div class="col-4">
                                    <%= f.submit "Añadir", class: "btn btn-primary w-100 py-2 h-100" %>
                                </div>
                            </div>
                        <% end %>
                    </div>
                <% end %>

                <h6 class="fw-bold mb-2 font-13 text-muted uppercase">Miembros Actuales</h6>
                <div class="list-group list-group-flush">
                    <% @project.project_members.includes(:user).each do |membership| %>
                        <div class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <div class="d-flex align-items-center">
                                <div class="avatar-xs me-2">
                                    <% if membership.user.avatar.attached? %>
                                        <%= image_tag url_for(membership.user.avatar), class: "rounded-circle", style: "width: 24px; height: 24px; object-fit: cover;" %>
                                    <% else %>
                                        <span class="avatar-title rounded-circle bg-primary-light text-primary font-11 fw-bold">
                                            <%= membership.user.first_name[0] %>
                                        </span>
                                    <% end %>
                                </div>
                                <div>
                                    <h5 class="font-13 mb-0 fw-bold"><%= membership.user.full_name %></h5>
                                    <small class="text-muted"><%= membership.role&.humanize %></small>
                                </div>
                            </div>
                            <% if ['admin', 'lider'].include?(current_project_role) %>
                                <%= button_to client_project_project_member_path(@client, @project, membership), method: :delete, class: "btn btn-xs btn-outline-danger border-0", form: { onsubmit: "return confirm('¿Quitar del equipo?');" } do %>
                                    <i class="ri-close-line"></i>
                                <% end %>
                            <% end %>
                        </div>
                    <% end %>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="uploadEvidenceModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content shadow-lg border-0">
      <div class="modal-header bg-success text-white">
        <h5 class="modal-title"><i class="ri-upload-cloud-line me-1"></i> Carga Rápida de Evidencia</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <%= form_with scope: :activity, 
                    url: upload_evidence_client_project_activity_path(@client, @project, '0'), 
                    method: :patch, 
                    id: "evidenceForm", 
                    local: true, 
                    multipart: true do |f| %>
        
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

        <div class="modal-body p-4">
          <p class="mb-1 text-muted font-12 uppercase fw-bold">Actividad:</p>
          <h5 id="modalActivityName" class="text-primary mt-0 mb-4"></h5>
          <div class="alert alert-info border-0 font-13 mb-4">
            <i class="ri-information-line me-1"></i> Adjuntar la evidencia habilitará el proceso de aprobación para el cliente.
          </div>
          <div class="mb-3">
            <label class="form-label font-13 fw-bold">Archivo de Evidencia</label>
            <%= f.file_field :evidence, class: "form-control", required: true %>
          </div>
        </div>
        <div class="modal-footer bg-light">
          <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
          <%= f.submit "Cargar y Sellar Historial", class: "btn btn-success px-4 shadow-sm" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<div class="modal fade" id="activityDetailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content shadow-lg border-0" id="modalActivityDetailContent">
            <div class="modal-body text-center p-5">
                <div class="spinner-border text-primary" role="status"></div>
                <p class="mt-2 text-muted fw-bold">Conectando con el Centro de Mando...</p>
            </div>
        </div>
    </div>
</div>

<script>
    function confirmDeleteProject() {
        Swal.fire({
            title: '¿Eliminar Proyecto?',
            text: "Esta acción borrará permanentemente el proyecto '<%= @project.name %>', sus etapas, tareas y archivos. ¡No se puede deshacer!",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#fa5c7c',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Sí, eliminar todo',
            cancelButtonText: 'Cancelar',
            reverseButtons: true
        }).then((result) => {
            if (result.isConfirmed) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '<%= client_project_path(@client, @project) %>';
                const methodInput = document.createElement('input');
                methodInput.type = 'hidden';
                methodInput.name = '_method';
                methodInput.value = 'delete';
                form.appendChild(methodInput);
                const csrfInput = document.createElement('input');
                csrfInput.type = 'hidden';
                csrfInput.name = 'authenticity_token';
                csrfInput.value = document.querySelector('meta[name="csrf-token"]').content;
                form.appendChild(csrfInput);
                document.body.appendChild(form);
                form.submit();
            }
        })
    }

    function openUploadModal(activityId, activityName) {
        document.getElementById('modalActivityName').textContent = activityName;
        let baseUrl = "<%= upload_evidence_client_project_activity_path(@client, @project, 'REPLACE_ID') %>";
        let finalUrl = baseUrl.replace('REPLACE_ID', activityId);
        document.getElementById('evidenceForm').action = finalUrl;
        new bootstrap.Modal(document.getElementById('uploadEvidenceModal')).show();
    }

    function verSeguimientoActividad(activityId) {
        const url = `/clients/<%= @client.id %>/projects/<%= @project.id %>/activities/${activityId}/tracking`; 
        const contentArea = document.getElementById('modalActivityDetailContent');
        const modalElement = document.getElementById('activityDetailModal');
        const modal = new bootstrap.Modal(modalElement);

        fetch(url, { headers: { 'Accept': 'text/html' } })
        .then(response => response.text())
        .then(html => {
            contentArea.innerHTML = html;
            modal.show();
        });
    }
</script>

