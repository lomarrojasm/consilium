<%# app/views/public_quotations/show.html.erb %>
<div class="container mt-5 mb-5">
  <div class="row justify-content-center">
    <div class="col-md-9 col-lg-8">
      
      <div class="text-center mb-4">
        <%# Aquí va tu logo de Consilium %>
        <h2 class="fw-bold text-dark tracking-wider">Consilium S.C.</h2>
        <p class="text-muted text-uppercase font-12 tracking-wider fw-bold">Revisión y Autorización Comercial</p>
      </div>

      <div class="card shadow-lg border-0" style="border-radius: 16px;">
        <div class="card-header bg-white p-4 border-bottom text-center">
          <h4 class="mb-0 text-primary fw-bold">Cotización #COT-<%= @quotation.id %></h4>
          <span class="badge <%= @quotation.aceptado? || @quotation.facturado? || @quotation.pagado? ? 'bg-success' : 'bg-warning text-dark border border-warning' %> mt-2 font-11 text-uppercase tracking-wider px-3 py-2 rounded-pill shadow-sm">
            <%= @quotation.status %>
          </span>
        </div>

        <div class="card-body p-4 p-md-5">
          <div class="row mb-5 font-14">
            <div class="col-sm-6">
              <h6 class="text-muted text-uppercase fw-bold mb-2 font-11 tracking-wider">Facturar A:</h6>
              <p class="fw-bold mb-0 text-dark fs-6"><%= @quotation.client.company_name %></p>
              <p class="mb-0 text-muted">RFC: <%= @quotation.client.rfc %></p>
            </div>
            <div class="col-sm-6 text-sm-end mt-4 mt-sm-0">
              <h6 class="text-muted text-uppercase fw-bold mb-2 font-11 tracking-wider">Proyecto Relacionado:</h6>
              <p class="fw-bold text-dark mb-0 fs-6"><%= @quotation.project.name %></p>
              <p class="mb-0 text-muted font-12">Fecha de Emisión: <%= @quotation.created_at.strftime("%d/%m/%Y") %></p>
            </div>
          </div>

          <h6 class="text-primary border-bottom pb-2 mb-3 fw-bold text-uppercase tracking-wider font-12"><i class="ri-list-check-2 me-1"></i> Conceptos a Facturar</h6>
          
          <div class="table-responsive mb-4">
            <table class="table table-sm table-hover mb-0 font-13">
              <thead class="table-light text-muted font-11 text-uppercase tracking-wider">
                <tr>
                  <th class="py-2 ps-2">Descripción del Concepto</th>
                  <th class="py-2 text-end">Costo Original</th>
                  <th class="py-2 text-end pe-2">Importe a Facturar</th>
                </tr>
              </thead>
              <tbody>
                <%# REGLA DE ORO: Iterar sobre quotation_items para obtener montos parciales %>
                <% @quotation.quotation_items.includes(:financial_accrual).each do |q_item| %>
                  <% 
                     accrual = q_item.financial_accrual 
                     is_partial = q_item.amount < (accrual.amount - 0.01)
                  %>
                  <tr>
                    <td class="py-3 ps-2">
                      <strong class="text-dark"><%= accrual.concept_name %></strong>
                      <% if is_partial %>
                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle ms-2 font-9 tracking-wider">COBERTURA PARCIAL</span>
                      <% end %>
                      <br>
                      <span class="text-muted font-11"><%= accrual.stage_name %></span>
                    </td>
                    <td class="py-3 text-end align-middle font-monospace text-muted">
                      <%= is_partial ? number_to_currency(accrual.amount) : '<span class="text-light-subtle">-</span>'.html_safe %>
                    </td>
                    <td class="py-3 text-end pe-2 align-middle font-monospace fw-bold text-dark">
                      <%= number_to_currency(q_item.amount) %>
                    </td>
                  </tr>
                <% end %>
                <tr class="table-light border-top border-2 border-dark">
                  <td colspan="2" class="text-end fw-bold text-uppercase tracking-wider py-3">Total a Facturar:</td>
                  <td class="text-end pe-2 fw-bold text-success font-monospace py-3" style="font-size: 1.2rem;"><%= number_to_currency(@quotation.total_amount) %></td>
                </tr>
              </tbody>
            </table>
          </div>

          <% if @quotation.aceptado? || @quotation.facturado? || @quotation.pagado? %>
            <%# VISTA DE EVIDENCIA LEGAL (Ya firmado) %>
            <div class="bg-success bg-opacity-10 p-4 rounded-3 border border-success border-opacity-25 text-center mt-5 shadow-sm">
              <i class="ri-shield-check-fill text-success" style="font-size: 48px;"></i>
              <h4 class="text-success fw-bold">Acuerdo Autorizado</h4>
              <p class="text-muted font-13 mb-3">La emisión de facturación ha sido aprobada legalmente por el cliente.</p>
              
              <div class="text-start bg-white p-3 rounded border font-11 font-monospace text-muted mt-3 shadow-sm">
                <div class="row">
                    <div class="col-md-6 mb-2">
                        <strong class="d-block text-uppercase tracking-wider">ID de Transacción:</strong> 
                        <span class="text-primary"><%= @quotation.auth_code %></span>
                    </div>
                    <div class="col-md-6 mb-2">
                        <strong class="d-block text-uppercase tracking-wider">Sello de Tiempo:</strong> 
                        <span class="text-dark"><%= @quotation.accepted_at.strftime("%d/%m/%Y %H:%M:%S") %></span>
                    </div>
                    <div class="col-md-6 mb-2 mb-md-0">
                        <strong class="d-block text-uppercase tracking-wider">Dirección IP:</strong> 
                        <span class="text-dark"><%= @quotation.ip_address %></span>
                    </div>
                    <div class="col-md-6">
                        <strong class="d-block text-uppercase tracking-wider">Dispositivo:</strong> 
                        <span class="text-dark" title="<%= @quotation.user_agent %>"><%= @quotation.user_agent.truncate(45) %></span>
                    </div>
                </div>
              </div>
            </div>
          <% else %>
            <%# VISTA PARA FIRMAR %>
            <div class="bg-light p-4 rounded-3 border border-light mt-5 font-12 text-muted text-justify shadow-sm">
              <h6 class="text-dark fw-bold mb-2"><i class="ri-article-line me-1"></i> Declaración Legal y Condiciones Generales</h6>
              <%= simple_format(@quotation.legal_text) %>
            </div>

            <div class="mt-4 pt-3 border-top">
              <%= button_to authorize_public_quotation_path(code: @quotation.auth_code), 
                    method: :post, 
                    class: "btn btn-primary btn-lg w-100 shadow rounded-pill fw-bold",
                    data: { turbo_confirm: "Al hacer clic, tu dirección IP (#{request.remote_ip}) quedará registrada como firma electrónica y evidencia legal de aceptación. ¿Autorizas la facturación?" } do %>
                <i class="ri-check-double-line me-1"></i> Autorizar Facturación por <%= number_to_currency(@quotation.total_amount) %>
              <% end %>
            </div>
          <% end %>

        </div>
      </div>
      
      <div class="text-center mt-4 mb-5 text-muted font-11 tracking-wider text-uppercase">
         <p>Documento generado por el sistema de control financiero de Consilium.</p>
      </div>

    </div>
  </div>
</div>