<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item"><a href="<%= root_path %>">Consilium</a></li>
                    <li class="breadcrumb-item active">Clientes</li>
                </ol>
            </div>
            <h4 class="page-title">Cartera de Clientes</h4>
        </div>
    </div>
</div>

<div class="row">
  <div class="col-12">
    <div class="card shadow-sm border-0">
      <div class="card-body">
        <div class="row mb-2">
          <div class="col-sm-12 text-sm-end">
              <%= link_to new_client_path, class: "btn btn-primary rounded-pill mb-2" do %>
                <i class="mdi mdi-plus-circle me-2"></i> Agregar Cliente
              <% end %>
          </div>
        </div>

        <div class="table-responsive">
          <table class="table table-centered table-hover border-0 w-100" id="clients-datatable">
            <thead class="table-light opacity-75">
                <tr>
                    <th class="text-center" style="width: 50px;">Logo</th>
                    <th>Razón Social / Comercial</th>
                    <th class="text-center">RFC</th>
                    <th>Industria</th>
                    <th>Contacto Principal</th>
                    <th class="text-center">Timeline</th>
                </tr>
            </thead>
            <tbody>
            <% @clients.each do |client| %>
                <tr>
                    <td class="text-center">
                        <% if client.avatar.attached? %>
                            <%= image_tag url_for(client.avatar), class: "rounded-circle avatar-xs shadow-sm border" %>
                        <% else %>
                            <%= image_tag "icono_consilium.jpg", class: "rounded-circle avatar-xs shadow-sm border" %>
                        <% end %>
                    </td>
                    <td>
                        <div class="d-flex flex-column">
                            <%= link_to client.company_name, client_path(client), class: "fw-bold text-dark" %>
                            <small class="text-muted"><%= client.trade_name %></small>
                        </div>
                    </td>
                    <td class="text-center">
                        <span class="badge bg-light text-primary border"><%= client.rfc %></span>
                    </td>
                    <td>
                       <span class="font-13"><%= client.industry %></span>
                    </td>
                    <td>
                        <div class="d-flex flex-column">
                            <span class="font-13 fw-medium"><%= client.sponsor_name %></span>
                            <small class="text-info"><%= client.sponsor_email rescue '' %></small>
                        </div>
                    </td>
                    <td class="text-center">
                        <%= link_to timeline_client_path(client), class: "btn btn-xs btn-outline-secondary rounded-pill" do %>
                            <i class="mdi mdi-history"></i>
                        <% end %>
                    </td>
                </tr>
            <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<% content_for :javascript do %>
    <%= javascript_include_tag 'pages/clients/clients-table.js', defer: true %>
    <script>
        function confirmarEliminacion(event, formulario) {
            event.preventDefault();
            Swal.fire({
                title: '¿Eliminar cliente?',
                text: "No podrás recuperar sus datos y proyectos asociados.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#fa5c7c',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) { formulario.submit(); }
            });
        }
    </script>
<% end %>

<style>
    .avatar-xs { height: 32px; width: 32px; }
    .table-centered td { vertical-align: middle !important; }
</style>