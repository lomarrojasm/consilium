<div class="row">
    <% if current_user.role == "admin" %>
        <div class="col-12">
            <div class="page-title-box">
                <div class="page-title-right">
                    <ol class="breadcrumb m-0">
                        <li class="breadcrumb-item"><a href="<%= root_path %>">Consilium</a></li>
                        <li class="breadcrumb-item"><a href="<%= clients_path %>">Clientes</a></li> 
                        <li class="breadcrumb-item"><a href="<%= client_path(@client) %>"><%= @client.company_name %></a></li>                  
                    </ol>
                </div>
                <h4 class="page-title">Proyecto</h4>
            </div>
        </div>
    <% else %>
        <div class="col-12">
            <div class="page-title-box">
                <div class="page-title-right">
                    <ol class="breadcrumb m-0">
                        <li class="breadcrumb-item"><a href="<%= client_dashboard_path %>">Consilium</a></li>
                        <li class="breadcrumb-item"><a href="<%= client_path(@client) %>"><%= @client.company_name %></a></li>                  
                    </ol>
                </div>
                <h4 class="page-title">Proyecto</h4>
            </div>
        </div>

    <% end %>
</div>


<div class="row">
  <div class="col-xl-4 col-lg-5">
    <div class="card text-center">
      <div class="card-body">
        <% if @client.avatar.attached? %>
            <img src="<%= url_for(@client.avatar) %>" alt="table-user" class="me-2 rounded-circle">
        <% else %>
            <img src="<%= image_path("icono_consilium.jpg") %>" alt="table-user" class="rounded-circle avatar-lg img-thumbnail" alt="profile-image">
        <% end %>

        <h4 class="mb-0 mt-2"><%= @client.company_name %> <%= @client.corporate_regime %> / <%= @client.trade_name%></h4>
        <p class="text-muted font-14">
          <%= @client.tax_regime%><br/>
          <%= @client.type_taxpayer%><br/>
          <%= @client.rfc%>
        </p>

        <%= link_to "Editar", edit_client_path(@client), class: "btn btn-sm btn-warning mb-2" %>
        <button type="button" class="btn btn-danger btn-sm mb-2">Eliminar</button>

        <hr/>

        <p class="text-muted mb-2 font-13">
          <strong>Giro :</strong> <span class="ms-2"><%= @client.industry %></span><br/>
          <strong>País :</strong> <span class="ms-2"><%= @client.country %></span><br/>
          <span class="ms-1"><%= @client.tax_street %></span>
          <span class="ms-1">No. <%= @client.tax_no_ext %>, </span>
          <span class="ms-1"><%= @client.tax_no_int %>, </span><br/>
          <span class="ms-1">Colonia <%= @client.tax_suburb %>, </span>
          <span class="ms-1">C.P.<%= @client.tax_cp %>, </span>
          <span class="ms-1">Ciudad <%= @client.tax_city %>, </span>
          <span class="ms-1">Alcaldia, <%= @client.tax_town_hall %></span><br/>
        </p>

        <hr/>

        <div class="text-start mt-3">
          <h4 class="font-13 text-uppercase bg-primary-lighten p-2">Contacto Principal</h4>
          <p class="text-muted mb-2 font-13"><strong>Nombre :</strong> <span class="ms-2"><%= @client.sponsor_name %></span></p>
          <p class="text-muted mb-2 font-13"><strong>Cargo :</strong> <span class="ms-2"><%= @client.sponsor_position %></span></p>
          <p class="text-muted mb-2 font-13"><strong>Móvil :</strong><span class="ms-2"><%= phone_to @client.sponsor_cel %></span></p>
          <p class="text-muted mb-2 font-13"><strong>Email :</strong> <span class="ms-2 "><%= mail_to @client.sponsor_email %></span></p>
        </div>
      </div> <!-- end card-body -->
    </div> <!-- end card -->

    <!-- Messages-->
    <div class="card">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-center mb-2">
          <h4 class="header-title bg-primary-lighten p-2 col-lg-12">Contactos Clave</h4>
        </div>
        <hr/>

        <div class="inbox-widget">
          <div class="inbox-item">
            <p class="inbox-item-author"><%= @client.legal_representative_name %> <br/> <strong><%= @client.legal_representative_position %></strong> </p> 
            <p class="inbox-item-text"><%= mail_to @client.legal_representative_email %></p>
            <p class="inbox-item-date">
              <span class="btn btn-sm btn-link text-info font-13"> <%= phone_to @client.legal_representative_cel %> </span>
            </p>
          </div>

          <div class="inbox-item">
            <p class="inbox-item-author"><%= @client.operation_name %><br/><strong><%= @client.operation_position %></strong></p>
            <p class="inbox-item-text"><%= mail_to @client.operation_email %></p>
            <p class="inbox-item-date">
              <span class="btn btn-sm btn-link text-info font-13"> <%= phone_to @client.operation_cel %> </span>
            </p>
          </div>

          <div class="inbox-item">
            <p class="inbox-item-author"><%= @client.finance_accounting_name %><br/><strong><%= @client.finance_accounting_position %></strong></p>
            <p class="inbox-item-text"><%= mail_to @client.finance_accounting_email %></p>
            <p class="inbox-item-date">
              <span class="btn btn-sm btn-link text-info font-13"> <%= phone_to @client.finance_accounting_cel %> </span>
            </p>
          </div>

          <div class="inbox-item">
            <p class="inbox-item-author"><%= @client.rrhh_name %><br/><strong><%= @client.rrhh_position %></strong></p>
            <p class="inbox-item-text"><%= mail_to @client.rrhh_email %></p>
            <p class="inbox-item-date">
              <span class="btn btn-sm btn-link text-info font-13"> <%= phone_to @client.rrhh_cel %> </span>
            </p>
          </div>

          <div class="inbox-item">
            <p class="inbox-item-author"><%= @client.comercial_name %><br/><strong><%= @client.comercial_position %></strong></p>
            <p class="inbox-item-text"><%= mail_to @client.comercial_email %></p>
            <p class="inbox-item-date">
              <span class="btn btn-sm btn-link text-info font-13"> <%= phone_to @client.comercial_cel %> </span>
            </p>
          </div>
        </div> <!-- end inbox-widget -->
      </div> <!-- end card-body-->
    </div> <!-- end card-->
  </div> <!-- end col-->

  <div class="col-xl-8 col-lg-7">
    <div class="card">
      <div class="card-body">
        <h5 class="text-uppercase bg-primary-lighten p-2 m-0"><i class="mdi mdi-align-vertical-bottom me-1"></i> Dimensionamiento</h5>
        <div class="row text-center">
          <div class="col-md-3">
            <div class="mb-4">
              <h5>Años Operando</h5>
              <p><%= @client.operation_year %></p>
            </div>
          </div>
          <div class="col-md-3">
            <div class="mb-4">
              <h5>Empleados</h5>
              <p><%= @client.total_employee %></p>
            </div>
          </div>
          <div class="col-md-3">
            <div class="mb-4">
              <h5>Sucursales</h5>
              <p><%= @client.total_location %></p>
            </div>
          </div>
          <div class="col-md-3">
            <div class="mb-4">
              <h5>Servicios / Productos</h5>
              <p><%= @client.product_service %></p>
            </div>
          </div>
        </div>

        <h5 class="text-uppercase bg-primary-lighten p-2 m-0"><i class="mdi mdi-tab-search me-1"></i> Sistemas</h5>
        <div class="row text-center">
          <div class="col-md-3">
            <div class="mb-2">
              <h5>ERP / Admin</h5>
              <p><%= @client.erp_system %></p>
            </div>
          </div>
          <div class="col-md-2">
            <div class="mb-4">
              <h5>Contabilidad</h5>
              <p><%= @client.accounting_system %></p>
            </div>
          </div>
          <div class="col-md-2">
            <div class="mb-4">
              <h5>Nómina</h5>
              <p><%= @client.rrhh_system %></p>
            </div>
          </div>
          <div class="col-md-2">
            <div class="mb-4">
              <h5>CRM / Ventas</h5>
              <p><%= @client.crm_system %></p>
            </div>
          </div>
          <div class="col-md-2">
            <div class="mb-4">
              <h5>Documentación</h5>
              <p><%= @client.storage_system %></p>
            </div>
          </div>
        </div>

        <h5 class="text-uppercase bg-primary-lighten p-2 m-0"><i class="mdi mdi-crowd"></i> Coordinación</h5>
        <div class="row text-center">
          <div class="col-md-6">
            <div class="mb-2">
              <h5>Responsable Interno</h5>
              <p><%= @client.internal_responsible_name %></p>
            </div>
          </div>
          <div class="col-md-6">
            <div class="mb-4">
              <h5>Contacto</h5>
              <p><%= @client.internal_responsible_contact %></p>
            </div>
          </div>
        </div>

        <h5 class="text-uppercase bg-primary-lighten p-2 m-0"><i class="mdi mdi-account-supervisor-circle"></i> Redes Sociales</h5>
        <div class="row text-center">
          <div class="col-md-6">
            <div class="mb-2">
              <h5>Redes Sociales</h5>
              <% @client.social_network.to_s.split("\n").each do |linea| %>
                <% url_texto = linea.strip %>
                <% next if url_texto.blank? %>
                <% url_destino = url_texto.start_with?('http') ? url_texto : "https://#{url_texto}" %>
                <%= link_to url_texto, url_destino, target: "_blank", class: "d-block mb-1 text-primary" %>
              <% end %>

              <% if @client.social_network.blank? %>
                <p class="text-muted">No hay enlaces registrados.</p>
              <% end %>
            </div>
          </div>
          <div class="col-md-6">
            <div class="mb-4">
              <h5>Página Web</h5>
              <% if @client.web_page.blank? %>
                <p> Sin página web </p>
                <% else %>
                <p><%= link_to @client.web_page, @client.web_page.start_with?('http') ? @client.web_page : "https://#{@client.web_page}", target: "_blank" %></p>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
    
    <div class="card">
      <div class="card-body">
        <ul class="nav nav-pills bg-nav-pills nav-justified mb-3">
          <li class="nav-item">
            <a href="#aboutme" data-bs-toggle="tab" aria-expanded="false" class="nav-link rounded-0 active">
              Contexto del Proyecto
            </a>
          </li>
          <li class="nav-item">
            <a href="#timeline" data-bs-toggle="tab" aria-expanded="true" class="nav-link rounded-0">
              Comunicación
            </a>
          </li>
          <li class="nav-item">
            <a href="#settings" data-bs-toggle="tab" aria-expanded="false" class="nav-link rounded-0">
              Proyectos
            </a>
          </li>
        </ul>
        <div class="tab-content">
          <div class="tab-pane show active" id="aboutme">
            <p class="font-14 text-end mb-0">Fecha límite : <span class="ms-2 font-12"><strong class="text-danger"><%= @client.deadline%></strong></span></p>
            <div class="timeline-alt pb-0">
              <div class="timeline-item">
                <i class="mdi mdi-circle bg-info-lighten text-danger timeline-icon"></i>
                <div class="timeline-item-info">
                  <h5 class="mt-0 mb-1">Problematica Principal</h5>
                  <p class="text-muted mt-2 mb-0 pb-3">
                    <%= @client.main_issue%>
                  </p>
                </div>
              </div>

              <div class="timeline-item">
                <i class="mdi mdi-circle bg-primary-lighten text-success timeline-icon"></i>
                <div class="timeline-item-info">
                  <h5 class="mt-0 mb-1">Objetivo del Proyecto</h5>
                  
                  <p class="text-muted mt-2 mb-0 pb-3">
                    <%= @client.project_objective%>
                  </p>

                </div>
              </div>

            </div>
            <!-- end timeline -->

            <h5 class="mb-3 mt-4 text-uppercase bg-primary-lighten p-2 m-0">
              <i class="mdi mdi-cards-variant me-1"></i>
              Usuarios del Sistema
            </h5>
            <div class="row text-end">
              <div class="col-lg-12 mb-3 mt-0">
              <% if current_user.role == 'admin' %>
                <%= link_to new_user_invitation_path(client_id: @client.id), class: "btn btn-sm btn-primary" do %>
                  <i class="mdi mdi-email-plus-outline me-1"></i>Nuevo Usuario
                <% end %>
              <% end %>
              </div>
            </div>
          
            
            <div class="table-responsive">
              <table class="table table-borderless table-nowrap mb-0 table-responsive">
                <thead class="table-light">
                <tr>
                  <th>Nombre</th>
                  <th>Email</th>
                  <th class="text-center">Rol</th>
                  <th>Fecha de Invitación</th>
                  <th>Estatus</th>
                </tr>
                </thead>
                <tbody>
                  <% @client.users.each do |user| %>
                    <tr>
                      <td>
                        <img src="<%= image_path("users/avatar-2.jpg") %>" alt="table-user" class="me-2 rounded-circle" height="24">
                        <%= link_to user.first_name + " " + user.last_name, user_path(user) %>
                      </td>
                      <td><%= user.email %></td>
                      <td class="text-center"><%= user.role %></td>
                      <td>
                        <% if user.invitation_sent_at %>
                          <a href="#" class="btn btn-sm btn-link text-info font-13"><%= l(user.invitation_sent_at, format: :short) %></a>    
                        <% else %>
                          <span href="#" class="btn-link text-info font-13"> Registrado por Sistema </span>
                        <% end %>
                      </td>
                      <td>
                        <% if user.invitation_accepted_at %>
                            <span class="badge bg-success">Aceptada</span> 
                            <small class="text-muted ms-2">el <%= l(user.invitation_accepted_at, format: :long) %></small>
                        <% elsif user.invitation_sent_at %>
                            <span class="badge badge-outline-warning">Pendiente</span>                            
                        <% else %>
                            <span class="badge bg-secondary">Registro Manual</span>
                        <% end %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>

          </div> <!-- end tab-pane -->
          <!-- end about me section content -->

          <div class="tab-pane" id="timeline">

          <div class="card mb-3 shadow-none border bg-light">
        <div class="p-2">
            <div class="row align-items-center">
                <div class="col-auto">
                    <div class="avatar-sm">
                        <span class="avatar-title bg-primary rounded-circle">
                            <i class="mdi mdi-plus"></i>
                        </span>
                    </div>
                </div>
                <div class="col ps-0">
                    <a href="javascript:void(0);" class="text-body fw-bold" data-bs-toggle="collapse" data-bs-target="#newChatCollapse">
                        Iniciar nueva conversación
                    </a>
                    <p class="mb-0 text-muted font-12">Haz clic para escribir a un usuario</p>
                </div>
            </div>
            
            <div class="collapse mt-3" id="newChatCollapse">
                 <div class="d-flex flex-wrap gap-2">
                    <% @client.users.where.not(id: current_user.id).each do |user| %>
                        <%= button_to client_conversations_path(@client), 
                            params: { recipient_id: user.id }, 
                            class: "btn btn-sm btn-soft-primary" do %>
                            <i class="mdi mdi-chat text-success me-1"></i> <%= user.first_name %> <%= user.last_name %>
                        <% end %>
                    <% end %>
                 </div>
            </div>
        </div>
    </div>

    <div class="list-group">
      <% if @conversations.any? %>
        <% @conversations.each do |conversation| %>
          <% other_user = (conversation.sender == current_user) ? conversation.recipient : conversation.sender %>
            <% last_message = conversation.messages.chronological.last %>

              <div class="list-group-item list-group-item-action p-0">
                <div class="d-flex align-items-center justify-content-between pe-3">
                  <%= link_to client_conversation_messages_path(@client, conversation), class: "d-flex align-items-center flex-grow-1 p-3 text-decoration-none text-body" do %>    
                    <div class="flex-shrink-0 me-3">
                      <div class="avatar-sm">
                        <% if other_user.avatar.attached? %>
                          <%= image_tag url_for(other_user.avatar), class: "rounded-circle", style: "width: 100%; height: 100%; object-fit: cover;" %>
                        <% else %>
                          <span class="avatar-title rounded-circle bg-soft-info text-info font-14">
                            <%= other_user.first_name[0] %>
                          </span>
                        <% end %>
                      </div>
                    </div>
                          
                    <div class="flex-grow-1 overflow-hidden">
                      <h5 class="mt-0 mb-1 font-14">
                        <%= other_user.first_name %> <%= other_user.last_name %>
                        <small class="badge bg-light text-dark ms-1"><%= other_user.role&.humanize %></small>
                      </h5>
                      <p class="text-muted text-truncate mb-0 font-13">
                        <% if last_message %>
                          <strong><%= last_message.user == current_user ? "Tú" : last_message.user.first_name %>:</strong>
                          <%= truncate(last_message.body, length: 40) %>
                        <% else %>
                          <span class="text-warning">Sin mensajes</span>
                        <% end %>
                      </p>
                    </div>
            <% end %> 
            <div class="text-end">
              <div class="font-11 text-muted mb-2">
                <%= last_message ? time_ago_in_words(last_message.messaged_at) : "Nuevo" %>
              </div>

              <% if current_user.role == 'admin' %> <div class="ms-2">
                  <%= button_to client_conversation_path(@client, conversation), 
                      method: :delete, 
                      class: "btn btn-link text-danger p-0", 
                      form: { onsubmit: "confirmarEliminacionChat(event, this)" } do %>
                      
                      <i class="mdi mdi-trash-can-outline font-20" data-bs-toggle="tooltip" title="Eliminar Chat"></i>
                  <% end %>
              </div>
          <% end %>
            </div>
          </div>
        </div>
      <% end %>
      <% else %>
        <div class="text-center p-5">
          <div class="avatar-md mx-auto mb-3">
            <span class="avatar-title rounded-circle bg-light">
                <i class="mdi mdi-forum-outline font-24 text-muted"></i>
            </span>
          </div>
            <h5>No hay historial</h5>
        </div>
      <% end %>
    </div>
  </div>
  <!-- end timeline content-->
  <div class="tab-pane" id="settings">

  <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="header-title">Proyectos Activos</h4>
            <% if current_user.role == 'admin' %>
              <%= link_to new_client_project_path(@client), class: "btn btn-sm btn-success" do %>
                  <i class="mdi mdi-plus"></i> Nuevo Proyecto
              <% end %>
            <% end %>
        </div>

        <div class="row">
            <% if @client.projects.any? %>
                <% @client.projects.each do |project| %>
                    <div class="col-md-6 col-xl-4">
                        <div class="card d-block">
                            <div class="card-body">
                                <div class="dropdown float-end">
                                    <a href="#" class="dropdown-toggle arrow-none card-drop" data-bs-toggle="dropdown" aria-expanded="false">
                                        <i class="dripicons-dots-3"></i>
                                    </a>
                                    <div class="dropdown-menu dropdown-menu-end">
                                        <%= link_to "Ver Detalles", client_project_path(@client, project), class: "dropdown-item" %>
                                        <%= link_to "Editar", edit_client_project_path(@client, project), class: "dropdown-item" %>
                                        <div class="dropdown-divider"></div>
                                        <%= button_to "Eliminar", client_project_path(@client, project), method: :delete, class: "dropdown-item text-danger", form: { onsubmit: "confirmarEliminacion(event, this)" } %>
                                    </div>
                                </div>
                                
                                <h4 class="mt-0">
                                    <%= link_to project.name, client_project_path(@client, project), class: "text-title" %>
                                </h4>
                                
                                <div class="badge bg-<%= project.status_color %> mb-3">
                                    <%= project.status&.humanize&.upcase || "SIN ESTATUS" %>
                                </div>

                                <p class="text-muted font-13 mb-3">
                                    <%= truncate(project.details, length: 100) %>
                                </p>

                                <p class="mb-1">
                                    <span class="float-end text-nowrap"><%= project.progress_percentage %>%</span>
                                    <span class="text-nowrap">Progreso</span>
                                </p>
                                <div class="progress mb-3" style="height: 5px;">
                                    <div class="progress-bar bg-<%= project.status_color %>" role="progressbar" style="width: <%= project.progress_percentage %>%;"></div>
                                </div>

                                <p class="mb-1 font-13">
                                    <i class="mdi mdi-calendar-clock text-muted me-1"></i> 
                                    Inicio: <%= l(project.start_date, format: :short) rescue "--" %>
                                </p>
                            </div> 
                        </div> 
                    </div> 
                <% end %>
            <% else %>
                <div class="col-12 text-center py-5">
                    <div class="mb-3">
    <i class="mdi mdi-clipboard-text-off-outline text-muted" style="font-size: 5rem; opacity: 0.5;"></i>
</div>
                    <h5>No hay proyectos creados aún.</h5>
                    <p class="text-muted">Inicia un nuevo proyecto metodológico para este cliente.</p>
                </div>
            <% end %>
        </div>


            
  </div>
  <!-- end settings content-->

        </div> <!-- end tab-content -->
      </div> <!-- end card body -->
    </div> <!-- end card -->
  </div> <!-- end col -->
</div>
<!-- end row-->




<script>
  function confirmarEliminacionChat(event, formulario) {
    event.preventDefault(); // Detiene el envío automático

    Swal.fire({
      title: '¿Eliminar conversación?',
      text: "Se borrarán todos los mensajes y no se podrán recuperar.",
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#fa5c7c',
      cancelButtonColor: '#6c757d',
      confirmButtonText: 'Sí, eliminar chat',
      cancelButtonText: 'Cancelar',
      reverseButtons: true
    }).then((result) => {
      if (result.isConfirmed) {
        formulario.submit(); // Envía el formulario si confirma
      }
    });
  }
  
</script>