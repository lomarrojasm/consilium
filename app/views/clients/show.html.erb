<%# --- ENCABEZADO Y BREADCRUMBS --- %>
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item">
                        <%= link_to "Consilium", current_user.role == "admin" ? root_path : client_dashboard_path %>
                    </li>
                    <li class="breadcrumb-item"><%= link_to "Clientes", clients_path if current_user.role == "admin" %></li>
                    <li class="breadcrumb-item active"><%= @client.company_name %></li>
                </ol>
            </div>
            <h4 class="page-title">Perfil del Cliente</h4>
        </div>
    </div>
</div>

<div class="row">
    <%# --- COLUMNA IZQUIERDA: PERFIL Y CONTACTOS --- %>
    <div class="col-xl-4 col-lg-5">
        <div class="card text-center shadow-sm border-0">
            <div class="card-body">
                <div class="dropdown float-end">
                    <a href="#" class="dropdown-toggle arrow-none card-drop" data-bs-toggle="dropdown">
                        <i class="ri-more-2-fill"></i>
                    </a>
                    <div class="dropdown-menu dropdown-menu-end">
                        <%= link_to edit_client_path(@client), class: "dropdown-item" do %>
                            <i class="ri-edit-line me-1"></i> Editar Cliente
                        <% end %>
                        <% if current_user.role == "admin" %>
                            <button class="dropdown-item text-danger" onclick="confirmDeleteClient()">
                                <i class="ri-delete-bin-line me-1"></i> Eliminar
                            </button>
                        <% end %>
                    </div>
                </div>

                <% if @client.avatar.attached? %>
                    <%= image_tag url_for(@client.avatar), class: "rounded-circle avatar-lg img-thumbnail shadow-sm" %>
                <% else %>
                    <%= image_tag "icono_consilium.jpg", class: "rounded-circle avatar-lg img-thumbnail shadow-sm" %>
                <% end %>

                <h4 class="mb-0 mt-2 text-primary"><%= @client.company_name %></h4>
                <p class="text-muted font-13 fw-bold mb-2"><%= @client.trade_name %></p>
                
                <div class="badge bg-soft-primary text-primary border border-primary border-opacity-25 px-2 py-1 mb-3">
                    RFC: <%= @client.rfc %>
                </div>

                <div class="text-start border-top pt-3">
                    <h5 class="font-12 text-uppercase text-muted fw-bold mb-2">Datos Fiscales</h5>
                    <p class="text-muted font-13 mb-1"><strong>Régimen:</strong> <%= @client.tax_regime %></p>
                    <p class="text-muted font-13 mb-1"><strong>Tipo:</strong> <%= @client.type_taxpayer %></p>
                    <p class="text-muted font-13 mb-3"><strong>Giro:</strong> <%= @client.industry %></p>
                    
                    <h5 class="font-12 text-uppercase text-muted fw-bold mb-2">Ubicación Fiscal</h5>
                    <p class="text-muted font-12 mb-0">
                        <i class="ri-map-pin-2-line me-1"></i>
                        <%= "#{@client.tax_street} #{@client.tax_no_ext}, #{@client.tax_suburb}, CP #{@client.tax_cp}" %><br>
                        <%= "#{@client.tax_city}, #{@client.tax_town_hall}, #{@client.country}" %>
                    </p>
                </div>
            </div>
        </div>

        <%# CONTACTOS CLAVE (Diseño Compacto) %>
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h4 class="header-title mb-3"><i class="ri-contacts-book-2-line me-1"></i> Directorio Clave</h4>
                
                <%# Contacto Principal (Destacado) %>
                <div class="bg-light p-2 rounded mb-3 border-start border-3 border-primary">
                    <h6 class="m-0 text-primary font-13"><%= @client.sponsor_name %></h6>
                    <small class="text-muted d-block"><%= @client.sponsor_position %> (Sponsor)</small>
                    <div class="mt-1">
                        <%= mail_to @client.sponsor_email, class: "btn btn-xs btn-light" do %><i class="ri-mail-line"></i><% end %>
                        <%= phone_to @client.sponsor_cel, class: "btn btn-xs btn-light" do %><i class="ri-phone-line"></i><% end %>
                    </div>
                </div>

                <div class="inbox-widget" data-simplebar style="max-height: 350px;">
                    <% [
                        {name: @client.legal_representative_name, pos: "Rep. Legal", email: @client.legal_representative_email, cel: @client.legal_representative_cel},
                        {name: @client.operation_name, pos: "Operaciones", email: @client.operation_email, cel: @client.operation_cel},
                        {name: @client.finance_accounting_name, pos: "Finanzas", email: @client.finance_accounting_email, cel: @client.finance_accounting_cel},
                        {name: @client.rrhh_name, pos: "RH", email: @client.rrhh_email, cel: @client.rrhh_cel},
                        {name: @client.comercial_name, pos: "Comercial", email: @client.comercial_email, cel: @client.comercial_cel}
                    ].each do |contact| %>
                        <% next if contact[:name].blank? %>
                        <div class="inbox-item py-2 border-bottom border-light">
                            <p class="inbox-item-author mb-0 font-13 fw-bold"><%= contact[:name] %></p>
                            <p class="inbox-item-text mb-0 font-11"><%= contact[:pos] %></p>
                            <p class="inbox-item-date">
                                <%= mail_to contact[:email], class: "text-info me-1" do %><i class="ri-mail-line"></i><% end %>
                                <%= phone_to contact[:cel], class: "text-success" do %><i class="ri-whatsapp-line"></i><% end %>
                            </p>
                        </div>
                    <% end %>
                </div>
            </div>
        </div>
    </div>

    <%# --- COLUMNA DERECHA: DASHBOARD Y TABS --- %>
    <div class="col-xl-8 col-lg-7">
        
        <%# TARJETAS DE DIMENSIONAMIENTO (KPIs) %>
        <div class="row">
            <div class="col-md-3">
                <div class="card shadow-sm border-0 text-center py-2">
                    <div class="card-body">
                        <i class="ri-calendar-line font-24 text-primary"></i>
                        <h3 class="my-1"><%= @client.operation_year %></h3>
                        <p class="text-muted mb-0 font-12 text-uppercase">Años Operando</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-0 text-center py-2">
                    <div class="card-body">
                        <i class="ri-group-line font-24 text-info"></i>
                        <h3 class="my-1"><%= @client.total_employee %></h3>
                        <p class="text-muted mb-0 font-12 text-uppercase">Empleados</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-0 text-center py-2">
                    <div class="card-body">
                        <i class="ri-map-pin-line font-24 text-success"></i>
                        <h3 class="my-1"><%= @client.total_location %></h3>
                        <p class="text-muted mb-0 font-12 text-uppercase">Sucursales</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm border-0 text-center py-2">
                    <div class="card-body">
                        <i class="ri-service-line font-24 text-warning"></i>
                        <h3 class="my-1" style="font-size: 1.2rem;"><%= truncate(@client.product_service, length: 15) %></h3>
                        <p class="text-muted mb-0 font-12 text-uppercase">Productos</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body">
                <ul class="nav nav-pills bg-nav-pills nav-justified mb-3">
                    <li class="nav-item">
                        <a href="#projects" data-bs-toggle="tab" class="nav-link rounded-0 active">
                            <i class="ri-stack-line me-1"></i> Proyectos
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="#context" data-bs-toggle="tab" class="nav-link rounded-0">
                            <i class="ri-compass-3-line me-1"></i> Contexto & Sistemas
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="#communication" data-bs-toggle="tab" class="nav-link rounded-0">
                            <i class="ri-chat-3-line me-1"></i> Comunicación
                        </a>
                    </li>
                </ul>

                <div class="tab-content">
                    <%# TAB: PROYECTOS %>
                    <div class="tab-pane show active" id="projects">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <h4 class="header-title mb-0 text-primary">Portafolio de Proyectos</h4>
                            <% if current_user.role == 'admin' %>
                                <%= link_to new_client_project_path(@client), class: "btn btn-sm btn-primary shadow-sm" do %>
                                    <i class="ri-add-line me-1"></i> Nuevo Proyecto
                                <% end %>
                            <% end %>
                        </div>

                        <div class="row">
                            <% if @client.projects.any? %>
                                <% @client.projects.each do |project| %>
                                    <div class="col-md-6">
                                        <div class="card border shadow-none mb-3">
                                            <div class="card-body">
                                                <div class="dropdown float-end">
                                                    <a href="#" class="dropdown-toggle arrow-none text-muted" data-bs-toggle="dropdown">
                                                        <i class="ri-more-fill"></i>
                                                    </a>
                                                    <div class="dropdown-menu dropdown-menu-end">
                                                        <%= link_to "Gestionar", client_project_path(@client, project), class: "dropdown-item" %>
                                                        <%= link_to "Editar", edit_client_project_path(@client, project), class: "dropdown-item" %>
                                                    </div>
                                                </div>
                                                <h5 class="mt-0"><%= link_to project.name, client_project_path(@client, project), class: "text-title" %></h5>
                                                <div class="badge bg-soft-<%= project.status_color %> text-<%= project.status_color %> border border-<%= project.status_color %> border-opacity-25 mb-3">
                                                    <%= project.status&.humanize&.upcase %>
                                                </div>
                                                <p class="text-muted font-13"><%= truncate(project.details, length: 80) %></p>
                                                
                                                <div class="mt-2">
                                                    <div class="d-flex justify-content-between mb-1">
                                                        <span class="font-12">Progreso</span>
                                                        <span class="font-12 fw-bold"><%= project.progress_percentage %>%</span>
                                                    </div>
                                                    <div class="progress progress-sm">
                                                        <div class="progress-bar bg-<%= project.status_color %>" style="width: <%= project.progress_percentage %>%"></div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                <% end %>
                            <% else %>
                                <div class="col-12 text-center py-5">
                                    <i class="ri-clipboard-line font-40 text-muted opacity-25"></i>
                                    <p class="text-muted mt-2">No hay proyectos activos para este cliente.</p>
                                </div>
                            <% end %>
                        </div>
                    </div>

                    <%# TAB: CONTEXTO Y SISTEMAS %>
                    <div class="tab-pane" id="context">
                        <div class="row">
                            <div class="col-md-6 border-end">
                                <h5 class="text-uppercase font-12 fw-bold text-muted mb-3"><i class="ri-error-warning-line me-1 text-danger"></i> Diagnóstico Inicial</h5>
                                <div class="timeline-alt pb-0">
                                    <div class="timeline-item">
                                        <i class="ri-record-circle-line text-danger timeline-icon"></i>
                                        <div class="timeline-item-info">
                                            <h6 class="mt-0 mb-1 fw-bold">Problemática Principal</h6>
                                            <p class="text-muted font-13"><%= @client.main_issue %></p>
                                        </div>
                                    </div>
                                    <div class="timeline-item border-0">
                                        <i class="ri-record-circle-line text-success timeline-icon"></i>
                                        <div class="timeline-item-info">
                                            <h6 class="mt-0 mb-1 fw-bold">Objetivo del Proyecto</h6>
                                            <p class="text-muted font-13"><%= @client.project_objective %></p>
                                            <small class="text-danger fw-bold">Deadline: <%= @client.deadline %></small>
                                        </div>
                                    </div>
                                </div>
                                
                                <h5 class="text-uppercase font-12 fw-bold text-muted mt-4 mb-3"><i class="ri-global-line me-1 text-primary"></i> Presencia Digital</h5>
                                <p class="font-13 mb-1"><strong>Web:</strong> <%= @client.web_page.present? ? link_to(@client.web_page, "https://#{@client.web_page}", target: "_blank") : "No registrada" %></p>
                                <div class="mt-2">
                                    <% @client.social_network.to_s.split("\n").each do |net| %>
                                        <span class="badge badge-soft-primary me-1"><%= net.strip %></span>
                                    <% end %>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <h5 class="text-uppercase font-12 fw-bold text-muted mb-3"><i class="ri-cpu-line me-1 text-info"></i> Infraestructura Tecnológica</h5>
                                <div class="table-responsive">
                                    <table class="table table-sm table-borderless font-13">
                                        <tr><td class="fw-bold">ERP / Admin:</td><td><%= @client.erp_system %></td></tr>
                                        <tr><td class="fw-bold">Contabilidad:</td><td><%= @client.accounting_system %></td></tr>
                                        <tr><td class="fw-bold">RH / Nómina:</td><td><%= @client.rrhh_system %></td></tr>
                                        <tr><td class="fw-bold">CRM / Ventas:</td><td><%= @client.crm_system %></td></tr>
                                        <tr><td class="fw-bold">Documentos:</td><td><%= @client.storage_system %></td></tr>
                                    </table>
                                </div>
                                <div class="bg-light p-2 rounded mt-2">
                                    <h6 class="font-12 fw-bold m-0 text-primary">Enlace Interno Consilium</h6>
                                    <p class="font-12 mb-0"><%= @client.internal_responsible_name %> (<%= @client.internal_responsible_contact %>)</p>
                                </div>
                            </div>
                        </div>

                        <%# TABLA DE USUARIOS DEL SISTEMA %>
                        <div class="mt-4 pt-3 border-top">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h5 class="header-title m-0">Usuarios con Acceso</h5>
                                <% if current_user.role == 'admin' %>
                                    <%= link_to new_user_invitation_path(client_id: @client.id), class: "btn btn-xs btn-outline-primary" do %>
                                        <i class="ri-user-add-line"></i> Invitar
                                    <% end %>
                                <% end %>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-sm table-centered table-nowrap mb-0 font-12">
                                    <thead class="table-light">
                                        <tr><th>Nombre</th><th>Rol</th><th>Estatus</th></tr>
                                    </thead>
                                    <tbody>
                                        <% @client.users.each do |user| %>
                                            <tr>
                                                <td class="fw-bold"><%= user.full_name %></td>
                                                <td><span class="badge bg-soft-secondary text-secondary"><%= user.role %></span></td>
                                                <td>
                                                    <% if user.invitation_accepted_at %>
                                                        <span class="text-success"><i class="ri-checkbox-circle-fill"></i> Activo</span>
                                                    <% else %>
                                                        <span class="text-warning"><i class="ri-time-line"></i> Pendiente</span>
                                                    <% end %>
                                                </td>
                                            </tr>
                                        <% end %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <%# TAB: COMUNICACIÓN (CHATS) %>
                    <div class="tab-pane" id="communication">
                        <div class="bg-soft-primary p-3 rounded mb-4">
                            <h5 class="mt-0 font-14"><i class="ri-chat-voice-line me-1"></i> Nueva Conversación</h5>
                            <div class="d-flex flex-wrap gap-2">
                                <% @client.users.where.not(id: current_user.id).each do |user| %>
                                    <%= button_to client_conversations_path(@client), params: { recipient_id: user.id }, class: "btn btn-sm btn-white border shadow-sm rounded-pill" do %>
                                        <i class="ri-message-3-line text-success"></i> <%= user.first_name %>
                                    <% end %>
                                <% end %>
                            </div>
                        </div>

                        <div class="list-group list-group-flush">
                            <% if @conversations.any? %>
                                <% @conversations.each do |conversation| %>
                                    <% other_user = (conversation.sender == current_user) ? conversation.recipient : conversation.sender %>
                                    <% last_msg = conversation.messages.chronological.last %>
                                    <div class="list-group-item d-flex align-items-center border-bottom border-light px-0">
                                        <div class="avatar-xs me-2">
                                            <span class="avatar-title rounded-circle bg-soft-info text-info font-12 fw-bold">
                                                <%= other_user.first_name[0] %>
                                            </span>
                                        </div>
                                        <div class="flex-grow-1 overflow-hidden">
                                            <h6 class="m-0"><%= link_to other_user.full_name, client_conversation_messages_path(@client, conversation), class: "text-body" %></h6>
                                            <small class="text-muted text-truncate d-block">
                                                <%= last_msg ? truncate(last_msg.body, length: 50) : "Sin mensajes aún" %>
                                            </small>
                                        </div>
                                        <div class="text-end">
                                            <small class="font-10 text-muted"><%= last_msg ? time_ago_in_words(last_msg.messaged_at) : "" %></small>
                                            <% if current_user.role == 'admin' %>
                                                <%= button_to client_conversation_path(@client, conversation), method: :delete, class: "btn btn-xs btn-link text-danger p-0 ms-1", form: { onsubmit: "confirmarEliminacionChat(event, this)" } do %>
                                                    <i class="ri-delete-bin-line"></i>
                                                <% end %>
                                            <% end %>
                                        </div>
                                    </div>
                                <% end %>
                            <% else %>
                                <div class="text-center py-5">
                                    <p class="text-muted">No hay hilos de conversación activos.</p>
                                </div>
                            <% end %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
  function confirmDeleteClient() {
    Swal.fire({
      title: '¿Eliminar Cliente?',
      text: "Se borrará permanentemente '<%= @client.company_name %>' y toda su información fiscal y de contacto.",
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#fa5c7c',
      cancelButtonColor: '#6c757d',
      confirmButtonText: 'Sí, eliminar',
      cancelButtonText: 'Cancelar',
      reverseButtons: true
    }).then((result) => {
      if (result.isConfirmed) {
        // Ejecutar eliminación (Ajustar según ruta real)
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '<%= client_path(@client) %>';
        form.innerHTML = `<input type="hidden" name="_method" value="delete"><input type="hidden" name="authenticity_token" value="<%= form_authenticity_token %>">`;
        document.body.appendChild(form);
        form.submit();
      }
    });
  }

  function confirmarEliminacionChat(event, formulario) {
    event.preventDefault();
    Swal.fire({
      title: '¿Eliminar chat?',
      text: "Esta acción no se puede deshacer.",
      icon: 'warning',
      showCancelButton: true,
      confirmButtonColor: '#fa5c7c',
      cancelButtonColor: '#6c757d',
      confirmButtonText: 'Eliminar',
      reverseButtons: true
    }).then((result) => { if (result.isConfirmed) formulario.submit(); });
  }
</script>