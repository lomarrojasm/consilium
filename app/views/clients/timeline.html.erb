<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item"><a href="<%= root_path %>">Consilium</a></li>
                    <% if current_user.role == "admin" %>
                        <li class="breadcrumb-item"><a href="<%= clients_path %>">Clientes</a></li> 
                    <% else %>
                        <li class="breadcrumb-item"><a href="<%= client_dashboard_path %>">Dashboard</a></li>
                    <% end %>
                    <li class="breadcrumb-item"><a href="<%= client_path(@client) %>"><%= @client.company_name %></a></li>                  
                    <li class="breadcrumb-item active">Línea de Tiempo</li>
                </ol>
            </div>
            <h4 class="page-title"><i class="mdi mdi-clock-time-eight-outline text-primary me-2"></i>Línea de Tiempo: <%= @client.company_name %></h4>
        </div>
    </div>
</div>

<div class="container-fluid py-4">
  <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center mb-4 gap-3">
    
    <div>
      <p class="text-muted mb-0 d-flex align-items-center flex-wrap gap-2">
        <% if params[:query].present? || params[:search_date].present? %>
          <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-10">
            <i class="mdi mdi-filter-variant me-1"></i>Filtros activos
          </span>
          <span class="text-dark small fw-bold">
            <%= @events.respond_to?(:count) ? @events.count : 0 %> movimientos encontrados
          </span>
        <% else %>
          <span class="text-muted small">
            Mostrando actividad de <strong><%= I18n.l(@selected_date || Date.today, format: '%B %Y').capitalize %></strong>
          </span>
        <% end %>
      </p>
    </div>
    
    <div class="card shadow-sm border-0 flex-grow-1 flex-lg-grow-0" style="max-width: 600px;">
      <div class="card-body p-2">
        <form action="<%= timeline_client_path(@client) %>" method="get" class="row g-2 align-items-center m-0">
          
          <div class="col-12 col-md">
            <div class="input-group input-group-sm">
              <span class="input-group-text bg-white border-end-0 text-muted ps-3"><i class="mdi mdi-magnify"></i></span>
              <input type="text" name="query" class="form-control border-start-0 ps-0 shadow-none" 
                     placeholder="Buscar actividad, usuario..." 
                     value="<%= params[:query] %>">
            </div>
          </div>

          <div class="col-12 col-md-auto">
            <input type="date" name="search_date" class="form-control form-control-sm text-muted" 
                   value="<%= params[:search_date] %>" 
                   title="Filtrar por fecha exacta">
          </div>

          <div class="col-12 col-md-auto d-flex gap-2">
            <button type="submit" class="btn btn-primary btn-sm px-3 fw-bold shadow-sm flex-fill">
              Buscar
            </button>
            
            <% if params[:query].present? || params[:search_date].present? %>
              <a href="<%= timeline_client_path(@client) %>" class="btn btn-outline-danger btn-sm px-3 flex-fill" title="Borrar filtros">
                <i class="mdi mdi-close"></i>
              </a>
            <% end %>
          </div>

        </form>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-lg-10 mx-auto">
      <% if @events.any? %>
        <div class="timeline position-relative">
          <div class="position-absolute start-0 top-0 bottom-0 border-start border-2 ms-4 border-light-subtle"></div>

          <% @events.each do |log| %>
            <div class="position-relative ps-5 mb-4">
              
              <div class="position-absolute start-0 top-0 mt-1" style="z-index: 5;">
                <% case log.resource_type %>
                <% when 'Project' %>
                  <div class="avatar-sm rounded-circle bg-primary text-white d-flex align-items-center justify-content-center shadow"><i class="mdi mdi-folder font-18"></i></div>
                <% when 'Activity' %>
                  <div class="avatar-sm rounded-circle bg-success text-white d-flex align-items-center justify-content-center shadow"><i class="mdi mdi-check font-18"></i></div>
                <% when 'Message' %>
                  <div class="avatar-sm rounded-circle bg-info text-white d-flex align-items-center justify-content-center shadow"><i class="mdi mdi-chat font-18"></i></div>
                <% when 'ProjectMember' %>
                  <div class="avatar-sm rounded-circle bg-warning text-white d-flex align-items-center justify-content-center shadow"><i class="mdi mdi-account-plus font-18"></i></div>
                <% else %>
                  <div class="avatar-sm rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center shadow"><i class="mdi mdi-history font-18"></i></div>
                <% end %>
              </div>

              <div class="card shadow-sm border-0 border-start border-4 <%= log.resource_type == 'Activity' ? 'border-success' : (log.resource_type == 'ProjectMember' ? 'border-warning' : 'border-primary') %>"> 
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-start">
                  
                    <div class="flex-grow-1">

                        <% if log.action_type == 'destroy' %>
                        
                            <h6 class="fw-bold text-danger text-uppercase mb-1" style="font-size: 0.7rem;">
                                <i class="mdi mdi-delete-outline me-1"></i> Registro Eliminado
                            </h6>
                            <div class="bg-soft-danger p-2 rounded border border-danger border-opacity-10 text-dark">
                                <%= log.details %>
                            </div>
                            <p class="text-muted small mb-0 mt-1">Tipo: <%= log.resource_type %></p>

                        <% elsif log.resource_type == 'Project' %>
                    
                          <% if log.action_type == 'create' %>
                              <h6 class="fw-bold text-primary text-uppercase mb-1" style="font-size: 0.7rem;">
                                  🚀 Nuevo Proyecto
                              </h6>
                              <h5 class="mb-1 text-dark"><%= log.resource.name %></h5>
                              <p class="text-muted small mb-0"><%= log.details %></p>

                          <% elsif log.details.downcase.include?('eliminó') || log.details.downcase.include?('borró') %>
                              <h6 class="fw-bold text-danger text-uppercase mb-1" style="font-size: 0.7rem;">
                                  <i class="mdi mdi-file-remove-outline me-1"></i> Archivo Eliminado
                              </h6>
                              
                              <p class="mb-2 fw-bold text-dark">
                                  <%= log.resource.name %>
                              </p>

                              <div class="bg-soft-danger p-2 rounded small text-danger border border-danger border-opacity-25">
                                  <%= log.details %> 
                              </div>

                          <% else %>
                              <% if log.details.include?("📂") || log.details.downcase.include?("adjuntaron") %>
                                <h6 class="fw-bold text-dark text-uppercase mb-1" style="font-size: 0.7rem;">
                                  <i class="mdi mdi-cloud-upload me-1"></i> Archivos Adjuntos
                                </h6>
                              <% else %>
                                <h6 class="fw-bold text-info text-uppercase mb-1" style="font-size: 0.7rem;">
                                  <i class="mdi mdi-file-document-edit-outline me-1"></i> Proyecto Actualizado
                                </h6>
                              <% end %>
                              
                              <p class="mb-2 fw-bold text-dark">
                                  <%= log.resource.name %>
                              </p>

                              <div class="bg-light p-2 rounded small text-secondary border-start border-3 border-info">
                                  <%= log.details %> 
                              </div>
                          <% end %>

                        <% elsif log.resource_type == 'ProjectMember' %>
                        
                            <h6 class="fw-bold text-warning text-uppercase mb-2" style="font-size: 0.7rem;">
                                <i class="mdi mdi-account-group me-1"></i> Equipo Actualizado
                            </h6>

                            <% if log.resource %>
                                <div class="d-flex align-items-center bg-light p-2 rounded mb-2 border border-warning border-opacity-25">
                                    <div class="avatar-xs me-2">
                                        <span class="avatar-title rounded-circle bg-warning text-white font-10 fw-bold">
                                            <%= log.resource.user&.first_name&.first %><%= log.resource.user&.last_name&.first %>
                                        </span>
                                    </div>
                                    <div class="lh-1">
                                        <span class="text-dark fw-bold d-block">
                                            <%= log.resource.user&.first_name %> <%= log.resource.user&.last_name %>
                                        </span>
                                        <span class="text-muted small" style="font-size: 0.75rem;">se unió al proyecto</span>
                                    </div>
                                </div>
                                <p class="mb-0 small text-muted">
                                    <i class="mdi mdi-folder-outline me-1"></i> En: <strong><%= log.resource.project&.name %></strong>
                                </p>
                            <% else %>
                                <div class="bg-light p-2 rounded text-muted small fst-italic">Miembro eliminado. <%= log.details %></div>
                            <% end %>

                        <% elsif log.resource_type == 'Activity' %>

                          <% if log.resource %>
                              <% if log.action_type == 'create' %>
                                  <h6 class="fw-bold text-primary text-uppercase mb-1" style="font-size: 0.7rem;">
                                      📋 Nueva Tarea
                                  </h6>
                              <% elsif log.details.to_s.downcase.include?('completada') %>
                                  <h6 class="fw-bold text-success text-uppercase mb-1" style="font-size: 0.7rem;">
                                      ✅ Tarea Completada
                                  </h6>
                              <% else %>
                                  <h6 class="fw-bold text-info text-uppercase mb-1" style="font-size: 0.7rem;">
                                      ✏️ Tarea Actualizada
                                  </h6>
                              <% end %>

                              <h5 class="mb-1 fs-6"><%= log.resource.name %></h5>

                              <p class="mb-1 text-dark small">
                                  <%= log.details %>
                              </p>

                              <p class="text-muted small mb-2">
                                  <i class="mdi mdi-layers-outline me-1"></i> <%= log.resource.stage&.project&.name || "Sin proyecto" %>
                              </p>

                              <% if log.resource.evidence.attached? %>
                                  <div class="bg-light p-2 rounded d-flex align-items-center border border-success border-opacity-25 mt-2" style="max-width: 300px;">
                                      <div class="me-3 text-success"><i class="mdi mdi-file-document-check font-24"></i></div>
                                      <div class="flex-grow-1 overflow-hidden">
                                          <h6 class="mt-0 mb-1 font-12 text-truncate">Evidencia</h6>
                                          <small class="text-muted d-block text-truncate"><%= log.resource.evidence.filename %></small>
                                      </div>
                                      <div class="ms-2">
                                          <%= link_to rails_blob_path(log.resource.evidence, disposition: "attachment"), class: "btn btn-xs btn-success shadow-sm", target: "_blank" do %>
                                              <i class="mdi mdi-download"></i>
                                          <% end %>
                                      </div>
                                  </div>
                              <% end %>

                          <% else %>
                              <h6 class="fw-bold text-secondary text-uppercase mb-1" style="font-size: 0.7rem;">🗑️ Actividad Eliminada</h6>
                              <p class="mb-0 text-muted small"><%= log.details %></p>
                          <% end %>

                        <% elsif log.resource_type == 'Message' %>
                            <h6 class="fw-bold text-secondary text-uppercase mb-1" style="font-size: 0.7rem;">💬 Mensaje de Chat</h6>
                            <div class="bg-light p-2 rounded mb-0 fst-italic text-muted small">
                                "<%= log.resource.respond_to?(:body) ? log.resource.body : log.details %>"
                            </div>

                        <% elsif log.resource_type == 'ProjectComment' %>
                            <h6 class="fw-bold text-dark text-uppercase mb-1" style="font-size: 0.7rem;">📝 Comentario</h6>
                            <p class="mb-1 small fw-bold"><%= log.resource.project.name %></p>
                            <div class="text-muted small"><%= log.resource.body %></div>

                        <% else %>
                            <h6 class="fw-bold mb-1 text-primary"><%= log.action_type.capitalize %> <%= log.resource_type %></h6>
                            <p class="mb-0 text-dark small"><%= log.details %></p>
                        <% end %>

                        <div class="d-flex align-items-center mt-2 border-top pt-2">
                            <small class="text-muted me-1">Acción realizada por:</small>
                            <strong class="text-dark small">
                                <%= log.user ? "#{log.user.first_name} #{log.user.last_name}" : "Sistema" %>
                            </strong>
                        </div>

                    </div> <div class="text-end date-hover-zone ms-3" style="min-width: 80px;">
                        <span class="d-block fw-bold text-dark"><%= log.happened_at.strftime("%d %b %Y") %></span>
                        <small class="text-muted d-block"><%= log.happened_at.strftime("%H:%M") %>
                            <% if current_user.respond_to?(:role) && (current_user.role == 'admin' || current_user.role == 2) %>
                                <div class="mt-1">
                                    <button type="button" 
                                            class="btn btn-link p-0 text-decoration-none btn-invisible" 
                                            style="font-size: 0.75rem; color: #adb5bd;"
                                            onclick="openEditDateModal('<%= log.id %>', '<%= log.happened_at %>')">
                                        <i class="mdi mdi-pencil"></i> Editar
                                    </button>
                                </div>
                            <% end %>
                        </small>
                    </div>

                  </div>
                </div>
              </div> </div>
          <% end %>
        </div>
      <% else %>
        <div class="alert alert-light text-center border mt-4">
            <i class="mdi mdi-calendar-blank-outline font-24 d-block mb-2 text-muted"></i>
            No hay movimientos registrados con estos filtros.
        </div>
      <% end %>
    </div>
  </div>
</div>

<% if current_user.respond_to?(:role) && (current_user.role == 'admin' || current_user.role == 2) %>
  
  <div class="modal fade" id="editDateModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header border-0 pb-0">
          <h6 class="modal-title fw-bold">Reagendar Evento</h6>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        
        <div class="modal-body pt-2">
          <%= form_with url: update_timeline_event_path, method: :patch do |f| %>
            <input type="hidden" name="log_id" id="modal_log_id">
            
            <div class="mb-3">
              <label class="form-label small text-muted mb-1">Nueva Fecha y Hora</label>
              <input type="datetime-local" name="new_date" id="modal_new_date" class="form-control form-control-sm bg-light border-0" required>
            </div>
            
            <div class="d-grid">
              <button type="submit" class="btn btn-primary btn-sm">Guardar Cambio</button>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <script>
    function openEditDateModal(logId, currentDateStr) {
      document.getElementById('modal_log_id').value = logId;
      
      // Ajuste de fecha para que el input datetime-local la lea correctamente
      let date = new Date(currentDateStr);
      date.setMinutes(date.getMinutes() - date.getTimezoneOffset());
      document.getElementById('modal_new_date').value = date.toISOString().slice(0, 16);
      
      var myModal = new bootstrap.Modal(document.getElementById('editDateModal'));
      myModal.show();
    }
  </script>

  <style>
    /* CSS CORREGIDO */
    .btn-invisible {
        opacity: 0;
        transition: all 0.3s ease-in-out;
        visibility: hidden;
    }

    /* Al pasar el mouse por la ZONA, el botón se hace visible (opacity 1) */
    .date-hover-zone:hover .btn-invisible {
        opacity: 0.0; /* Un poco transparente para ser sutil */
        visibility: visible;
    }

    /* Al pasar el mouse sobre el BOTÓN, se pone totalmente visible y azul */
    .btn-invisible:hover {
        opacity: 0 !important;
        color: var(--bs-primary) !important;
    }
  </style>
<% end %>