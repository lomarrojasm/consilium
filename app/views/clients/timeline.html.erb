<%# --- ENCABEZADO --- %>
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <ol class="breadcrumb m-0 font-12">
                    <li class="breadcrumb-item"><%= link_to "Consilium", root_path %></li>
                    <% if current_user.role == "admin" %>
                        <li class="breadcrumb-item"><%= link_to "Clientes", clients_path %></li> 
                    <% else %>
                        <li class="breadcrumb-item"><%= link_to "Dashboard", client_dashboard_path %></li>
                    <% end %>
                    <li class="breadcrumb-item"><%= link_to @client.company_name, client_path(@client) %></li>                  
                    <li class="breadcrumb-item active">Historial</li>
                </ol>
            </div>
            <h4 class="page-title"><i class="ri-history-line text-primary me-2"></i>Historial de Actividad</h4>
        </div>
    </div>
</div>

<div class="container-fluid py-2">
  <%# --- FILTROS DE BÚSQUEDA --- %>
  <div class="card shadow-sm border-0 mb-4">
    <div class="card-body py-2">
      <form action="<%= timeline_client_path(@client) %>" method="get" class="row g-2 align-items-center">
        <div class="col-md-5">
          <div class="input-group input-group-sm">
            <span class="input-group-text bg-light border-0"><i class="ri-search-line"></i></span>
            <input type="text" name="query" class="form-control bg-light border-0 shadow-none" 
                   placeholder="Buscar por descripción, usuario o tarea..." value="<%= params[:query] %>">
          </div>
        </div>
        <div class="col-md-3">
          <div class="input-group input-group-sm">
            <span class="input-group-text bg-light border-0"><i class="ri-calendar-line"></i></span>
            <input type="date" name="search_date" class="form-control bg-light border-0 shadow-none" value="<%= params[:search_date] %>">
          </div>
        </div>
        <div class="col-md-4 d-flex gap-2">
          <button type="submit" class="btn btn-primary btn-sm px-3 flex-grow-1">Filtrar</button>
          <% if params[:query].present? || params[:search_date].present? %>
            <%= link_to timeline_client_path(@client), class: "btn btn-soft-danger btn-sm px-2" do %>
              <i class="ri-refresh-line"></i>
            <% end %>
          <% end %>
        </div>
      </form>
    </div>
  </div>

  <%# --- LÍNEA DE TIEMPO --- %>
  <div class="row">
    <div class="col-lg-11 mx-auto">
      <% if @events.any? %>
        <div class="timeline-alt pb-0">
          <% @events.each do |log| %>
            <div class="timeline-item">
              
              <%# ICONO SEGÚN TIPO DE RECURSO %>
              <div class="timeline-icon">
                <% case log.resource_type %>
                <% when 'Project' %>
                  <div class="avatar-xs"><span class="avatar-title rounded-circle bg-primary shadow-sm"><i class="ri-folder-6-line"></i></span></div>
                <% when 'Activity' %>
                  <div class="avatar-xs"><span class="avatar-title rounded-circle bg-success shadow-sm"><i class="ri-task-line"></i></span></div>
                <% when 'Message' %>
                  <div class="avatar-xs"><span class="avatar-title rounded-circle bg-info shadow-sm"><i class="ri-chat-3-line"></i></span></div>
                <% when 'ProjectMember' %>
                  <div class="avatar-xs"><span class="avatar-title rounded-circle bg-warning shadow-sm"><i class="ri-user-follow-line"></i></span></div>
                <% else %>
                  <div class="avatar-xs"><span class="avatar-title rounded-circle bg-secondary shadow-sm"><i class="ri-history-line"></i></span></div>
                <% end %>
              </div>

              <div class="timeline-item-info pb-3 mb-4 ms-4 ps-3">
                <div class="card shadow-none border mb-0">
                  <div class="card-body p-3">
                    <div class="row align-items-center">
                      <div class="col-md-9">
                        
                        <%# SNAPSHOT DE NOMBRE (Para evitar errores si el recurso se borró) %>
                        <% res_name = log.resource_name.presence || log.resource&.try(:name) || "Recurso no disponible" %>
                        
                        <%# ETIQUETA DE ACCIÓN %>
                        <div class="mb-2">
                          <span class="badge badge-soft-<%= log.action_type == 'destroy' ? 'danger' : (log.action_type == 'create' ? 'primary' : 'info') %> font-10 text-uppercase">
                            <%= log.action_type == 'destroy' ? 'Eliminado' : (log.action_type == 'create' ? 'Nuevo Registro' : 'Actualización') %>
                          </span>
                          <small class="text-muted ms-2 font-11 text-uppercase fw-bold"><%= log.resource_type %></small>
                        </div>

                        <%# TÍTULO DEL EVENTO %>
                        <h5 class="mt-0 mb-1 font-15 fw-bold">
                          <% if log.resource.present? %>
                            <% if log.resource_type == 'Project' %>
                              <%= link_to res_name, client_project_path(@client, log.resource), class: "text-dark hover-primary" %>
                            <% elsif log.resource_type == 'Activity' %>
                              <%# Navegación segura para evitar el error de undefined method project %>
                              <% project = log.resource.respond_to?(:project) ? log.resource.project : log.resource.stage&.project %>
                              <% if project %>
                                <%= link_to res_name, edit_client_project_activity_path(@client, project, log.resource), class: "text-dark hover-primary" %>
                              <% else %>
                                <span class="text-dark"><%= res_name %></span>
                              <% end %>
                            <% else %>
                              <span class="text-dark"><%= res_name %></span>
                            <% end %>
                          <% else %>
                            <span class="text-muted"><%= res_name %></span>
                            <small class="text-danger fst-italic font-11 ms-1">(Borrado permanentemente)</small>
                          <% end %>
                        </h5>

                        <%# DETALLES DEL LOG %>
                        <div class="bg-light bg-opacity-50 p-2 rounded mb-2 border-start border-3 border-primary border-opacity-25">
                          <p class="text-muted font-13 mb-0" style="white-space: pre-wrap;"><%= log.details %></p>
                        </div>

                        <%# EVIDENCIA DE TAREA %>
                        <% if log.resource_type == 'Activity' && log.resource&.respond_to?(:evidence) && log.resource&.evidence&.attached? %>
                          <div class="d-inline-flex align-items-center bg-soft-success p-1 rounded border border-success border-opacity-10 mb-2">
                            <i class="ri-file-check-line text-success me-1 font-16"></i>
                            <span class="font-11 text-dark me-2"><%= truncate(log.resource.evidence.filename.to_s, length: 25) %></span>
                            <%= link_to rails_blob_path(log.resource.evidence, disposition: "attachment"), class: "btn btn-xs btn-success py-0 px-1", target: "_blank" do %>
                              <i class="ri-download-2-line"></i>
                            <% end %>
                          </div>
                        <% end %>

                        <%# USUARIO RESPONSABLE %>
                        <div class="mt-1 d-flex align-items-center">
                          <div class="avatar-xs me-2" style="width: 18px; height: 18px;">
                            <span class="avatar-title rounded-circle bg-soft-secondary text-secondary font-9 fw-bold">
                              <%= log.user ? log.user.first_name[0] : 'S' %>
                            </span>
                          </div>
                          <small class="text-muted">Por: <strong><%= log.user ? log.user.full_name : "Sistema" %></strong></small>
                        </div>

                      </div>

                      <%# ZONA DE FECHA / REAGENDAR %>
                      <div class="col-md-3 text-md-end date-hover-zone">
                        <span class="d-block fw-bold text-dark font-13"><%= log.happened_at.strftime("%d %b, %Y") %></span>
                        <span class="text-primary fw-bold font-12"><%= log.happened_at.strftime("%H:%M") %></span>
                        
                        <% if current_user.role == 'admin' %>
                          <div class="mt-2">
                            <button type="button" class="btn btn-xs btn-soft-secondary btn-invisible py-0" 
                                    onclick="openEditDateModal('<%= log.id %>', '<%= log.happened_at %>')">
                              <i class="ri-calendar-edit-line me-1"></i>Reagendar
                            </button>
                          </div>
                        <% end %>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <div class="text-center py-5 border rounded bg-white">
          <i class="ri-calendar-line font-40 text-muted opacity-25"></i>
          <p class="text-muted mt-2">No se encontró actividad registrada para este periodo.</p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<%# --- MODAL DE REAGENDADO (ADMIN) --- %>
<% if current_user.role == 'admin' %>
  <div class="modal fade" id="editDateModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
      <div class="modal-content shadow-lg border-0">
        <div class="modal-header bg-light py-2">
          <h6 class="modal-title fw-bold">Modificar Fecha de Registro</h6>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <%= form_with url: update_timeline_event_path, method: :patch do |f| %>
            <%= hidden_field_tag :log_id, "", id: "modal_log_id" %>
            <div class="mb-3">
              <label class="form-label small text-muted">Nueva Fecha y Hora</label>
              <input type="datetime-local" name="new_date" id="modal_new_date" class="form-control form-control-sm border-primary-subtle" required>
            </div>
            <div class="d-grid">
              <button type="submit" class="btn btn-primary btn-sm shadow-sm">Guardar Cambio</button>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <script>
    function openEditDateModal(logId, currentDateStr) {
      document.getElementById('modal_log_id').value = logId;
      let date = new Date(currentDateStr);
      let tzOffset = date.getTimezoneOffset() * 60000;
      let localISODate = (new Date(date.getTime() - tzOffset)).toISOString().slice(0, 16);
      document.getElementById('modal_new_date').value = localISODate;
      new bootstrap.Modal(document.getElementById('editDateModal')).show();
    }
  </script>

  <style>
    /* Estilos del Timeline y Botón Invisible */
    .btn-invisible {
        opacity: 0;
        visibility: hidden;
        transition: all 0.2s ease;
    }
    .date-hover-zone:hover .btn-invisible {
        opacity: 1;
        visibility: visible;
    }
    .timeline-alt .timeline-item:before {
        left: 15px;
        background-color: #f1f3fa;
    }
    .timeline-alt .timeline-icon {
        left: 0;
        width: 32px;
        height: 32px;
        background: #fff;
    }
    .hover-primary:hover {
        color: var(--bs-primary) !important;
        text-decoration: underline !important;
    }
  </style>
<% end %>