<%# app/views/clients/_form.html.erb %>
<%= form_with(model: client, local: true, class: "needs-validation shadow-none", html: { multipart: true }) do |form| %>
  
  <% if client.errors.any? %>
    <div class="alert alert-danger alert-dismissible bg-danger text-white border-0 fade show" role="alert">
      <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
      <strong><i class="ri-error-warning-line me-1"></i> ¡Atención!</strong>
      <ul class="mb-0 font-13">
        <% client.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card border-0 shadow-sm">
    <div class="card-body">
      <%# --- NAVEGACIÓN POR PESTAÑAS --- %>
      <ul class="nav nav-pills bg-nav-pills nav-justified mb-3" role="tablist">
        <li class="nav-item">
          <a href="#tab-identificacion" data-bs-toggle="tab" class="nav-link rounded-0 active">
            <i class="ri-bank-card-line d-md-none d-block"></i>
            <span class="d-none d-md-block">1. Identificación</span>
          </a>
        </li>
        <li class="nav-item">
          <a href="#tab-dimensionamiento" data-bs-toggle="tab" class="nav-link rounded-0">
            <i class="ri-bar-chart-box-line d-md-none d-block"></i>
            <span class="d-none d-md-block">2. Dimensionamiento</span>
          </a>
        </li>
        <li class="nav-item">
          <a href="#tab-contactos" data-bs-toggle="tab" class="nav-link rounded-0">
            <i class="ri-contacts-line d-md-none d-block"></i>
            <span class="d-none d-md-block">3. Contactos</span>
          </a>
        </li>
        <li class="nav-item">
          <a href="#tab-sistemas" data-bs-toggle="tab" class="nav-link rounded-0">
            <i class="ri-computer-line d-md-none d-block"></i>
            <span class="d-none d-md-block">4. Sistemas</span>
          </a>
        </li>
        <li class="nav-item">
          <a href="#tab-contexto" data-bs-toggle="tab" class="nav-link rounded-0">
            <i class="ri-focus-2-line d-md-none d-block"></i>
            <span class="d-none d-md-block">5. Estrategia</span>
          </a>
        </li>
        <li class="nav-item">
          <a href="#tab-coordinacion" data-bs-toggle="tab" class="nav-link rounded-0">
            <i class="ri-team-line d-md-none d-block"></i>
            <span class="d-none d-md-block">6. Coordinación</span>
          </a>
        </li>
        <li class="nav-item">
          <a href="#tab-redes" data-bs-toggle="tab" class="nav-link rounded-0">
            <i class="ri-share-line d-md-none d-block"></i>
            <span class="d-none d-md-block">7. Redes</span>
          </a>
        </li>
      </ul>

      <div class="tab-content border-0 p-0">
        
        <%# --- TAB 1: IDENTIFICACIÓN --- %>
        <div class="tab-pane show active" id="tab-identificacion">
          <h5 class="mb-3 text-uppercase bg-light p-2 rounded-1"><i class="ri-building-line me-1"></i> Datos Legales y Fiscales</h5>
          
          <div class="row g-2 mb-3">
            <div class="col-md-3">
              <div class="card border shadow-none mb-0">
                <div class="card-body p-2 text-center">
                   <label class="form-label font-12 text-muted mb-1">Logotipo / Avatar</label>
                   <%= form.file_field :avatar, class: "form-control form-control-sm", accept: "image/*" %>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="form-floating">
                <%= form.text_field :rfc, class: "form-control", placeholder: "RFC", required: true %>
                <%= form.label :rfc, "RFC (Registro Fiscal)" %>
              </div>
            </div>
            <div class="col-md-3">
              <div class="form-floating">
                <%= form.text_field :company_name, class: "form-control", placeholder: "Razón Social", required: true %>
                <%= form.label :company_name, "Razón Social" %>
              </div>
            </div>
            <div class="col-md-3">
              <div class="form-floating">
                <%= form.text_field :trade_name, class: "form-control", placeholder: "Nombre Comercial", required: true %>
                <%= form.label :trade_name, "Nombre Comercial" %>
              </div>
            </div>
          </div>

          <div class="row g-2 mb-3">
            <div class="col-md-3">
              <div class="form-floating">
                <%= form.text_field :corporate_regime, class: "form-control", placeholder: "Régimen S." %>
                <%= form.label :corporate_regime, "Régimen Societario" %>
              </div>
            </div>
            <div class="col-md-3">
              <div class="form-floating">
                <%= form.text_field :tax_regime, class: "form-control", placeholder: "Régimen F." %>
                <%= form.label :tax_regime, "Régimen Fiscal" %>
              </div>
            </div>
            <div class="col-md-3">
              <div class="form-floating">
                <%= form.text_field :type_taxpayer, class: "form-control", placeholder: "Tipo" %>
                <%= form.label :type_taxpayer, "Tipo de Contribuyente" %>
              </div>
            </div>
            <div class="col-md-3">
              <div class="form-floating">
                <%= form.text_field :industry, class: "form-control", placeholder: "Giro" %>
                <%= form.label :industry, "Industria / Giro" %>
              </div>
            </div>
          </div>

          <div class="row g-2 mb-4">
            <div class="col-md-12">
               <div class="form-floating">
                 <%= form.text_field :country, class: "form-control", placeholder: "País", value: client.country || "México" %>
                 <%= form.label :country, "País" %>
               </div>
            </div>
          </div>

          <div class="row">
            <%# DIRECCIÓN FISCAL %>
            <div class="col-md-6 border-end">
              <h5 class="mb-3 text-uppercase font-12 fw-bold text-muted"><i class="ri-map-pin-line me-1"></i> Dirección Fiscal</h5>
              <div class="form-floating mb-2">
                <%= form.text_field :tax_street, class: "form-control", id: "tax_street", placeholder: "Calle" %>
                <%= form.label :tax_street, "Calle" %>
              </div>
              <div class="row g-2 mb-2">
                <div class="col-6"><div class="form-floating"><%= form.text_field :tax_no_ext, class: "form-control", id: "tax_ext", placeholder: "Ext" %><%= form.label :tax_no_ext, "No. Ext" %></div></div>
                <div class="col-6"><div class="form-floating"><%= form.text_field :tax_no_int, class: "form-control", id: "tax_int", placeholder: "Int" %><%= form.label :tax_no_int, "No. Int" %></div></div>
              </div>
              <div class="form-floating mb-2">
                <%= form.text_field :tax_suburb, class: "form-control", id: "tax_suburb", placeholder: "Colonia" %>
                <%= form.label :tax_suburb, "Colonia" %>
              </div>
              <div class="row g-2">
                <div class="col-4"><div class="form-floating"><%= form.text_field :tax_cp, class: "form-control", id: "tax_cp", placeholder: "CP" %><%= form.label :tax_cp, "C.P." %></div></div>
                <div class="col-8"><div class="form-floating"><%= form.text_field :tax_city, class: "form-control", id: "tax_city", placeholder: "Ciudad" %><%= form.label :tax_city, "Ciudad / Alcaldía" %></div></div>
              </div>
            </div>

            <%# DIRECCIÓN OPERATIVA %>
            <div class="col-md-6">
              <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="text-uppercase font-12 fw-bold text-muted m-0"><i class="ri-map-pin-user-line me-1"></i> Dirección Operativa</h5>
                <button onclick="copiarDireccion()" type="button" class="btn btn-soft-info btn-xs py-0 px-1" id="copy-address"><i class="ri-file-copy-line"></i> Igual a Fiscal</button>
              </div>
              <div class="form-floating mb-2">
                <%= form.text_field :oper_street, class: "form-control", id: "oper_street", placeholder: "Calle" %>
                <%= form.label :oper_street, "Calle" %>
              </div>
              <div class="row g-2 mb-2">
                <div class="col-6"><div class="form-floating"><%= form.text_field :oper_no_ext, class: "form-control", id: "oper_ext", placeholder: "Ext" %><%= form.label :oper_no_ext, "No. Ext" %></div></div>
                <div class="col-6"><div class="form-floating"><%= form.text_field :oper_no_int, class: "form-control", id: "oper_int", placeholder: "Int" %><%= form.label :oper_no_int, "No. Int" %></div></div>
              </div>
              <div class="form-floating mb-2">
                <%= form.text_field :oper_suburb, class: "form-control", id: "oper_suburb", placeholder: "Colonia" %>
                <%= form.label :oper_suburb, "Colonia" %>
              </div>
              <div class="row g-2">
                <div class="col-4"><div class="form-floating"><%= form.text_field :oper_cp, class: "form-control", id: "oper_cp", placeholder: "CP" %><%= form.label :oper_cp, "C.P." %></div></div>
                <div class="col-8"><div class="form-floating"><%= form.text_field :oper_city, class: "form-control", id: "oper_city", placeholder: "Ciudad" %><%= form.label :oper_city, "Ciudad / Alcaldía" %></div></div>
              </div>
            </div>
          </div>
        </div>

        <%# --- TAB 2: DIMENSIONAMIENTO --- %>
        <div class="tab-pane" id="tab-dimensionamiento">
          <h5 class="mb-3 text-uppercase bg-light p-2 rounded-1"><i class="ri-pulse-line me-1"></i> Dimensionamiento de la Empresa</h5>
          <div class="row g-3">
            <div class="col-md-3">
              <div class="form-floating">
                <%= form.number_field :operation_year, class: "form-control", placeholder: "0" %>
                <%= form.label :operation_year, "Años Operando" %>
              </div>
            </div>
            <div class="col-md-3">
              <div class="form-floating">
                <%= form.number_field :total_employee, class: "form-control", placeholder: "0" %>
                <%= form.label :total_employee, "Total Empleados" %>
              </div>
            </div>
            <div class="col-md-3">
              <div class="form-floating">
                <%= form.number_field :total_location, class: "form-control", placeholder: "0" %>
                <%= form.label :total_location, "No. de Sucursales / Sedes" %>
              </div>
            </div>
            <div class="col-md-3">
              <div class="form-floating">
                <%= form.text_field :product_service, class: "form-control", placeholder: "Prod" %>
                <%= form.label :product_service, "Principales Productos / Servicios" %>
              </div>
            </div>
          </div>
        </div>

        <%# --- TAB 3: CONTACTOS --- %>
        <div class="tab-pane" id="tab-contactos">
          <div class="row g-4">
             <% [
                ['ri-star-line text-warning', '1. Sponsor (Dueño/Director)', 'sponsor'],
                ['ri-scales-line', '2. Representante Legal', 'legal_representative'],
                ['ri-settings-line', '3. Operaciones', 'operation'],
                ['ri-money-dollar-circle-line', '4. Finanzas / Contabilidad', 'finance_accounting'],
                ['ri-user-heart-line', '5. RRHH', 'rrhh'],
                ['ri-shopping-cart-line', '6. Comercial', 'comercial']
             ].each do |icon, title, prefix| %>
                <div class="col-md-6">
                  <div class="p-2 border rounded bg-light bg-opacity-25">
                    <h6 class="mt-0 mb-2 font-13 text-primary"><i class="<%= icon %> me-1"></i> <%= title %></h6>
                    <div class="row g-2">
                      <div class="col-6"><div class="form-floating"><%= form.text_field "#{prefix}_name", class: "form-control form-control-sm", placeholder: "Nombre" %><%= form.label "#{prefix}_name", "Nombre" %></div></div>
                      <div class="col-6"><div class="form-floating"><%= form.text_field "#{prefix}_position", class: "form-control form-control-sm", placeholder: "Cargo" %><%= form.label "#{prefix}_position", "Cargo" %></div></div>
                      <div class="col-6"><div class="form-floating"><%= form.email_field "#{prefix}_email", class: "form-control form-control-sm", placeholder: "Email" %><%= form.label "#{prefix}_email", "Email" %></div></div>
                      <div class="col-6"><div class="form-floating"><%= form.text_field "#{prefix}_cel", class: "form-control form-control-sm", placeholder: "Cel" %><%= form.label "#{prefix}_cel", "Celular" %></div></div>
                    </div>
                  </div>
                </div>
             <% end %>
          </div>
        </div>

        <%# --- TAB 4: SISTEMAS --- %>
        <div class="tab-pane" id="tab-sistemas">
          <h5 class="mb-3 text-uppercase bg-light p-2 rounded-1"><i class="ri-cpu-line me-1"></i> Ecosistema Tecnológico</h5>
          <div class="row g-3">
            <div class="col-md-4"><div class="form-floating"><%= form.text_field :erp_system, class: "form-control", placeholder: "ERP" %><%= form.label :erp_system, "Sistema ERP / Admin" %></div></div>
            <div class="col-md-4"><div class="form-floating"><%= form.text_field :crm_system, class: "form-control", placeholder: "CRM" %><%= form.label :crm_system, "Sistema CRM / Ventas" %></div></div>
            <div class="col-md-4"><div class="form-floating"><%= form.text_field :accounting_system, class: "form-control", placeholder: "Cont" %><%= form.label :accounting_system, "Sistema Contable" %></div></div>
            <div class="col-md-6"><div class="form-floating"><%= form.text_field :rrhh_system, class: "form-control", placeholder: "RH" %><%= form.label :rrhh_system, "Sistema Nómina / RRHH" %></div></div>
            <div class="col-md-6"><div class="form-floating"><%= form.text_field :storage_system, class: "form-control", placeholder: "Doc" %><%= form.label :storage_system, "Almacenamiento Documental" %></div></div>
          </div>
        </div>

        <%# --- TAB 5: CONTEXTO --- %>
        <div class="tab-pane" id="tab-contexto">
          <h5 class="mb-3 text-uppercase bg-light p-2 rounded-1"><i class="ri-focus-3-line me-1"></i> Diagnóstico Estratégico</h5>
          <div class="form-floating mb-3">
            <%= form.text_area :main_issue, class: "form-control", placeholder: "Prob", style: "height: 120px;" %>
            <%= form.label :main_issue, "Problemática Principal" %>
          </div>
          <div class="form-floating mb-3">
            <%= form.text_area :project_objective, class: "form-control", placeholder: "Obj", style: "height: 120px;" %>
            <%= form.label :project_objective, "Objetivo del Proyecto" %>
          </div>
          <div class="row">
            <div class="col-md-4">
               <div class="form-floating">
                 <%= form.text_field :deadline, class: "form-control", placeholder: "Deadline" %>
                 <%= form.label :deadline, "Fecha Límite Estimada" %>
               </div>
            </div>
          </div>
        </div>

        <%# --- TAB 6: COORDINACIÓN --- %>
        <div class="tab-pane" id="tab-coordinacion">
          <h5 class="mb-3 text-uppercase bg-light p-2 rounded-1"><i class="ri-user-follow-line me-1"></i> Punto de Contacto Consilium</h5>
          <div class="row g-3">
            <div class="col-md-6">
              <div class="form-floating">
                <%= form.text_field :internal_responsible_name, class: "form-control", placeholder: "Nombre" %>
                <%= form.label :internal_responsible_name, "Nombre del Responsable Interno" %>
              </div>
            </div>
            <div class="col-md-6">
              <div class="form-floating">
                <%= form.text_field :internal_responsible_contact, class: "form-control", placeholder: "Contacto" %>
                <%= form.label :internal_responsible_contact, "Teléfono / Email de Contacto" %>
              </div>
            </div>
          </div>
        </div>

        <%# --- TAB 7: REDES --- %>
        <div class="tab-pane" id="tab-redes">
          <h5 class="mb-3 text-uppercase bg-light p-2 rounded-1"><i class="ri-global-line me-1"></i> Presencia Digital</h5>
          <div class="form-floating mb-3">
            <%= form.text_field :web_page, class: "form-control", placeholder: "Web" %>
            <%= form.label :web_page, "Página Web Oficial" %>
          </div>
          <div class="form-floating">
            <%= form.text_area :social_network, class: "form-control", placeholder: "Redes", style: "height: 120px;" %>
            <%= form.label :social_network, "Enlaces a Redes Sociales (uno por línea)" %>
          </div>
        </div>

      </div> <%# Fin tab-content %>
    </div> <%# Fin card-body %>
    
    <div class="card-footer bg-light d-flex justify-content-between py-3">
      <%= link_to clients_path, class: "btn btn-outline-secondary px-4" do %>
        <i class="ri-close-line me-1"></i> Cancelar
      <% end %>
      <%= form.submit client.new_record? ? "Registrar Cliente" : "Guardar Cambios", class: "btn btn-primary px-4 shadow-sm" %>
    </div>
  </div>
<% end %>

<script>
  function copiarDireccion() {
    const fields = ['street', 'ext', 'int', 'suburb', 'cp', 'city'];
    fields.forEach(f => {
      const fiscal = document.getElementById(`tax_${f}`);
      const oper = document.getElementById(`oper_${f}`);
      if (fiscal && oper) oper.value = fiscal.value;
    });
  }
</script>