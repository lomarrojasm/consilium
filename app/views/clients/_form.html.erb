<%# app/views/clients/_form.html.erb %>
<%= form_with(model: client, local: true, class: "needs-validation shadow-none", html: { multipart: true }) do |form| %>
  
  <% if client.errors.any? %>
    <div class="alert alert-danger alert-dismissible bg-danger text-white border-0 fade show" role="alert">
      <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
      <strong><i class="ri-error-warning-line me-1"></i> ¡Atención!</strong>
      <ul class="mb-0 font-13">
        <% client.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card border-0 shadow-sm">
    <div class="card-body">
      <%# --- NAVEGACIÓN POR PESTAÑAS --- %>
      <ul class="nav nav-pills bg-nav-pills nav-justified mb-3" role="tablist">
        <li class="nav-item">
          <a href="#tab-identificacion" data-bs-toggle="tab" class="nav-link rounded-0 active">
            <i class="ri-bank-card-line d-md-none d-block"></i>
            <span class="d-none d-md-block">1. Identificación</span>
          </a>
        </li>
      </ul>

      <div class="tab-content border-0 p-0">
        <%# --- TAB 1: IDENTIFICACIÓN --- %>
        <div class="tab-pane show active" id="tab-identificacion">
          <h5 class="mb-3 text-uppercase bg-light p-2 rounded-1"><i class="ri-building-line me-1"></i> Datos Legales y Fiscales</h5>
          <div class="row mb-3">
            <%# --- COLUMNA 1: NIVEL DE MEMBRESÍA --- %>
            <div class="col-md-3">
              <%= form.label :membership, "Nivel de Membresía", class: "form-label fw-bold" %>
              <div class="input-group">
                <span class="input-group-text bg-light"><i class="ri-vip-crown-line text-primary"></i></span>
                <% if current_user.role == 'admin' %>
                  <%= form.select :membership, 
                      Client.memberships.keys.map { |m| [m.humanize, m] }, 
                      {}, 
                      { class: "form-select shadow-none" } %>
                <% else %>
                  <%# MODO LECTURA PARA NO-ADMINS %>
                  <input type="text" class="form-control bg-light" value="<%= @client.membership&.humanize %>" readonly disabled>
                <% end %>
              </div>
            </div>
            <div class="col-md-3">
              <p></p>
              <div class="form-floating">
                <%= form.select :status, 
                  ['Activo', 'Inactivo'], 
                  { include_blank: false }, 
                  class: "form-select" %>
                <%= form.label :status, "Estatus" %>
              </div>
            </div>
            <%# --- COLUMNA 2: CONTRATO (PDF/WORD) --- %>
            <div class="col-md-6">
              <%= form.label :contract, "Contrato Firmado (PDF/Word)", class: "form-label fw-bold" %>
              <div class="input-group">
                <span class="input-group-text bg-light"><i class="ri-file-paper-2-line text-primary"></i></span>
                <% if current_user.role == 'admin' %>
                  <%= form.file_field :contract, class: "form-control shadow-none", accept: ".pdf,.doc,.docx" %>
                <% else %>
                  <%# LINK DE DESCARGA SI YA EXISTE, SINO TEXTO VACÍO %>
                  <div class="form-control bg-light d-flex align-items-center">
                    <% if @client.contract.attached? %>
                      <%= link_to rails_blob_path(@client.contract, disposition: "attachment"), class: "text-primary fw-bold text-decoration-none font-12" do %>
                        <i class="ri-download-cloud-2-line me-1"></i> Descargar Contrato Actual
                      <% end %>
                    <% else %>
                      <span class="text-muted font-12 italic">Sin contrato cargado</span>
                    <% end %>
                  </div>
                <% end %>
              </div>
              <% if @client.contract.attached? && current_user.role == 'admin' %>
                <small class="text-success fw-bold d-block mt-1">
                  <i class="ri-check-line"></i> Ya existe un archivo: <%= @client.contract.filename %>
                </small>
              <% end %>
            </div>
          </div>
          <div class="row g-2 mb-3">
            <div class="col-md-3">
              <div class="card border shadow-none mb-0">
                <div class="card-body p-2 text-center">
                   <label class="form-label font-12 text-muted mb-1">Logotipo / Avatar</label>
                   <%= form.file_field :avatar, class: "form-control form-control-sm", accept: "image/*" %>
                </div>
              </div>
            </div>
            <div class="col-md-3">
              <div class="form-floating">
                <%= form.text_field :rfc, class: "form-control", placeholder: "RFC", required: true %>
                <%= form.label :rfc, "RFC (Registro Fiscal)" %>
              </div>
            </div>
            <div class="col-md-3">
              <div class="form-floating">
                <%= form.text_field :company_name, class: "form-control", placeholder: "Razón Social", required: true %>
                <%= form.label :company_name, "Razón Social" %>
              </div>
            </div>
            <div class="col-md-3">
              <div class="form-floating">
                <%= form.text_field :trade_name, class: "form-control", placeholder: "Nombre Comercial" %>
                <%= form.label :trade_name, "Nombre Comercial" %>
              </div>
            </div>
          </div>
          <div class="row g-2 mb-3">
            <div class="col-md-3">
              <div class="form-floating">
                <%= form.text_field :tax_regime, class: "form-control", placeholder: "Régimen F." %>
                <%= form.label :tax_regime, "Régimen de Capital" %>
              </div>
            </div>
            <div class="col-md-3">
              <div class="form-floating">
                <%= form.select :type_taxpayer, 
                  ['Físca', 'Moral'], 
                  { include_blank: false }, 
                  class: "form-select" %>
                <%= form.label :type_taxpayer, "Tipo de Persona" %>
              </div>
            </div>
            <div class="col-md-3">
                <div class="form-floating">
                  <%= form.number_field :operation_year, class: "form-control", placeholder: "0" %>
                  <%= form.label :operation_year, "Años Operando" %>
                </div>
              </div>
              <div class="col-md-3">
                <div class="form-floating">
                  <%= form.date_field :start_date, class: "form-control" %>
                  <%= form.label :operation_year, "Fecha de Inicio" %>
                </div>
              </div>
          </div>
          <div class="row g-2 mb-3">
            <div class="col-md-6">
              <div class="form-floating">
                <%= form.text_area :corporate_regime, class: "form-control", style: "height: 100px;", placeholder: "Régimen S." %>
                <%= form.label :corporate_regime, "Régimen(Desc. Completa)" %>
              </div>
            </div>
            <div class="col-md-6">
              <div class="form-floating">
                <%= form.text_area :industry, class: "form-control", style: "height: 100px;", placeholder: "Giro" %>
                <%= form.label :industry, "Actividades Económicas (con %)" %>
              </div>
            </div>
          </div>
          <div class="row g-4 mb-3">
             <% [
                ['ri-star-line text-warning', '1. Sponsor', 'sponsor']
             ].each do |icon, title, prefix| %>
                <div class="col-md-12">
                  <div class="p-2 border rounded bg-light bg-opacity-25">
                    <h6 class="mt-0 mb-2 font-13 text-primary"><i class="<%= icon %> me-1"></i> <%= title %></h6>
                    <div class="row g-2">
                      <div class="col-3"><div class="form-floating"><%= form.text_field "#{prefix}_name", class: "form-control form-control-sm", placeholder: "Nombre" %><%= form.label "#{prefix}_name", "Nombre" %></div></div>
                      <div class="col-3"><div class="form-floating"><%= form.text_field "#{prefix}_position", class: "form-control form-control-sm", placeholder: "Cargo" %><%= form.label "#{prefix}_position", "Cargo" %></div></div>
                      <div class="col-3"><div class="form-floating"><%= form.email_field "#{prefix}_email", class: "form-control form-control-sm", placeholder: "Email" %><%= form.label "#{prefix}_email", "Email" %></div></div>
                      <div class="col-3"><div class="form-floating"><%= form.text_field "#{prefix}_cel", class: "form-control form-control-sm", placeholder: "Cel" %><%= form.label "#{prefix}_cel", "Celular" %></div></div>
                    </div>
                  </div>
                </div>
             <% end %>
          </div>
          <div class="row">
            <div class="col-md-3 border-end"></div>
            <%# DIRECCIÓN FISCAL %>
            <div class="col-md-6 border-end">
              <h5 class="mb-3 text-uppercase font-12 fw-bold text-muted"><i class="ri-map-pin-line me-1"></i> Dirección Fiscal</h5>
              <div class="form-floating mb-2">
                <%= form.text_field :country, class: "form-control", id: "country", placeholder: "Páis" %>
                <%= form.label :tax_street, "Páis" %>
              </div>
              <div class="row g-2 mb-2">
                <div class="col-6"><div class="form-floating"><%= form.text_field :tax_street, class: "form-control", id: "tax_street", placeholder: "Calle" %><%= form.label :tax_street, "Calle" %></div></div>
                <div class="col-3"><div class="form-floating"><%= form.text_field :tax_no_ext, class: "form-control", id: "tax_ext", placeholder: "Ext" %><%= form.label :tax_no_ext, "No. Ext" %></div></div>
                <div class="col-3"><div class="form-floating"><%= form.text_field :tax_no_int, class: "form-control", id: "tax_int", placeholder: "Int" %><%= form.label :tax_no_int, "No. Int" %></div></div>
              </div>
              <div class="row g-2">
                <div class="col-4"><div class="form-floating"><%= form.text_field :tax_suburb, class: "form-control", id: "tax_suburb", placeholder: "Colonia" %><%= form.label :tax_suburb, "Colonia" %></div></div>
                <div class="col-4"><div class="form-floating"><%= form.text_field :tax_cp, class: "form-control", id: "tax_cp", placeholder: "CP" %><%= form.label :tax_cp, "C.P." %></div></div>
                <div class="col-4"><div class="form-floating"><%= form.text_field :tax_city, class: "form-control", id: "tax_city", placeholder: "Ciudad" %><%= form.label :tax_city, "Ciudad / Alcaldía" %></div></div>
              </div>
            </div>
          </div>
        </div>
      </div> <%# Fin tab-content %>
    </div> <%# Fin card-body %>
    <div class="card-footer bg-light d-flex justify-content-between py-3">
      <%= link_to clients_path, class: "btn btn-outline-secondary px-4" do %>
        <i class="ri-close-line me-1"></i> Cancelar
      <% end %>
      <%= form.submit client.new_record? ? "Registrar Cliente" : "Guardar Cambios", class: "btn btn-primary px-4 shadow-sm" %>
    </div>
  </div>
<% end %>