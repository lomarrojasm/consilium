<%= form_with(model: client, class: "needs-validation") do |form| %>
  
  <% if client.errors.any? %>
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <strong>¡Atención!</strong> Revisa los siguientes errores:
      <ul class="mb-0">
        <% client.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% end %>

  <div class="card">
    <div class="card-body">
      
      <ul class="nav nav-pills bg-nav-pills nav-justified mb-3" role="tablist">
        <li class="nav-item">
          <a href="#tab-identificacion" data-bs-toggle="tab" aria-expanded="false" class="nav-link rounded-0 active">
            <i class="mdi mdi-home-variant d-md-none d-block"></i>
            <span class="d-none d-md-block">1.- Identificación</span>
          </a>
        </li>
        <li class="nav-item">
          <a href="#tab-dimensionamiento" data-bs-toggle="tab" aria-expanded="true" class="nav-link rounded-0">
            <i class="mdi mdi-account-group d-md-none d-block"></i>
            <span class="d-none d-md-block">2.- Dimensionamiento</span>
          </a>
        </li>
        <li class="nav-item">
          <a href="#tab-contactos" data-bs-toggle="tab" aria-expanded="false" class="nav-link rounded-0">
            <i class="mdi mdi-cogs d-md-none d-block"></i>
            <span class="d-none d-md-block">3.- Contactos clave</span>
          </a>
        </li>
        <li class="nav-item">
          <a href="#tab-sistemas" data-bs-toggle="tab" aria-expanded="false" class="nav-link rounded-0">
            <i class="mdi mdi-clipboard-text-outline d-md-none d-block"></i>
            <span class="d-none d-md-block">4.- Sistemas</span>
          </a>
        </li>
        <li class="nav-item">
          <a href="#tab-contexto" data-bs-toggle="tab" aria-expanded="false" class="nav-link rounded-0">
            <i class="mdi mdi-clipboard-text-outline d-md-none d-block"></i>
            <span class="d-none d-md-block">5.- Contexto del Proyecto</span>
          </a>
        </li>
        <li class="nav-item">
          <a href="#tab-coordinacion" data-bs-toggle="tab" aria-expanded="false" class="nav-link rounded-0">
            <i class="mdi mdi-clipboard-text-outline d-md-none d-block"></i>
            <span class="d-none d-md-block">6.- Coordinación</span>
          </a>
        </li>
        <li class="nav-item">
          <a href="#tab-redes" data-bs-toggle="tab" aria-expanded="false" class="nav-link rounded-0">
            <i class="mdi mdi-clipboard-text-outline d-md-none d-block"></i>
            <span class="d-none d-md-block">7.- Redes sociales</span>
          </a>
        </li>
      </ul>

      <div class="tab-content">
        
