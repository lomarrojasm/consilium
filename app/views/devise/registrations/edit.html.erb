<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-10">
      
      <%# El formulario envuelve toda la tarjeta para que 'f' funcione en ambas columnas %>
      <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, multipart: true }) do |f| %>
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
          <div class="row g-0">
            
            <div class="col-md-4 bg-light border-end">
              <div class="p-4 text-center">
                
                <div class="position-relative d-inline-block mb-4">
                  <div id="avatar-preview-container">
                    <% if resource.avatar.attached? %>
                      <%= image_tag resource.avatar, id: "avatar-preview", class: "rounded-circle shadow-sm object-fit-cover", style: "width: 120px; height: 120px; border: 4px solid white;" %>
                    <% else %>
                      <div id="avatar-placeholder" class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm mx-auto" style="width: 120px; height: 120px; font-size: 3rem; border: 4px solid white;">
                        <%= resource.first_name&.first || resource.email.first.upcase %>
                      </div>
                    <% end %>
                  </div>
                  
                  <%# Label vinculado al input oculto %>
                  <label for="user_avatar" class="position-absolute bottom-0 end-0 bg-white rounded-circle shadow-sm p-2 border" style="cursor: pointer; transform: translate(10%, 10%);">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-camera-fill text-primary" viewBox="0 0 16 16">
                      <path d="M10.5 8.5a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0z"/>
                      <path d="M2 4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-1.172a2 2 0 0 1-1.414-.586l-.828-.828A2 2 0 0 0 9.172 2H6.828a2 2 0 0 0-1.414.586l-.828.828A2 2 0 0 1 3.172 4H2zm.5 2a.5.5 0 1 1 0-1 .5.5 0 0 1 0 1zm9 2.5a3.5 3.5 0 1 1-7 0 3.5 3.5 0 0 1 7 0z"/>
                    </svg>
                  </label>
                </div>

                <%# Input de archivo real (oculto) %>
                <div class="d-none">
                  <%= f.file_field :avatar, id: "user_avatar", accept: 'image/*', onchange: "previewImage(this);" %>
                </div>

                <h5 class="fw-bold mb-0 mt-2"><%= "#{resource.first_name} #{resource.last_name}" %></h5>
                <p class="text-muted small">@<%= resource.username %></p>
                
                <span class="badge <%= resource.active ? 'bg-success' : 'bg-danger' %> rounded-pill mb-3">
                  <%= resource.active ? 'Cuenta Activa' : 'Cuenta Inactiva' %>
                </span>

                <hr class="my-4">

                <div class="text-start mb-4">
                  <h6 class="fw-bold small text-uppercase mb-3">Estadísticas de Acceso</h6>
                  <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Inicios de sesión:</span>
                    <span class="fw-bold small"><%= resource.sign_in_count %></span>
                  </div>
                  <div class="mb-2">
                    <p class="text-muted small mb-0">Última IP:</p>
                    <code class="small text-dark"><%= resource.last_sign_in_ip || "N/A" %></code>
                  </div>
                  <div class="mb-2">
                    <p class="text-muted small mb-0">Última conexión:</p>
                    <span class="small fw-semibold"><%= resource.last_sign_in_at&.strftime("%d/%m/%Y %H:%M") || "Nunca" %></span>
                  </div>
                </div>

                <div class="mt-auto pt-4 border-top text-start">
                  <p class="text-muted x-small mb-1 text-uppercase">Creado el: <%= resource.created_at.strftime("%d %b, %Y") %></p>
                  <p class="text-muted x-small text-uppercase">Última actualización: <%= resource.updated_at.strftime("%d %b, %Y") %></p>
                </div>
              </div>
            </div>

            <div class="col-md-8">
              <div class="card-body p-5">
                <%= render "devise/shared/error_messages", resource: resource %>

                <h5 class="fw-bold mb-4 text-primary">Información Personal</h5>
                <div class="row g-3 mb-4">
                  <div class="col-md-6">
                    <div class="form-floating">
                      <%= f.text_field :first_name, class: "form-control", id: "f_name", placeholder: "Nombre" %>
                      <label for="f_name">Nombre</label>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="form-floating">
                      <%= f.text_field :last_name, class: "form-control", id: "l_name", placeholder: "Apellido" %>
                      <label for="l_name">Apellido</label>
                    </div>
                  </div>
                 
                  <div class="col-md-6">
                    <div class="form-floating">
                      <%= f.text_field :job_title, class: "form-control", id: "j_title", placeholder: "Cargo" %>
                      <label for="j_title">Cargo / Puesto</label>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="form-floating">
                      <%= f.text_field :role, class: "form-control border-secondary bg-light", id: "f_role", placeholder: "Rol", readonly: true %>
                      <label for="f_role" class="text-secondary fw-bold">Rol del Sistema</label>
                    </div>
                  </div>
                  <div class="col-12">
                    <div class="form-floating">
                      <%= f.email_field :email, class: "form-control border-secondary bg-light", id: "f_email", placeholder: "email", readonly: true %>
                      <label for="f_email">Correo Electrónico</label>
                    </div>
                  </div>
                </div>

                <h5 class="fw-bold mb-4 text-primary border-top pt-4">Seguridad</h5>
                <div class="alert alert-warning py-2 border-0 shadow-sm mb-4">
                  <p class="small mb-0"><i class="bi bi-info-circle me-2"></i>Deja en blanco la contraseña si no deseas cambiarla.</p>
                </div>
                <div class="row g-3 mb-4">
                  <div class="col-md-6">
                    <div class="form-floating">
                      <%= f.password_field :password, class: "form-control", id: "f_pass", placeholder: "Nueva" %>
                      <label for="f_pass">Nueva Contraseña</label>
                    </div>
                  </div>
                  <div class="col-md-6">
                    <div class="form-floating">
                      <%= f.password_field :password_confirmation, class: "form-control", id: "f_conf", placeholder: "Confirmar" %>
                      <label for="f_conf">Confirmar Nueva Contraseña</label>
                    </div>
                  </div>
                </div>

                <div class="p-4 bg-primary bg-opacity-10 rounded-4 mb-4 border border-primary border-opacity-25">
                  <div class="form-floating">
                    <%= f.password_field :current_password, class: "form-control border-primary", id: "f_curr", placeholder: "Actual", required: true %>
                    <label for="f_curr" class="text-primary fw-bold">Contraseña Actual para Guardar</label>
                  </div>
                </div>

                <div class="d-grid gap-2">
                  <%= f.submit "Actualizar mi Perfil en Consilium", class: "btn btn-primary btn-lg rounded-pill py-3 fw-bold shadow-sm" %>
                  <%= link_to "Cancelar y Volver", :back, class: "btn btn-link text-muted mt-2" %>
                </div>
              </div>
            </div>
          </div>
        </div>
      <% end %>

    </div>
  </div>
</div>

<style>
  .x-small { font-size: 0.7rem; }
  .object-fit-cover { object-fit: cover; }
</style>

<%# Script para Vista Previa Inmediata %>
<script>
  function previewImage(input) {
    if (input.files && input.files[0]) {
      var reader = new FileReader();
      reader.onload = function(e) {
        var preview = document.getElementById('avatar-preview');
        var placeholder = document.getElementById('avatar-placeholder');
        
        if (preview) {
          preview.src = e.target.result;
        } else if (placeholder) {
          // Si no hay imagen previa, cambiamos el placeholder por una imagen
          var img = document.createElement('img');
          img.id = 'avatar-preview';
          img.src = e.target.result;
          img.className = 'rounded-circle shadow-sm object-fit-cover';
          img.style = 'width: 120px; height: 120px; border: 4px solid white;';
          placeholder.parentNode.replaceChild(img, placeholder);
        }
      }
      reader.readAsDataURL(input.files[0]);
    }
  }
</script>