<div class="row justify-content-center mt-4">
  <div class="col-lg-6">
    <div class="card">
      <div class="card-body">
        <h4 class="header-title mb-3">Invitar Nuevo Miembro</h4>
        <p class="text-muted font-14">Se enviará un correo con instrucciones para que el usuario configure su acceso.</p>

        <%= form_for(resource, as: resource_name, url: invitation_path(resource_name), html: { method: :post }) do |f| %>
          <%= render "devise/shared/error_messages", resource: resource %>

          <% resource.class.invite_key_fields.each do |key| -%>
            <div class="mb-3">
              <%= f.label key, "Correo electrónico", class: "form-label" %>
              <%= f.email_field key, class: "form-control", placeholder: "ejemplo@consilium.com" %>
            </div>
          <% end -%>

          <div class="text-end">
            <%= link_to "Cancelar", users_path, class: "btn btn-light me-1" %>
            <%= f.submit "Enviar Invitación", class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>