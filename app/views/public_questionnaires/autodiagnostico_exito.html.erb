<%# 1. NAVBAR SUPERIOR %>
<nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top shadow-sm py-2">
  <div class="container-fluid px-4">
    <div class="d-flex align-items-center">
      <div class="text-start">
        <span class="fw-bold text-dark font-18" style="letter-spacing: -0.5px;">
          Cons<span class="text-primary">ilium</span>
        </span>
        <small class="text-muted d-block mt-n1" style="font-size: 8px; font-weight: 500;">Consulta, delega y transforma</small>
      </div>
    </div>
    <div class="ms-auto">
      <%= link_to "Nuevo Diagnóstico", new_autodiagnostico_path, class: "btn btn-outline-primary rounded-pill px-3 py-1 font-12 fw-bold" %>
    </div>
  </div>
</nav>

<div class="auth-fluid-container" style="min-height: calc(100vh - 60px); display: flex; align-items: center; justify-content: center; background: #f4f7fa; position: relative; overflow: hidden; padding: 40px 0;">
  
  <%# Fondo de círculos decorativos %>
  <div class="auth-fluid-circles">
    <div class="circle-1"></div><div class="circle-2"></div><div class="circle-3"></div>
  </div>

  <div class="container" style="position: relative; z-index: 10;">
    <div class="row justify-content-center">
      <div class="col-lg-11 col-xl-10">
        
        <div class="card border-0 shadow-lg" style="border-radius: 24px; background: white;">
          <div class="card-header py-4 text-center border-0" style="background-color: #6366f1;">
            <h3 class="text-white fw-bold mb-0">Resultados del Diagnóstico de Madurez</h3>
          </div>
          
          <div class="card-body p-4 p-md-5">
            <div class="row align-items-start">
              
              <%# --- BLOQUE IZQUIERDO: GRÁFICA --- %>
              <div class="col-md-7 mb-4 mb-md-0">
                <div class="text-center mb-3">
                  <h4 class="fw-bold text-dark mb-1">Radiografía Empresarial</h4>
                  <p class="text-muted small">Visualización de los 5 pilares estratégicos</p>
                </div>
                
                <%# El controlador de Stimulus se encarga de la carga dinámica de la librería y el dibujo %>
                <div data-controller="chart" 
                     data-chart-scores-value="<%= @scores.to_json %>"
                     style="width: 100%; height: 400px; position: relative;">
                    
                    <canvas id="radarChart" 
                            data-chart-target="canvas"
                            style="display: block; width: 100%; height: 400px;">
                    </canvas>
                </div>
              </div>

              <%# --- BLOQUE DERECHO: MÉTRICAS Y COMENTARIOS --- %>
              <div class="col-md-5 ps-md-4 border-start">
                <h5 class="fw-bold mb-4 text-dark pb-2 border-bottom">Puntuación por Área</h5>
                
                <% categories = ["Dirección", "Finanzas", "Operaciones", "Comercial", "Personas"] %>
                <% total_score = 0 %>
                
                <% @scores.each_with_index do |score, i| %>
                  <% total_score += score %>
                  <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                      <span class="font-12 fw-bold text-dark"><%= categories[i] %></span>
                      <span class="font-12 fw-bold text-primary"><%= score %> / 5.0</span>
                    </div>
                    <div class="progress" style="height: 8px; border-radius: 10px; background-color: #eee;">
                      <div class="progress-bar custom-gradient-progress" 
                           role="progressbar" 
                           style="width: <%= (score/5.0)*100 %>%"></div>
                    </div>
                  </div>
                <% end %>

                <%# --- INTERPRETACIÓN DEL RESULTADO --- %>
                <% avg = (total_score / 5.0).round(1) %>
                <div class="mt-4 p-3 rounded-4 bg-light border">
                  <h6 class="fw-bold text-dark mb-2">Diagnóstico General: <span class="text-primary"><%= avg %> / 5.0</span></h6>
                  <p class="text-muted small mb-0">
                    <% if avg <= 2.0 %>
                      <strong>Nivel Inicial:</strong> Tu empresa opera de forma reactiva. Existe una alta dependencia del dueño y falta de procesos formales.
                    <% elsif avg <= 3.5 %>
                      <strong>Nivel en Desarrollo:</strong> Tienes bases sólidas pero la ejecución es inconsistente. Necesitas estandarizar para escalar.
                    <% else %>
                      <strong>Nivel Optimizado:</strong> Tu empresa cuenta con procesos robustos. El enfoque debe ser la innovación y la mejora continua.
                    <% end %>
                  </p>
                </div>
              </div>

            </div>

            <hr class="my-5 opacity-50">

            <%# --- ACCIONES FINALES --- %>
            <div class="text-center">
              <h5 class="fw-bold text-dark mb-3">¿Cómo podemos transformar estos resultados?</h5>
              <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
                <button class="btn btn-primary btn-lg rounded-pill px-5 shadow-sm" style="background-color: #6366f1; border: none;">
                  Descargar Reporte PDF <i class="ri-file-pdf-line ms-1"></i>
                </button>
                <a href="https://wa.me/TU_WHATSAPP" target="_blank" class="btn btn-outline-success btn-lg rounded-pill px-5">
                  Agendar Sesión de Claridad <i class="ri-whatsapp-line ms-1"></i>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%# Scripts adicionales del layout/plantilla %>
<% content_for :javascript do %>
  <%= javascript_include_tag 'pages/demo.chartjs-other.js', defer: true %>
<% end %>

<style>
  /* Círculos de fondo */
  .auth-fluid-circles { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 1; width: 100%; height: 100%; }
  .auth-fluid-circles [class^="circle-"] { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); border-radius: 50%; background: radial-gradient(circle, rgba(99, 102, 241, 0.08) 0%, rgba(99, 102, 241, 0) 70%); border: 1px solid rgba(99, 102, 241, 0.1); }
  .circle-1 { width: 500px; height: 500px; } 
  .circle-2 { width: 850px; height: 850px; } 
  .circle-3 { width: 1200px; height: 1200px; }

  /* Estilos de progreso y texto */
  .custom-gradient-progress { background: linear-gradient(90deg, #6366f1 0%, #a855f7 100%); }
  .font-12 { font-size: 12px; }
  .bg-light { background-color: #f8fafc !important; }
</style>