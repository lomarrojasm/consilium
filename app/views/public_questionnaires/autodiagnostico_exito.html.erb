<%# Para asegurar que la web no muestre el contenido del PDF %>
<style>
  @media screen { .pdf-only { display: none !important; } }
</style>

<%# ========================================== %>
<%# PÁGINA 1: INTRODUCCIÓN (SOLO PDF)          %>
<%# ========================================== %>
<div class="pdf-only pdf-page bg-white">
  <div class="h-100 d-flex flex-column justify-content-center text-center">
    <div class="mb-5">
      <div style="width: 80px; height: 8px; background: #6366f1; margin: 0 auto 30px auto; border-radius: 10px;"></div>
      <h1 class="fw-bold text-dark display-4 mb-2">Cons<span class="text-primary">ilium</span></h1>
      <h3 class="text-muted fw-light">Reporte de Autodiagnóstico Empresarial</h3>
    </div>
    
    <div class="mt-5 p-5 bg-light rounded-4 text-start shadow-sm mx-auto" style="max-width: 600px;">
      <h4 class="fw-bold text-dark mb-4">Bienvenido a tu Diagnóstico</h4>
      <p class="text-muted" style="line-height: 1.8;">
        Este reporte ejecutivo ha sido generado para
        <p>Generado para: <strong><%= @questionnaire.name %></strong></p>
        <p>Cargo: <strong><%= @questionnaire.position %></strong></p>
        <p>Empresa: <strong><%= @questionnaire.company_name %></strong></p>
        Su propósito es brindarte una radiografía clara y objetiva sobre el nivel de madurez actual de tu organización.
      </p>
      <p class="text-muted" style="line-height: 1.8;">
        A través de la metodología Consilium, analizamos 5 pilares fundamentales para identificar brechas, riesgos operativos y, lo más importante, la ruta exacta para escalar tu negocio con control y certidumbre.
      </p>
    </div>
  </div>
  <div class="footer-pdf">Página 1 de 3 | Consilium - Consulta, delega y transforma</div>
</div>


<%# ========================================== %>
<%# PÁGINA 2: GRÁFICA Y PUNTAJES (WEB Y PDF)   %>
<%# ========================================== %>
<div class="page-break pdf-page" style="padding-top: 20px;">
  
  <%# La Navbar solo se ve en la web %>
  <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top shadow-sm py-2 web-only">
    <div class="container-fluid px-4">
      <div class="d-flex align-items-center">
        <span class="fw-bold text-dark font-18">Cons<span class="text-primary">ilium</span></span>
      </div>
      <div class="ms-auto">
        <%= link_to "Nuevo Diagnóstico", new_autodiagnostico_path, class: "btn btn-outline-primary rounded-pill px-3 py-1 font-12 fw-bold" %>
      </div>
    </div>
  </nav>

  <div class="container mt-4">
    <div class="pdf-only text-center mb-4">
      <h3 class="fw-bold text-dark">Radiografía de Madurez</h3>
      <p class="text-muted">Desempeño actual por pilar estratégico</p>
    </div>

    <div class="card border-0 shadow-lg" style="border-radius: 24px; background: white;">
      <div class="card-body p-4 p-md-5">
        <div class="row align-items-center">
          
          <%# GRÁFICA %>
          <div class="col-md-7 mb-4 mb-md-0">
            <div data-controller="chart" data-chart-scores-value="<%= @scores.to_json %>" style="width: 100%; height: 350px;">
                <canvas id="radarChart" data-chart-target="canvas"></canvas>
            </div>
          </div>

          <%# DESGLOSE %>
          <div class="col-md-5 ps-md-4">
            <h5 class="fw-bold mb-4 text-dark border-bottom pb-2">Puntuación por Área</h5>
            <% categories = ["Dirección y Estrategia", "Finanzas", "Operaciones / Procesos", "Comercial (Ventas / Mkt)", "RH (Personas y Cultura)"] %>
            <% @scores.each_with_index do |score, i| %>
              <div class="mb-3">
                <div class="d-flex justify-content-between mb-1">
                  <span class="font-12 fw-bold text-dark"><%= categories[i] %></span>
                  <span class="font-12 fw-bold text-primary"><%= score %> / 5.0</span>
                </div>
                <div class="progress" style="height: 6px; border-radius: 10px;">
                  <div class="progress-bar custom-gradient-progress" style="width: <%= (score/5.0)*100 %>%; background: linear-gradient(90deg, #6366f1 0%, #a855f7 100%);"></div>
                </div>
              </div>
            <% end %>
          </div>

        </div>

        <%# ACCIONES WEB (Ocultas en PDF) %>
        <div class="text-center mt-5 web-only">
          <h5 class="fw-bold text-dark mb-3">¿Cómo transformar estos resultados?</h5>
          <div class="d-flex flex-column flex-sm-row justify-content-center gap-3">
            <%= link_to autodiagnostico_pdf_path(@questionnaire), class: "btn btn-primary btn-lg rounded-pill px-5 shadow-sm", data: { turbo: false } do %>
              Descargar Reporte PDF <i class="ri-file-pdf-line ms-1"></i>
            <% end %>

            <%# Enlace secundario de salida %>
            <%= link_to "Finalizar y Salir", new_user_session_path, class: "text-muted font-12 fw-bold text-decoration-none" %>

          </div>
        </div>

      </div>
    </div>
  </div>
  <div class="footer-pdf pdf-only">Página 2 de 3 | Consilium - Consulta, delega y transforma</div>
</div>


<%# ========================================== %>
<%# PÁGINA 3: PLAN DE ACCIÓN (SOLO PDF)        %>
<%# ========================================== %>
<div class="pdf-only page-break pdf-page bg-white">
  <% avg_global = ((@scores.sum / 25.0) * 100).round %>
  <% dir_score = ((@scores[0] / 5.0) * 100).round %>
  <% op_score = ((@scores[2] / 5.0) * 100).round %>

  <div class="container-fluid p-0">
    <h3 class="fw-bold text-dark mb-4 border-bottom pb-2">Interpretación Ejecutiva</h3>
    <p class="text-muted mb-5 text-justify">
      El prediagnóstico revela un índice global del <strong><%= avg_global %>%</strong>. 
      Dependiendo de los picos en tu gráfica, áreas como Comercial y Finanzas podrían presentar un nivel superior, 
      mientras que pilares como Dirección y Operaciones muestran oportunidades críticas de mejora.
    </p>

    <h4 class="fw-bold text-dark mb-3">Análisis de Capacidades</h4>
    <div class="table-responsive mb-5">
      <table class="table table-custom rounded-3 overflow-hidden shadow-sm">
        <thead>
          <tr>
            <th class="py-3 px-4">Área Estratégica</th>
            <th class="py-3 px-4 text-center">Tu Resultado</th>
            <th class="py-3 px-4 text-center">Referencia Ideal Consilium</th>
          </tr>
        </thead>
        <tbody class="bg-light">
          <% categories.each_with_index do |cat, i| %>
            <tr>
              <td class="py-3 px-4 fw-bold text-dark"><%= cat %></td>
              <td class="py-3 px-4 text-center text-primary fw-bold"><%= @scores[i] %> / 5.0</td>
              <td class="py-3 px-4 text-center text-muted">5.0 / 5.0</td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="row g-4 mb-4 avoid-break">
      <%# DIAGNÓSTICO Y DOLOR %>
      <div class="col-6">
        <div class="card h-100 bg-light p-4">
          <h5 class="fw-bold text-danger mb-3"><i class="ri-error-warning-line me-2"></i> Diagnóstico y Riesgo</h5>
          <p class="small text-muted mb-2">
            "Tu empresa enfrenta brechas en <strong>Dirección y Estrategia (<%= dir_score %>%)</strong> y <strong>Operaciones (<%= op_score %>%)</strong> que afectan su desempeño."
          </p>
          <strong class="small text-dark d-block mt-3">Punto de Dolor:</strong>
          <p class="small text-muted mb-2">Estrés por falta de control y posibles fugas de efectivo que merman la rentabilidad.</p>
          <strong class="small text-dark d-block mt-2">Causa Raíz:</strong>
          <p class="small text-muted mb-0">La falta de procesos definidos limita la gestión, generando decisiones a ciegas.</p>
        </div>
      </div>

      <%# SOLUCIÓN PROPUESTA %>
      <div class="col-6">
        <div class="card h-100 p-4" style="background-color: #f0fdf4; border: 1px solid #bbf7d0 !important;">
          <h5 class="fw-bold text-success mb-3"><i class="ri-checkbox-circle-line me-2"></i> Solución Consilium</h5>
          <p class="small text-muted mb-3">
            Acompañamiento en la definición de objetivos anuales y documentación de procesos clave.
          </p>
          <strong class="small text-dark d-block">Alcance:</strong>
          <ul class="small text-muted mb-3 ps-3">
            <li>Definición de objetivos anuales</li>
            <li>Documentación de procesos clave</li>
            <li>Reportes mensuales de flujo y resultados</li>
          </ul>
          <strong class="small text-dark d-block">Impacto Esperado:</strong>
          <ul class="small text-muted mb-0 ps-3">
            <li>Claridad en la dirección del negocio</li>
            <li>Reducción de riesgos financieros</li>
            <li>Eficiencia operativa garantizada</li>
          </ul>
        </div>
      </div>
    </div>

    <%# CTA FINAL %>
    <div class="text-center mt-5">
      <h5 class="fw-bold text-dark">Transforma tu negocio con Consilium</h5>
      <p class="text-muted small mb-3">Sin compromiso. 30 minutos de asesoría gratuita basada en estos resultados.</p>
      <a href="https://wa.me/TU_NUMERO" style="display: inline-block; background-color: #6366f1; color: white; padding: 12px 30px; border-radius: 30px; text-decoration: none; font-weight: bold;">
        Agendar Sesión de Implementación
      </a>
    </div>

  </div>
  <div class="footer-pdf">Página 3 de 3 | Consilium - Consulta, delega y transforma</div>
</div>