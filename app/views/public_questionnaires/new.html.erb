<%# Inclusión de SweetAlert2 %>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<%# 1. NAVBAR SUPERIOR (Estilo Consilium) %>
<nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top shadow-sm py-2">
  <div class="container-fluid px-4">
    <div class="d-flex align-items-center">
      <div class="text-start">
        <%# Logo en texto (Fallback si no hay imagen) %>
        <span class="fw-bold text-dark font-18" style="letter-spacing: -0.5px;">
          Cons<span class="text-primary">ili</span>um
        </span>
        <small class="text-muted d-block mt-n1" style="font-size: 8px; font-weight: 500;">Consulta, delega y transforma</small>
      </div>
      <div class="ms-3 ps-3 border-start py-1">
        <span class="text-primary fw-bold d-block font-11 mb-0" style="line-height: 1;">Contexto Directivo</span>
        <span class="text-muted font-11">Cuestionario v1.0</span>
      </div>
    </div>
    
    <div class="ms-auto d-flex align-items-center">
      <%= link_to "Reiniciar", new_diagnostico_path, 
          class: "btn btn-soft-danger rounded-pill px-3 py-1 font-12 fw-bold shadow-none",
          data: { turbo: false, confirm: "¿Estás seguro de reiniciar el diagnóstico? Perderás el progreso actual." } %>
    </div>
  </div>
</nav>

<%# 2. CONTENEDOR PRINCIPAL CON STIMULUS %>
<div class="auth-fluid-container" 
     data-controller="questionnaire" 
     style="min-height: calc(100vh - 60px); display: flex; align-items: center; justify-content: center; background: #f4f7fa !important; position: relative; overflow: hidden; padding: 40px 0;">
  
  <%# Círculos Difuminados de Fondo %>
  <div class="auth-fluid-circles">
    <div class="circle-1"></div>
    <div class="circle-2"></div>
    <div class="circle-3"></div>
    <div class="circle-4"></div>
  </div>

  <div class="container" style="position: relative; z-index: 2;">
    <div class="row justify-content-center">
      <div class="col-lg-7 col-xl-6">
        <span class="text-dark fw-bold font-17">Guía de preguntas para alinear historia, operación, prioridades y decisiones clave.</span></br></br>
        <span class="text-secondary font-14">Responde como si estuvieras explicándole tu empresa a un consultor: 
                                                    Breve, real y con ejemplos; y, cuando aplique, con números aproximados. 
                                                    Esto nos permitirá priorizar acciones y construir un plan práctico.</span>
        <%# --- ÁREA DE PROGRESO Y CONTADOR --- %>
        <div class="mb-4 px-1 text-center mt-2">
          <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="badge bg-soft-primary text-primary rounded-pill px-3 py-1 text-uppercase font-10 fw-bold tracking-wider">
              Diagnóstico Estratégico
            </span>
            <span class="fw-bold text-primary font-12" data-questionnaire-target="progressText">0%</span>
          </div>
          
          <div class="progress shadow-sm" style="height: 5px; border-radius: 10px; background-color: rgba(99, 102, 241, 0.15);">
            <div class="progress-bar custom-gradient-progress" 
                 role="progressbar" 
                 style="width: 0%; transition: width 0.6s ease;" 
                 data-questionnaire-target="progressBar"></div>
          </div>

          <%# Contador debajo de la barra %>
          <div class="mt-2">
            <span class="text-muted font-12 fw-bold">
              Pregunta <span data-questionnaire-target="currentNum">1</span> de 31
            </span>
          </div>
        </div>

        <%# --- TARJETA DEL FORMULARIO --- %>
        <div class="card border-0 shadow-lg" style="border-radius: 20px; background: white;">
          <div class="card-header border-0 py-4 text-center" style="background-color: #6366f1;">
             <h4 class="text-white mb-0 fw-bold">Consilium</h4>
          </div>

          <div class="card-body p-4 p-md-5">
            <%= form_with(model: @questionnaire, url: public_questionnaires_path, id: "questionnaire-form") do |f| %>
              
              <div style="min-height: 320px;">
                
                <%# PASO 0: CONTACTO (Floating Labels) %>
                <div data-questionnaire-target="step" class="animate-fade-in">
                  <h2 class="fw-bold text-dark mb-4 text-center">Datos de Contexto</h2>
                  
                  <div class="form-floating mb-3">
                    <%= f.text_field :name, class: "form-control custom-input", id: "floatName", placeholder: "Nombre", required: true %>
                    <label for="floatName">Nombre y puesto</label>
                  </div>

                  <div class="form-floating mb-3">
                    <%= f.text_field :company_name, class: "form-control custom-input", id: "floatCompany", placeholder: "Empresa", required: true %>
                    <label for="floatCompany">Empresa / Razón Social</label>
                  </div>

                  <div class="form-floating mb-3">
                    <%= f.text_field :website, class: "form-control custom-input", id: "floatWeb", placeholder: "Web", required: true %>
                    <label for="floatWeb">Web o redes sociales</label>
                  </div>
                </div>

                <%# PASOS 1-30: PREGUNTAS (Sin Float, obligatorias) %>
                <% get_categorized_questions.each_with_index do |(category, qs), sec_index| %>
                  <% qs.each do |q_key, q_text| %>
                    <div data-questionnaire-target="step" class="d-none animate-fade-in">
                      <div class="text-center mb-4">
                        <span class="text-muted text-uppercase font-10 fw-bold tracking-wider"><%= category %></span>
                        <h3 class="fw-bold text-dark mt-2" style="font-size: 1.5rem; line-height: 1.4;"><%= q_text %></h3>
                      </div>
                      
                      <div class="mb-3">
                        <%= f.fields_for :answers do |af| %>
                          <%= af.text_area q_key, 
                              class: "form-control border-0 bg-light custom-textarea", 
                              rows: 7, 
                              placeholder: "Escribe tu respuesta con detalle aquí...",
                              required: true %>
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                <% end %>
              </div>

              <%# NAVEGACIÓN %>
              <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">
                <button type="button" 
                        class="btn btn-link text-primary fw-bold text-decoration-none d-none" 
                        data-questionnaire-target="prevBtn" 
                        data-action="click->questionnaire#prev">
                  <i class="ri-arrow-left-s-line me-1"></i> Anterior
                </button>
                
                <button type="button" 
                        class="btn btn-primary rounded-pill px-4 py-2 shadow-sm ms-auto" 
                        style="background-color: #6366f1; border: none;"
                        data-questionnaire-target="nextBtn" 
                        data-action="click->questionnaire#next">
                  Siguiente <i class="ri-arrow-right-s-line ms-1"></i>
                </button>
                
                <%= f.submit "Finalizar diagnóstico", 
                    class: "btn btn-success rounded-pill px-4 py-2 shadow-sm d-none", 
                    data: { questionnaire_target: "submitBtn" } %>
              </div>
            <% end %>
          </div>
        </div>
        
        <div class="text-center mt-4">
          <p class="text-muted small">2026 © Consilium</p>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* --- CÍRCULOS CON GLOW --- */
  .auth-fluid-circles {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 1;
    width: 100%;
    height: 100%;
  }
  .auth-fluid-circles [class^="circle-"] {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    border-radius: 50%;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.08) 0%, rgba(99, 102, 241, 0) 70%);
    border: 1px solid rgba(99, 102, 241, 0.1);
    box-shadow: 0 0 40px rgba(99, 102, 241, 0.05);
  }
  .circle-1 { width: 500px; height: 500px; }
  .circle-2 { width: 850px; height: 850px; }
  .circle-3 { width: 1200px; height: 1200px; }
  .circle-4 { width: 1550px; height: 1550px; }

  /* --- UI ELEMENTS --- */
  .custom-gradient-progress {
    background: linear-gradient(90deg, #6366f1 0%, #a855f7 100%);
  }
  .custom-input, .custom-textarea {
    border-radius: 12px;
    background-color: #f8fafc !important;
    border: 1px solid #e2e8f0 !important;
  }
  .custom-input:focus, .custom-textarea:focus {
    background-color: #fff !important;
    border-color: #6366f1 !important;
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1) !important;
  }
  .btn-soft-danger {
    background-color: rgba(250, 92, 124, 0.1);
    color: #fa5c7c;
  }
  .bg-soft-primary { background-color: rgba(99, 102, 241, 0.1); }
  .animate-fade-in { animation: fadeIn 0.4s ease-out; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
</style>