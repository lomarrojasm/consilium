<% @page_title = "Evaluación de Perfil Operativo | Consilium" %>
<% @body_attributes = "class='authentication-bg pb-0'" %>

<%# 1. Inclusión de dependencias externas (SweetAlert2 para validaciones) %>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<%# 2. NAVBAR SUPERIOR %>
<nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top shadow-sm py-2">
  <div class="container-fluid px-4">
    <div class="d-flex align-items-center">
      <div class="text-start">
        <span class="fw-bold text-dark font-18" style="letter-spacing: -0.5px;">
          Cons<span class="text-primary">ilium</span>
        </span>
        <small class="text-muted d-block mt-n1" style="font-size: 8px; font-weight: 500;">Consulta, delega y transforma</small>
      </div>
      <div class="ms-3 ps-3 border-start py-1">
        <span class="text-primary fw-bold d-block font-11 mb-0" style="line-height: 1;">EVALUACIÓN DE PERFIL</span>
        <span class="text-muted font-11">Recomendador de Membresía</span>
      </div>
    </div>
    
    <div class="ms-auto d-flex align-items-center">
      <%= link_to "Reiniciar", new_membership_path, 
          class: "btn btn-soft-danger rounded-pill px-3 py-1 font-12 fw-bold shadow-none",
          data: { turbo: false, confirm: "¿Deseas reiniciar la evaluación? Se perderá tu progreso actual." } %>
    </div>
  </div>
</nav>

<%# 3. CONTENEDOR PRINCIPAL CON STIMULUS %>
<%# Usamos el mismo controlador 'questionnaire' o 'wizard' que ya tienes configurado %>
<div class="auth-fluid-container" 
     data-controller="questionnaire" 
     style="min-height: calc(100vh - 60px); display: flex; align-items: center; justify-content: center; background: #f4f7fa !important; position: relative; overflow: hidden; padding: 40px 0;">
  
  <%# Círculos Glow de Fondo %>
  <div class="auth-fluid-circles">
    <div class="circle-1"></div><div class="circle-2"></div><div class="circle-3"></div><div class="circle-4"></div>
  </div>

  <div class="container" style="position: relative; z-index: 2;">
    <div class="row justify-content-center">
      <div class="col-lg-8 col-xl-7">
        
        <%# --- INDICADORES DE PROGRESO --- %>
        <div class="mb-4 px-1 text-center">
          <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="badge bg-soft-primary text-primary rounded-pill px-3 py-1 text-uppercase font-10 fw-bold tracking-wider">
              Perfil Operativo
            </span>
            <span class="fw-bold text-primary font-12" data-questionnaire-target="progressText">0%</span>
          </div>
          <div class="progress shadow-sm" style="height: 6px; border-radius: 10px; background-color: rgba(99, 102, 241, 0.15);">
            <div class="progress-bar custom-gradient-progress" 
                 data-questionnaire-target="progressBar" 
                 style="width: 0%; transition: width 0.4s ease;"></div>
          </div>
          <div class="mt-2">
            <span class="text-muted font-11 fw-bold">Paso <span data-questionnaire-target="currentNum">1</span> de 7</span>
          </div>
        </div>

        <%# --- TARJETA DEL CUESTIONARIO --- %>
        <div class="card border-0 shadow-lg overflow-hidden" style="border-radius: 20px; background: white;">
          <div class="card-body p-4 p-md-5">
            <%= form_with(model: @questionnaire, url: public_questionnaires_path, id: "membership-form", data: { turbo: false }) do |f| %>
              
              <%# Identificador oculto para que el Dashboard sepa clasificar este registro %>
              <%= f.hidden_field :status, value: 'Evaluación Membresía' %>

              <div style="min-height: 420px;">
                
                <%# PASO 0: DATOS DE CONTACTO %>
                <div data-questionnaire-target="step" class="animate-fade-in">
                  <div class="text-center mb-4">
                    <h2 class="fw-bold text-dark mb-2">Tu Membresía Ideal</h2>
                    <p class="text-muted font-14 px-3">Ingresa tus datos para descubrir qué nivel de acompañamiento (Básico, Gold o Platinum) se adapta a la complejidad de tu empresa.</p>
                  </div>

                  <div class="form-floating mb-3">
                    <%= f.text_field :name, class: "form-control custom-input", id: "floatName", placeholder: "Nombre", required: true %>
                    <label for="floatName">Nombre Completo</label>
                  </div>

                  <div class="form-floating mb-3">
                    <%= f.text_field :position, class: "form-control custom-input", id: "floatPosition", placeholder: "Puesto", required: true %>
                    <label for="floatPosition">Puesto / Cargo</label>
                  </div>

                  <div class="form-floating mb-3">
                    <%= f.text_field :company_name, class: "form-control custom-input", id: "floatCompany", placeholder: "Empresa", required: true %>
                    <label for="floatCompany">Empresa / Razón Social</label>
                  </div>

                  <div class="form-floating mb-4">
                    <%= f.email_field :email, class: "form-control custom-input", id: "floatEmail", placeholder: "Email", required: true %>
                    <label for="floatEmail">Correo Electrónico</label>
                  </div>

                  <div class="bg-light rounded-4 p-3 mb-4 border shadow-sm text-center">
                    <h6 class="fw-bold text-primary mb-1 font-12 text-uppercase"><i class="ri-time-line me-1"></i> Duración Estimada</h6>
                    <p class="text-muted font-12 mb-0">Esta evaluación consta de 6 preguntas de opción múltiple y toma menos de 2 minutos completarla.</p>
                  </div>
                </div>

                <%# PASOS 1-6: PREGUNTAS DE MEMBRESÍA %>
                <% get_membership_questions.each do |category, questions| %>
                  <% questions.each do |key, question_data| %>
                    <div data-questionnaire-target="step" class="d-none animate-fade-in">
                      
                      <div class="text-center mb-4">
                        <span class="badge bg-soft-primary text-primary rounded-pill px-3 py-1 mb-2 text-uppercase font-10 fw-bold">
                          <%= category %>
                        </span>
                        <h3 class="fw-bold text-dark mt-2" style="font-size: 1.45rem; line-height: 1.4;">
                          <%= question_data[:text] %>
                        </h3>
                      </div>
                      
                      <%# Opciones tipo botones en lista vertical %>
                      <div class="d-flex flex-column gap-3 my-4">
                        <% question_data[:options].each_with_index do |(option_text, score), i| %>
                          <div class="rating-box w-100">
                            <%= f.radio_button :answers, score, 
                                name: "prospect_questionnaire[answers][#{key}]", 
                                id: "#{key}_#{i}", 
                                class: "btn-check",
                                data: { action: "change->questionnaire#autoNext" } %>
                            <label class="btn btn-outline-light border-2 text-start p-3 w-100 shadow-none d-flex align-items-center rounded-4 custom-option-label" 
                                   for="<%= key %>_<%= i %>">
                              <div class="custom-radio-circle me-3 flex-shrink-0"></div>
                              <span class="font-15 text-dark fw-medium" style="line-height: 1.3;"><%= option_text %></span>
                            </label>
                          </div>
                        <% end %>
                      </div>

                    </div>
                  <% end %>
                <% end %>

              </div>

              <%# NAVEGACIÓN DINÁMICA %>
              <div class="d-flex justify-content-between align-items-center mt-5 pt-3 border-top">
                <button type="button" class="btn btn-link text-primary fw-bold text-decoration-none d-none shadow-none" 
                        data-questionnaire-target="prevBtn" data-action="click->questionnaire#prev">
                  <i class="ri-arrow-left-s-line me-1"></i> Anterior
                </button>
                
                <%# "Siguiente" solo aparece en el Paso 0 %>
                <button type="button" class="btn btn-primary rounded-pill px-5 py-2 shadow-sm ms-auto" 
                        data-questionnaire-target="nextBtn" data-action="click->questionnaire#next">
                  Comenzar Evaluación <i class="ri-arrow-right-s-line ms-1"></i>
                </button>

                <%= f.submit "Descubrir Membresía", class: "btn btn-success rounded-pill px-5 py-2 shadow-sm d-none", 
                             data: { questionnaire_target: "submitBtn" } %>
              </div>
            <% end %>
          </div>
        </div>
        
        <div class="text-center mt-4">
          <p class="text-muted font-12">© <%= Time.now.year %> Consilium. Tu información es tratada de forma confidencial.</p>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* --- Estilos Opciones de Texto (Lista Vertical) --- */
  .custom-option-label {
    border-color: #e2e8f0 !important;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;
  }
  
  .custom-radio-circle {
    width: 20px;
    height: 20px;
    border: 2px solid #cbd5e1;
    border-radius: 50%;
    position: relative;
    transition: all 0.2s ease;
  }

  .rating-box:hover .custom-option-label:not(.btn-check:checked + .custom-option-label) {
    border-color: #6366f1 !important;
    background-color: rgba(99, 102, 241, 0.02);
  }
  
  .rating-box:hover .custom-radio-circle:not(.btn-check:checked + .custom-option-label .custom-radio-circle) {
    border-color: #6366f1;
  }

  .btn-check:checked + .custom-option-label {
    background-color: rgba(99, 102, 241, 0.05) !important;
    border-color: #6366f1 !important;
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.15) !important;
    transform: translateY(-2px);
  }

  .btn-check:checked + .custom-option-label .custom-radio-circle {
    border-color: #6366f1;
    background-color: #6366f1;
  }

  /* Punto central del círculo cuando está seleccionado */
  .btn-check:checked + .custom-option-label .custom-radio-circle::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 8px;
    height: 8px;
    background-color: white;
    border-radius: 50%;
  }

  .btn-check:checked + .custom-option-label span {
    color: #6366f1 !important;
    font-weight: 700 !important;
  }
  
  /* --- Círculos de Fondo con Animación Suave --- */
  .auth-fluid-circles { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 1; width: 100%; height: 100%; pointer-events: none; }
  .auth-fluid-circles [class^="circle-"] { 
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); 
    border-radius: 50%; background: radial-gradient(circle, rgba(99, 102, 241, 0.07) 0%, rgba(99, 102, 241, 0) 70%); 
    border: 1px solid rgba(99, 102, 241, 0.08); 
  }
  .circle-1 { width: 500px; height: 500px; } 
  .circle-2 { width: 850px; height: 850px; } 
  .circle-3 { width: 1200px; height: 1200px; }
  .circle-4 { width: 1550px; height: 1550px; }
  
  /* --- UI Helpers --- */
  .custom-gradient-progress { background: linear-gradient(90deg, #6366f1 0%, #a855f7 100%); }
  .custom-input { background-color: #f8fafc !important; border: 1px solid #e2e8f0 !important; border-radius: 12px !important; }
  .custom-input:focus { border-color: #6366f1 !important; box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1) !important; }
  
  .btn-soft-danger { background-color: rgba(250, 92, 124, 0.1); color: #fa5c7c; }
  .bg-soft-primary { background-color: rgba(99, 102, 241, 0.1); }
  
  .font-10 { font-size: 10px; } .font-11 { font-size: 11px; } .font-12 { font-size: 12px; }
  .animate-fade-in { animation: fadeIn 0.45s ease-out; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }
  
  /* Quitar el outline azul de los botones en Chrome */
  .btn:focus, .btn-check:focus + .btn, .btn-check:focus + label { box-shadow: none !important; outline: none !important; }
</style>