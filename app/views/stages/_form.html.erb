<%= form_with(model: [@client, @project, @stage], local: true) do |f| %>
    <% if @stage.errors.any? %>
        <div class="alert alert-danger">
            <%= @stage.errors.full_messages.first %>
        </div>
    <% end %>

    <div class="mb-3">
        <%= f.label :name, "Nombre de la Etapa", class: "form-label" %>
        <%= f.text_field :name, class: "form-control", placeholder: "Ej: Etapa 7 - Mantenimiento", required: true %>
    </div>

    <div class="d-flex justify-content-end">
        <%= link_to "Cancelar", client_project_path(@client, @project), class: "btn btn-light me-2" %>
        <%= f.submit "Guardar Etapa", class: "btn btn-primary" %>
    </div>
<% end %>