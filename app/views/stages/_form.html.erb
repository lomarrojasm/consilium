<%# app/views/stages/_form.html.erb %>
<%= form_with(model: [@client, @project, @stage], local: true) do |f| %>
  <% if @stage.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% @stage.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :name, "Nombre de la Etapa", class: "form-label" %>
    <%= f.text_field :name, class: "form-control", placeholder: "Ej. Fase de Diagnóstico", required: true %>
  </div>

  <% if current_user.role == 'admin' %>
    <div class="mb-3">
      <%= f.label :created_at, "Fecha de Inicio / Creación", class: "form-label text-primary fw-bold" %>
      <%= f.date_field :created_at, value: @stage.created_at&.to_date, class: "form-control border-primary" %>
      <div class="form-text italic">Solo tú como administrador puedes ajustar la fecha retroactivamente.</div>
    </div>
  <% end %>

  <div class="d-flex justify-content-end gap-2 mt-4">
    <%= link_to "Cancelar", client_project_path(@client, @project), class: "btn btn-light" %>
    <%= f.submit @stage.new_record? ? "Crear Etapa" : "Guardar Cambios", class: "btn btn-primary" %>
  </div>
<% end %>