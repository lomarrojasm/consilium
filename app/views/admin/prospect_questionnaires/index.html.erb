<%# --- LÓGICA DE SEPARACIÓN --- %>
<%# Separamos los leads detectando si tienen el estatus de autodiagnóstico o si sus respuestas tienen la llave 'a1' (propia de la gráfica) %>
<% 
  autodiagnosticos = @questionnaires.select { |q| q.status == 'Autodiagnóstico' || (q.answers && q.answers['a1'].present?) }
  diagnosticos_profundos = @questionnaires - autodiagnosticos
  nuevos_count = @questionnaires.count { |q| q.status == 'Nuevo' }
%>

<div class="row mb-2">
    <div class="col-12">
        <div class="page-title-box">
            <h4 class="page-title">Lead Dashboard: Inteligencia de Prospectos</h4>
        </div>
    </div>
</div>

<%# --- MÉTRICAS RÁPIDAS (KPIs) --- %>
<div class="row">
    <div class="col-md-3">
        <div class="card widget-flat bg-primary text-white shadow-sm border-0">
            <div class="card-body">
                <div class="float-end">
                    <i class="ri-group-line widget-icon bg-white text-primary"></i>
                </div>
                <h5 class="fw-normal mt-0" title="Total Leads">Total Prospectos</h5>
                <h3 class="mt-3 mb-3 text-white"><%= @questionnaires.count %></h3>
                <p class="mb-0 opacity-70 font-13">Acumulados en el sistema</p>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card widget-flat bg-success text-white shadow-sm border-0">
            <div class="card-body">
                <div class="float-end">
                    <i class="ri-radar-line widget-icon bg-white text-success"></i>
                </div>
                <h5 class="fw-normal mt-0">Autodiagnósticos</h5>
                <h3 class="mt-3 mb-3 text-white"><%= autodiagnosticos.count %></h3>
                <p class="mb-0 opacity-70 font-13">Evaluaciones cuantitativas</p>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card widget-flat bg-info text-white shadow-sm border-0">
            <div class="card-body">
                <div class="float-end">
                    <i class="ri-file-list-3-line widget-icon bg-white text-info"></i>
                </div>
                <h5 class="fw-normal mt-0">Contexto Directivo</h5>
                <h3 class="mt-3 mb-3 text-white"><%= diagnosticos_profundos.count %></h3>
                <p class="mb-0 opacity-70 font-13">Formularios narrativos</p>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card widget-flat bg-danger text-white shadow-sm border-0">
            <div class="card-body">
                <div class="float-end">
                    <i class="ri-flashlight-line widget-icon bg-white text-danger"></i>
                </div>
                <h5 class="fw-normal mt-0">Nuevos / Sin Atender</h5>
                <h3 class="mt-3 mb-3 text-white"><%= nuevos_count %></h3>
                <p class="mb-0 opacity-70 font-13">Requieren acción inmediata</p>
            </div>
        </div>
    </div>
</div>

<%# --- SISTEMA DE PESTAÑAS Y TABLAS --- %>
<div class="row">
    <div class="col-12">
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                
                <%# Navegación de Pestañas %>
                <ul class="nav nav-tabs nav-bordered px-3 pt-3" role="tablist">
                    <li class="nav-item">
                        <a href="#tab-autodiagnosticos" data-bs-toggle="tab" aria-expanded="true" class="nav-link active fw-bold">
                            <i class="ri-pie-chart-2-line me-1 text-success"></i> Autodiagnósticos
                            <span class="badge bg-success ms-1"><%= autodiagnosticos.count %></span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="#tab-profundos" data-bs-toggle="tab" aria-expanded="false" class="nav-link fw-bold">
                            <i class="ri-file-text-line me-1 text-info"></i> Contexto del Negocio
                            <span class="badge bg-info ms-1"><%= diagnosticos_profundos.count %></span>
                        </a>
                    </li>
                </ul>

                <%# Contenido de Pestañas %>
                <div class="tab-content p-4">
                    
                    <%# PESTAÑA 1: AUTODIAGNÓSTICOS (Con Gráfica) %>
                    <div class="tab-pane show active" id="tab-autodiagnosticos">
                        <table class="table table-centered table-hover dt-responsive nowrap w-100" id="leads-auto-table">
                            <thead class="table-light">
                                <tr>
                                    <th>Empresa</th>
                                    <th>Contacto</th>
                                    <th>Fecha</th>
                                    <th>Estatus</th>
                                    <th class="text-center">Notas</th>
                                    <th class="text-end">Acción</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% autodiagnosticos.each do |lead| %>
                                    <%= render 'lead_row', lead: lead %>
                                <% end %>
                            </tbody>
                        </table>
                    </div>

                    <%# PESTAÑA 2: DIAGNÓSTICOS PROFUNDOS %>
                    <div class="tab-pane" id="tab-profundos">
                        <table class="table table-centered table-hover dt-responsive nowrap w-100" id="leads-profundos-table">
                            <thead class="table-light">
                                <tr>
                                    <th>Empresa</th>
                                    <th>Contacto</th>
                                    <th>Fecha</th>
                                    <th>Estatus</th>
                                    <th class="text-center">Notas</th>
                                    <th class="text-end">Acción</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% diagnosticos_profundos.each do |lead| %>
                                    <%= render 'lead_row', lead: lead %>
                                <% end %>
                            </tbody>
                        </table>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>