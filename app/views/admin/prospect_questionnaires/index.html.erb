<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <h4 class="page-title">Lead Dashboard: Diagnósticos de Contexto</h4>
        </div>
    </div>
</div>

<%# --- METRICAS RAPIDAS --- %>
<div class="row">
    <div class="col-md-3">
        <div class="card widget-flat bg-primary text-white">
            <div class="card-body">
                <div class="float-end">
                    <i class="ri-survey-line widget-icon bg-white text-primary"></i>
                </div>
                <h5 class="fw-normal mt-0" title="Total Leads">Total Diagnósticos</h5>
                <h3 class="mt-3 mb-3 text-white"><%= @questionnaires.count %></h3>
                <p class="mb-0 opacity-70">Acumulados en el sistema</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card widget-flat bg-info text-white">
            <div class="card-body">
                <div class="float-end">
                    <i class="ri-flashlight-line widget-icon bg-white text-info"></i>
                </div>
                <h5 class="fw-normal mt-0">Nuevos (Sin leer)</h5>
                <h3 class="mt-3 mb-3 text-white"><%= @questionnaires.where(status: 'Nuevo').count %></h3>
                <p class="mb-0 opacity-70">Requieren tu atención hoy</p>
            </div>
        </div>
    </div>
</div>

<%# --- TABLA DE LEADS --- %>
<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-body">
                <table class="table table-centered table-hover dt-responsive nowrap w-100" id="leads-table">
                    <thead>
                        <tr>
                            <th>Empresa</th>
                            <th>Contacto</th>
                            <th>Fecha</th>
                            <th>Estatus</th>
                            <th class="text-center">Notas</th>
                            <th>Acción</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% @questionnaires.each do |lead| %>
                            <tr>
                                <td>
                                    <span class="fw-bold"><%= lead.company_name %></span><br>
                                    <small class="text-muted"><%= lead.website %></small>
                                </td>
                                <td>
                                    <%= lead.name %><br>
                                    <small><%= lead.position %></small>
                                </td>
                                <td><%= lead.created_at.strftime("%d/%m/%Y") %></td>
                                <td>
                                    <% badge_class = case lead.status 
                                        when 'Nuevo' then 'bg-danger'
                                        when 'En Análisis' then 'bg-warning'
                                        when 'Contactado' then 'bg-info'
                                        when 'Convertido' then 'bg-success'
                                        else 'bg-secondary' end %>
                                    <span class="badge <%= badge_class %>"><%= lead.status %></span>
                                </td>
                                <td class="text-center">
                                    <% if lead.notes.present? %>
                                        <i class="ri-chat-check-line text-success font-18" title="Tiene notas"></i>
                                    <% else %>
                                        <i class="ri-chat-new-line text-muted font-18" title="Sin notas"></i>
                                    <% end %>
                                </td>
                                <td>
                                    <%= link_to admin_prospect_questionnaire_path(lead), class: "btn btn-sm btn-soft-primary" do %>
                                        Analizar <i class="ri-arrow-right-line ms-1"></i>
                                    <% end %>
                                </td>
                            </tr>
                        <% end %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>