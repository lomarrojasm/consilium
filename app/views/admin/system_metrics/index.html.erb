<div class="container-fluid">
  <div class="row">
    <div class="col-12">
      <div class="page-title-box">
        <h4 class="page-title">Monitor de Sistema y Procesos</h4>
      </div>
    </div>
  </div>

  <div class="row mb-4">
    <div class="col-md-4">
      <div class="card shadow-none border">
        <div class="card-body">
          <h5 class="card-title font-14">Uso de CPU</h5>
          <div data-netdata="system.cpu" data-chart-library="gauge" data-height="150" data-after="-300"></div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card shadow-none border">
        <div class="card-body">
          <h5 class="card-title font-14">Uso de RAM</h5>
          <div data-netdata="system.ram" data-chart-library="gauge" data-height="150" data-after="-300"></div>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card shadow-none border">
        <div class="card-body">
          <h5 class="card-title font-14">Espacio en Disco</h5>
          <div data-netdata="disk_space./" data-chart-library="gauge" data-height="150" data-after="-300"></div>
        </div>
      </div>
    </div>
  </div>

  <div data-controller="system-workers">
    <div class="row mb-3">
      <div class="col-12">
        <div class="card shadow-none border">
          <div class="card-body py-3">
            <div class="row align-items-center text-center">
              <div class="col-md-3 border-end">
                <p class="text-muted mb-1 font-13">Estado de Workers</p>
                <span data-system-workers-target="status" class="badge bg-secondary">CARGANDO...</span>
              </div>
              <div class="col-md-3 border-end">
                <h4 class="mb-0 fw-bold" data-system-workers-target="active">0</h4>
                <p class="text-muted mb-0 font-12">Procesos Activos</p>
              </div>
              <div class="col-md-3 border-end">
                <h4 class="mb-0 fw-bold" data-system-workers-target="pending">0</h4>
                <p class="text-muted mb-0 font-12">Tareas Pendientes</p>
              </div>
              <div class="col-md-3">
                <h4 class="mb-0 fw-bold text-danger" data-system-workers-target="failed">0</h4>
                <p class="text-muted mb-0 font-12">Tareas Fallidas</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="row mb-4">
      <div class="col-12 text-end mb-2">
        <div class="btn-group shadow-sm">
          <button data-action="click->system-workers#retryAll" class="btn btn-sm btn-outline-primary">
            <i class="ri-restart-line me-1"></i> Reintentar Todo
          </button>
          <button data-action="click->system-workers#discardAll" class="btn btn-sm btn-outline-secondary">
            <i class="ri-delete-bin-line me-1"></i> Limpiar Historial
          </button>
        </div>
      </div>

      <div class="col-md-6">
        <div class="card shadow-none border h-100">
          <div class="card-header bg-soft-danger py-2 d-flex justify-content-between align-items-center">
            <h6 class="mb-0 text-danger font-13">Últimas Fallidas</h6>
          </div>
          <div class="card-body p-0">
            <table class="table table-sm mb-0">
              <tbody data-system-workers-target="failedList">
                </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="col-md-6">
        <div class="card shadow-none border h-100">
          <div class="card-header bg-soft-info py-2 d-flex justify-content-between align-items-center">
            <h6 class="mb-0 text-info font-13">Próximas Pendientes</h6>
          </div>
          <div class="card-body p-0">
            <table class="table table-sm mb-0">
              <tbody data-system-workers-target="pendingList">
                </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="row" data-controller="system-logs">
    <div class="col-12">
      <div class="card shadow-none border">
        <div class="card-header bg-light d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-2">
          <h5 class="card-title mb-0 font-14"><i class="ri-terminal-box-line me-1"></i> Registros de la Aplicación</h5>
          <div class="d-flex flex-wrap gap-2">
            <div class="input-group input-group-sm" style="width: 200px;">
              <span class="input-group-text bg-white border-end-0"><i class="ri-search-line"></i></span>
              <input type="text" class="form-control border-start-0" placeholder="Buscar..." 
                     data-action="input->system-logs#handleSearch" data-system-logs-target="search">
            </div>
            <button data-action="click->system-logs#toggleFilter" data-system-logs-target="filterBtn" class="btn btn-sm btn-outline-warning">
              <i class="ri-error-warning-line"></i> Errores
            </button>
            <button data-action="click->system-logs#togglePause" data-system-logs-target="pauseBtn" class="btn btn-sm btn-outline-danger">
              <i class="ri-pause-line"></i> Pausar
            </button>
            <button data-action="click->system-logs#fetchLogs" class="btn btn-sm btn-light border"><i class="ri-refresh-line"></i></button>
          </div>
        </div>
        <div class="card-body p-0">
          <pre data-system-logs-target="container" 
               style="height: 400px; overflow-y: auto; background-color: #1a1a1a; color: #eaeaea; padding: 15px; font-family: 'Monaco', monospace; font-size: 11px; margin-bottom: 0; white-space: pre-wrap;"></pre>
        </div>
      </div>
    </div>
  </div>
</div>