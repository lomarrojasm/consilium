<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item"><%= link_to "Clientes", clients_path %></li>
                    <li class="breadcrumb-item"><%= link_to @user.client.company_name, client_path(@user.client) %></li>
                    <li class="breadcrumb-item active">Perfil de Usuario</li>
                </ol>
            </div>
            <h4 class="page-title">Perfil de <%= @user.first_name %></h4>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-xl-4 col-lg-5">
        <div class="card text-center">
            <div class="card-body">
                
                <% if defined?(@user.avatar) && @user.avatar.attached? %>
                    <%= image_tag url_for(@user.avatar), class: "rounded-circle avatar-lg img-thumbnail", alt: "profile-image" %>
                <% else %>
                    <div class="avatar-lg mx-auto">
                        <span class="avatar-title rounded-circle bg-primary-light text-primary font-24">
                            <%= @user.first_name[0] %><%= @user.last_name[0] %>
                        </span>
                    </div>
                <% end %>

                <h4 class="mb-0 mt-2"><%= @user.first_name %> <%= @user.last_name %></h4>
                <p class="text-muted font-14"><%= @user.job_title || "Sin puesto definido" %></p>

                <%= link_to edit_user_path(@user), class: "btn btn-success btn-sm mb-2" do %>
                    <i class="mdi mdi-square-edit-outline me-1"></i> Editar
                <% end %>
                <%= button_to user_path(@user), 
                    method: :delete, 
                    form: { data: { turbo_confirm: "¿Estás seguro de que deseas eliminar a #{@user.full_name}?" } }, 
                    class: "btn btn-soft-danger btn-sm", 
                    data: { bs_toggle: "tooltip", bs_placement: "top" }, 
                    title: "Eliminar Usuario" do %>
                    <i class="ri-delete-bin-line"></i>
                <% end %>

                <div class="text-start mt-3">
                    <h4 class="font-13 text-uppercase">Sobre el usuario:</h4>
                    
                    <p class="text-muted mb-2 font-13"><strong>Nombre Completo :</strong> 
                        <span class="ms-2"><%= @user.first_name %> <%= @user.last_name %></span>
                    </p>

                    <p class="text-muted mb-2 font-13"><strong>Teléfono :</strong>
                    </p>

                    <p class="text-muted mb-2 font-13"><strong>Email :</strong> 
                        <span class="ms-2"><%= @user.email %></span>
                    </p>

                    <p class="text-muted mb-1 font-13"><strong>Empresa / Cliente :</strong> 
                        <span class="ms-2"><%= @user.client.company_name %></span>
                    </p>
                </div>

                <ul class="social-list list-inline mt-3 mb-0">
                    <li class="list-inline-item">
                        <a href="mailto:<%= @user.email %>" class="social-list-item border-primary text-primary"><i class="mdi mdi-email"></i></a>
                    </li>
                </ul>
            </div> </div> <div class="card">
            <div class="card-body">
                <h4 class="header-title mb-3">Estado de la Cuenta</h4>
                
                <div class="d-flex align-items-center mb-3">
                    <div class="flex-shrink-0">
                         <i class="mdi mdi-shield-account font-24 text-info"></i>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="mt-0 mb-1 font-14">Rol de Acceso</h6>
                        <p class="text-muted mb-0"><span class="badge bg-info"><%= @user.role.humanize %></span></p>
                    </div>
                </div>

                <div class="d-flex align-items-center mb-3">
                    <div class="flex-shrink-0">
                         <i class="mdi mdi-account-check font-24 text-success"></i>
                    </div>
                    <div class="flex-grow-1 ms-3">
                        <h6 class="mt-0 mb-1 font-14">Estado Activo</h6>
                        <p class="text-muted mb-0">
                            <% if @user.active %>
                                <span class="badge bg-success">Activo</span>
                            <% else %>
                                <span class="badge bg-danger">Inactivo</span>
                            <% end %>
                        </p>
                    </div>
                </div>

            </div>
        </div>
    </div> <div class="col-xl-8 col-lg-7">
        <div class="card">
            <div class="card-body">
                <h4 class="header-title mb-3">Detalles de Invitación y Acceso</h4>

                <div class="table-responsive">
                    <table class="table table-hover table-centered mb-0">
                        <tbody>
                            <tr>
                                <th style="width: 30%;">Estado de Invitación:</th>
                                <td>
                                    <% if @user.invitation_accepted_at %>
                                        <span class="badge bg-success">Aceptada</span> 
                                        <small class="text-muted ms-2">el <%= l(@user.invitation_accepted_at, format: :long) %></small>
                                    <% elsif @user.invitation_sent_at %>
                                        <span class="badge bg-warning">Pendiente</span>
                                        <small class="text-muted ms-2">Enviada el <%= l(@user.invitation_sent_at, format: :long) %></small>
                                        
                                        <div class="mt-2">
                                            <%= button_to resend_invitation_user_path(@user), 
                                                method: :post, 
                                                class: "btn btn-soft-info btn-sm", 
                                                data: { bs_toggle: "tooltip", bs_placement: "top" }, 
                                                title: "Reenviar Invitación" do %>
                                                <i class="ri-mail-send-line"></i>
                                            <% end %>
                                        </div>
                                    <% else %>
                                        <span class="badge bg-secondary">Registro Manual</span>
                                    <% end %>
                                </td>
                            </tr>
                            <tr>
                                <th>Enviado por:</th>
                                <td>
                                    <% if @user.invited_by %>
                                        <%= @user.invited_by.email %>
                                    <% else %>
                                        Sistema / Desconocido
                                    <% end %>
                                </td>
                            </tr>
                            <tr>
                                <th>Último inicio de sesión:</th>
                                <td>
                                    <% if @user.last_sign_in_at %>
                                        <%= l(@user.last_sign_in_at, format: :long) %>
                                    <% else %>
                                        <span class="text-muted">Nunca ha iniciado sesión</span>
                                    <% end %>
                                </td>
                            </tr>
                            <tr>
                                <th>IP Último acceso:</th>
                                <td><%= @user.last_sign_in_ip || "N/A" %></td>
                            </tr>
                            <tr>
                                <th>Contador de accesos:</th>
                                <td><%= @user.sign_in_count %> veces</td>
                            </tr>
                            <tr>
                                <th>Usuario creado el:</th>
                                <td><%= l(@user.created_at, format: :long) %></td>
                            </tr>
                        </tbody>
                    </table>
                </div> </div> </div> <div class="card">
            <div class="card-body">
                <h4 class="header-title mb-3">Actividad Reciente</h4>
                <p class="text-muted">Aquí podrás agregar logs de lo que ha hecho este usuario en el sistema más adelante.</p>
                <div class="alert alert-light bg-light text-dark border-0" role="alert">
                    <i class="mdi mdi-information-outline me-2"></i> 
                    Funcionalidad en desarrollo.
                </div>
            </div>
        </div>

    </div> </div>