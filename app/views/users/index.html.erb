<div class="container-fluid">
  <%# --- HEADER --- %>
  <div class="row">
    <div class="col-12">
      <div class="page-title-box">
        <div class="page-title-right">
          <button type="button" class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#inviteUserModal">
            <i class="ri-user-add-line me-1"></i> Invitar Miembro
          </button>
        </div>
        <h4 class="page-title">Administración de Usuarios</h4>
      </div>
    </div>
  </div>

  <%# --- WIDGETS DE ESTADO --- %>
  <div class="row">
    <div class="col-md-6 col-xl-3">
      <div class="card shadow-sm">
        <div class="card-body">
          <div class="row align-items-center">
            <div class="col-6">
              <h5 class="text-muted fw-normal mt-0">Total Equipo</h5>
              <h3 class="my-2 py-1"><%= @users.count %></h3>
            </div>
            <div class="col-6 text-end">
              <div class="avatar-sm bg-primary-lighten rounded">
                <i class="ri-group-line font-24 avatar-title text-primary"></i>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="col-md-6 col-xl-3">
      <div class="card shadow-sm">
        <div class="card-body">
          <div class="row align-items-center">
            <div class="col-6">
              <h5 class="text-muted fw-normal mt-0">Confirmados</h5>
              <h3 class="my-2 py-1 text-success"><%= @users.where.not(invitation_accepted_at: nil).count %></h3>
            </div>
            <div class="col-6 text-end">
              <div class="avatar-sm bg-success-lighten rounded">
                <i class="ri-user-check-line font-24 avatar-title text-success"></i>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# --- TABLA DE USUARIOS --- %>
  <div class="row">
    <div class="col-12">
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <div class="table-responsive">
            <table class="table table-centered table-hover dt-responsive nowrap w-100">
              <thead class="table-light">
                <tr>
                  <th>Usuario</th>
                  <th>Puesto</th>
                  <th>Rol Sistema</th>
                  <th>Empresa Asignada</th>
                  <th>Estado</th>
                  <th class="text-end">Acciones</th>
                </tr>
              </thead>
              <tbody>
                <% @users.each do |user| %>
                  <tr>
                    <td class="table-user">
                      <div class="d-flex align-items-center">
                        <% if user.avatar.attached? %>
                          <%= image_tag user.avatar, class: "me-2 rounded-circle border shadow-sm", style: "height: 38px; width: 38px; object-fit: cover;" %>
                        <% else %>
                          <div class="avatar-xs d-inline-block me-2">
                            <span class="avatar-title bg-soft-primary text-primary rounded-circle fw-bold">
                              <%= user.first_name[0] %><%= user.last_name[0] %>
                            </span>
                          </div>
                        <% end %>
                        <div>
                          <%= link_to user_path(user), class: "text-body fw-bold d-block" do %>
                            <%= user.first_name %> <%= user.last_name %>
                          <% end %>
                          <small class="text-muted"><%= user.email %></small>
                        </div>
                      </div>
                    </td>
                    <td><span class="fw-medium text-muted"><%= user.job_title %></span></td>
                    <td>
                      <span class="badge badge-outline-<%= user.role == 'admin' ? 'danger' : 'primary' %> px-2 py-1">
                        <%= user.role&.upcase %>
                      </span>
                    </td>
                    <td>
                      <i class="ri-building-line me-1 text-muted"></i>
                      <%= user.client&.company_name || content_tag(:span, "Equipo Consilium", class: "text-muted small") %>
                    </td>
                    <td>
                      <span class="badge bg-<%= user.invitation_accepted_at ? 'success' : 'warning' %>-lighten text-<%= user.invitation_accepted_at ? 'success' : 'warning' %>">
                        <%= user.invitation_accepted_at ? 'Activo' : 'Invitación Pendiente' %>
                      </span>
                    </td>
                    <td class="text-end">
                      <div class="dropdown">
                        <a href="#" class="dropdown-toggle arrow-none card-drop" data-bs-toggle="dropdown"><i class="ri-more-2-fill"></i></a>
                        <div class="dropdown-menu dropdown-menu-end shadow border-0">
                          <%= link_to user_path(user), class: "dropdown-item" do %><i class="ri-eye-line me-1 text-muted"></i> Ver Perfil<% end %>
                          <%= link_to edit_user_path(user), class: "dropdown-item" do %><i class="ri-edit-line me-1 text-muted"></i> Editar<% end %>
                          
                          <% unless user.invitation_accepted_at %>
                            <div class="dropdown-divider"></div>
                            <%= button_to resend_invitation_user_path(user), method: :post, class: "dropdown-item text-info" do %>
                              <i class="ri-mail-send-line me-1"></i> Reenviar Mail
                            <% end %>
                          <% end %>

                          <div class="dropdown-divider"></div>
                          <%= button_to user_path(user), method: :delete, 
                              form: { data: { turbo_confirm: "¿Eliminar definitivamente a #{user.first_name}?" } }, 
                              class: "dropdown-item text-danger" do %>
                            <i class="ri-delete-bin-line me-1"></i> Eliminar
                          <% end %>
                        </div>
                      </div>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%# --- MODAL DE INVITACIÓN (SISTEMA) --- %>
<div class="modal fade" id="inviteUserModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content shadow-lg border-0">
      <div class="modal-header bg-primary p-3 text-white">
        <h5 class="modal-title"><i class="ri-user-add-line me-1"></i> Nueva Invitación de Sistema</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <%= form_for(User.new, url: user_invitation_path, html: { method: :post, class: "p-3" }) do |f| %>
        <div class="modal-body p-0">
          <div class="row g-2 mb-3">
            <div class="col-md-6">
              <label class="form-label font-13 fw-bold">Nombre</label>
              <%= f.text_field :first_name, class: "form-control", required: true %>
            </div>
            <div class="col-md-6">
              <label class="form-label font-13 fw-bold">Apellido</label>
              <%= f.text_field :last_name, class: "form-control", required: true %>
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label font-13 fw-bold">Correo Electrónico</label>
            <%= f.email_field :email, class: "form-control", placeholder: "ejemplo@consilium.com", required: true %>
          </div>

          <div class="row g-2 mb-3">
            <div class="col-md-6">
              <label class="form-label font-13 fw-bold">Rol de Acceso Global</label>
              <%# REGLA APLICADA: Solo Admin o Usuario %>
              <%= f.select :role, [
                  ['Administrador (Control Total)', 'admin'], 
                  ['Usuario (Acceso Estándar)', 'user']
                ], {}, class: "form-select" %>
            </div>
            <div class="col-md-6">
              <label class="form-label font-13 fw-bold">Asignar a Cliente</label>
              <%= f.collection_select :client_id, Client.all, :id, :company_name, { include_blank: "Staff Consilium (Sin cliente)" }, { class: "form-select" } %>
            </div>
          </div>

          <div class="mb-0">
            <label class="form-label font-13 fw-bold">Puesto o Cargo</label>
            <%= f.text_field :job_title, class: "form-control", placeholder: "Ej. Especialista de Calidad" %>
          </div>
        </div>
        <div class="modal-footer px-0 pb-0 pt-3">
          <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cerrar</button>
          <%= f.submit "Enviar Invitación", class: "btn btn-primary px-4" %>
        </div>
      <% end %>
    </div>
  </div>
</div>