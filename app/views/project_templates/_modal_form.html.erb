<%# app/views/project_templates/_modal_form.html.erb %>
<div class="modal fade" id="<%= project_template.new_record? ? 'newTemplateModal' : "editTemplateModal_#{project_template.id}" %>" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content shadow-sm border-0" style="border-radius: 12px;">
      
      <div class="modal-header bg-light p-3 border-bottom border-2 border-primary border-opacity-25">
        <h5 class="modal-title text-dark fw-bold">
          <i class="ri-git-repository-line me-1 text-primary"></i> 
          <%= project_template.new_record? ? "Nueva Metodología Base" : "Editar Metodología" %>
        </h5>
        <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
      </div>

      <%= form_with(model: project_template, local: true, multipart: true, class: "p-3") do |f| %>
        <div class="modal-body p-0 text-start">
          
          <div class="mb-3">
            <label class="form-label font-12 fw-bold text-muted text-uppercase tracking-wider">Nombre de la Generación / Plantilla</label>
            <%= f.text_field :name, class: "form-control font-13 fw-bold shadow-none", placeholder: "Ej: Metodología 2027 - Especial", required: true %>
          </div>

          <div class="mb-3">
            <label class="form-label font-12 fw-bold text-muted text-uppercase tracking-wider">Descripción Interna (Opcional)</label>
            <%= f.text_area :description, class: "form-control font-13 shadow-none", rows: 2, placeholder: "Describe el propósito de esta versión..." %>
          </div>

          <%# --- SELECTOR DE CLONACIÓN / IMPORTACIÓN (Solo para nuevas plantillas) --- %>
          <% if project_template.new_record? %>
            <div class="bg-light p-3 rounded-3 mt-4 border border-light">
              <label class="form-label font-12 fw-bold text-primary text-uppercase tracking-wider mb-2">
                <i class="ri-settings-3-line me-1"></i> Origen de Datos
              </label>
              <p class="text-muted font-11 mb-3">Elige <strong>solo una</strong> de las siguientes opciones. Si dejas ambas vacías, se creará un lienzo en blanco.</p>

              <%# OPCIÓN 1: EXCEL %>
              <div class="mb-3 p-2 border border-success border-opacity-25 rounded bg-white">
                <label class="form-label fw-bold font-12 text-success"><i class="ri-file-excel-2-line me-1"></i> 1. Importar desde Excel</label>
                <%# Usamos _tag porque :excel_file va directo al controlador en params[:excel_file], no a la base de datos %>
                <%= file_field_tag :excel_file, class: "form-control form-control-sm font-12 shadow-none", accept: ".xlsx, .xls" %>
                <div class="form-text font-10">El archivo debe contener las columnas en el orden exacto.</div>
              </div>
              
              <%# OPCIÓN 2: CLONAR %>
              <% if ProjectTemplate.any? %>
                <div class="p-2 border border-primary border-opacity-25 rounded bg-white">
                  <label class="form-label fw-bold font-12 text-primary"><i class="ri-file-copy-2-line me-1"></i> 2. Clonar Plantilla Existente</label>
                  <%= select_tag :base_template_id, 
                        options_from_collection_for_select(ProjectTemplate.order(created_at: :desc), :id, :name), 
                        include_blank: "Selecciona una plantilla base...", 
                        class: "form-select form-select-sm font-12 shadow-none" %>
                  <div class="form-text font-10">Ignora esta opción si subiste un Excel.</div>
                </div>
              <% end %>
            </div>
          <% end %>

        </div>

        <div class="modal-footer px-0 pb-0 pt-4 border-0">
          <button type="button" class="btn btn-light px-4 rounded-pill" data-bs-dismiss="modal">Cancelar</button>
          <%= f.submit project_template.new_record? ? "Crear Plantilla" : "Guardar Cambios", class: "btn btn-primary px-4 shadow-sm rounded-pill" %>
        </div>
      <% end %>
    </div>
  </div>
</div>