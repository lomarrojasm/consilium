<%# app/views/project_templates/_form.html.erb %>
<%= form_with(model: project_template, local: true) do |f| %>
  
  <% if project_template.errors.any? %>
    <div class="alert alert-danger border-0 mb-4 shadow-sm">
      <ul class="mb-0">
        <% project_template.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-floating mb-3">
    <%= f.text_field :name, class: "form-control shadow-none", placeholder: "Ej: Generación 2027", required: true %>
    <label>Nombre de la Metodología / Generación</label>
  </div>

  <div class="form-floating mb-4">
    <%= f.text_area :description, class: "form-control shadow-none", style: "height: 100px", placeholder: "Opcional" %>
    <label>Descripción interna (Opcional)</label>
  </div>

  <div class="d-flex justify-content-between border-top pt-3">
    <%= link_to "Cancelar", project_templates_path, class: "btn btn-light" %>
    <%= f.submit project_template.new_record? ? "Crear Plantilla" : "Actualizar Plantilla", class: "btn btn-primary shadow" %>
  </div>
<% end %>