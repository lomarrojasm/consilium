    <h2>Nueva Plantilla Base</h2>
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Plantillas", project_templates_path %></li>
      <li class="breadcrumb-item active"><strong>Nueva</strong></li>
    </ol>
  </div>
</div>

<div class="wrapper wrapper-content animated fadeInRight">
  <div class="row">
    <div class="col-lg-8">
      <div class="ibox">
        <div class="ibox-title">
          <h5>Detalles de la nueva metodología</h5>
        </div>
        <div class="ibox-content p-4">
          <%= render 'form', project_template: @project_template %>
        </div>
      </div>
    </div>
  </div>
</div>