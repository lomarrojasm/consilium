<div class="row">
    <% if current_user.role == "admin" %>
        <div class="col-12">
            <div class="page-title-box">
                <div class="page-title-right">
                    <ol class="breadcrumb m-0">
                        <li class="breadcrumb-item"><a href="<%= root_path %>">Consilium</a></li>
                        <li class="breadcrumb-item"><a href="<%= clients_path %>">Clientes</a></li> 
                        <li class="breadcrumb-item"><a href="<%= client_path(@client) %>"><%= @client.company_name %></a></li>                  

                    </ol>
                </div>
                <h4 class="page-title">Proyecto</h4>
            </div>
        </div>
    <% else %>
        <div class="col-12">
            <div class="page-title-box">
                <div class="page-title-right">
                    <ol class="breadcrumb m-0">
                        <li class="breadcrumb-item"><a href="<%= client_dashboard_path %>">Consilium</a></li>
                        <li class="breadcrumb-item"><a href="<%= client_path(@client) %>">Ver Perfil de Empresa</a></li>                  
                    </ol>
                </div>
                <h4 class="page-title">Bienvenido al portal de seguimiento de proyectos.</h4>
            </div>
        </div>

    <% end %>
</div>

<div class="container-fluid py-4">
  
  <div class="row mb-4">
    <div class="col-12">
      <div class="card bg-primary text-white shadow-sm">
        <div class="card-body p-4">
          <h2 class="fw-bold text-white">
            <%= @client ? @client.company_name : "Panel de Administración" %>
            </h2>
          <p class="mb-0 text-white-50">Bienvenido al portal de seguimiento de proyectos.</p>
        </div>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-lg-8">
      <div class="card shadow-sm h-100">
        <div class="card-header bg-white">
          <h5 class="mb-0">Cronograma de Proyectos</h5>
        </div>
        <div class="card-body">
          <% if @projects.any? %>
            <div class="table-responsive">
              <table class="table table-borderless align-middle">
                <thead>
                  <tr class="text-muted small text-uppercase">
                    <th style="width: 30%">Proyecto</th>
                    <th style="width: 50%">Línea de Tiempo / Avance</th>
                    <th style="width: 20%" class="text-end">Estado</th>
                  </tr>
                </thead>
                <tbody>
                  <% @projects.each do |proj| %>
                    <tr class="border-bottom">
                      <td>
                        <h6 class="mb-1 text-dark fw-bold"><%= proj.name %></h6>
                        <small class="text-muted">
                          <i class="mdi mdi-calendar"></i> 
                          <%= proj.start_date.strftime("%d %b") %> - <%= proj.end_date.strftime("%d %b") %>
                        </small>
                      </td>
                      <td>
                        <div class="d-flex justify-content-between font-12 mb-1">
                          <span>Progreso</span>
                          <span class="fw-bold"><%= proj.progress_percentage %>%</span>
                        </div>
                        <div class="progress" style="height: 10px; border-radius: 10px;">
                          <div class="progress-bar bg-<%= proj.progress_percentage == 100 ? 'success' : 'primary' %>" 
                               role="progressbar" 
                               style="width: <%= proj.progress_percentage %>%;">
                          </div>
                        </div>
                      </td>
                      <td class="text-end">
                        <span class="badge bg-light text-dark border">
                          <%= (proj.status || "sin estado").capitalize %>
                        </span>
                        <%= link_to "Ver Detalles", client_project_path(@client, proj), class: "btn btn-sm btn-link text-decoration-none" %>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="text-center py-5">
              <p class="text-muted">No hay proyectos activos asignados a tu empresa.</p>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="col-lg-4">

        <div class="row g-2">
        <div class="col-6">
          <div class="card bg-light border-0">
            <div class="card-body text-center">
              <h3 class="fw-bold mb-0 text-primary"><%= @projects.length %></h3>
              <small class="text-muted">Total Proyectos</small>
            </div>
          </div>
        </div>
        <div class="col-6">
          <div class="card bg-light border-0">
            <div class="card-body text-center">
              <h3 class="fw-bold mb-0 text-success">
                <%= @projects.select { |p| p.progress_percentage == 100 }.count %>
              </h3>
              <small class="text-muted">Completados</small>
            </div>
          </div>
        </div>
      </div>



      <div class="card shadow-sm mb-4">
        <div class="card-header bg-white">
          <h5 class="mb-0">Resumen General</h5>
        </div>
        <div class="card-body">
          <canvas id="progressChart" height="250"></canvas>
        </div>
      </div>


      <div class="card shadow-sm mb-4">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Mis Conversaciones</h5>
            <button class="btn btn-sm btn-soft-primary" type="button" data-bs-toggle="collapse" data-bs-target="#newChatCollapse">
            <i class="mdi mdi-plus"></i> Nuevo
            </button>
        </div>

        <div class="list-group list-group-flush">
            <% if @conversations.any? %>
            <% @conversations.each do |conversation| %>
                <% 
                # Lógica para saber quién es la "otra persona"
                other_user = (conversation.sender_id == current_user.id) ? conversation.recipient : conversation.sender 
                %>
                
                <%= link_to client_conversation_messages_path(@client, conversation), class: "list-group-item list-group-item-action d-flex align-items-center px-3 py-2" do %>
                
                <div class="avatar-xs me-2">
                    <span class="avatar-title rounded-circle bg-light text-primary font-12">
                    <%= other_user.first_name.first.upcase %><%= other_user.last_name.first.upcase %>
                    </span>
                </div>

                <div class="flex-grow-1 overflow-hidden">
                    <h6 class="mb-0 font-14"><%= other_user.first_name %> <%= other_user.last_name %></h6>
                    <p class="mb-0 text-muted font-11 text-truncate">
                    <% if conversation.messages.any? %>
                        <%= conversation.messages.last.body %>
                    <% else %>
                        <span class="fst-italic">Iniciar conversación...</span>
                    <% end %>
                    </p>
                </div>
                
                <small class="text-muted font-10">
                    <% if conversation.messages.any? %>
                    <%= time_ago_in_words(conversation.messages.last.created_at) %>
                    <% end %>
                </small>
                <% end %>
            <% end %>
            <% else %>
            <div class="text-center p-3">
                <p class="text-muted mb-0 small">No tienes conversaciones activas.</p>
            </div>
            <% end %>
        </div>

        <div class="collapse bg-light border-top" id="newChatCollapse">
            <div class="card-body">
                <h6 class="font-11 text-muted text-uppercase mb-2">Iniciar chat con:</h6>
                <div class="d-flex flex-wrap gap-2">
                    <% @client.users.where.not(id: current_user.id).each do |user| %>
                        <%= button_to client_conversations_path(@client), 
                            params: { recipient_id: user.id }, 
                            class: "btn btn-xs btn-white border shadow-sm" do %>
                            <i class="mdi mdi-chat-outline text-success me-1"></i> <%= user.first_name %>
                        <% end %>
                    <% end %>
                    
                    <% if @client.users.where.not(id: current_user.id).empty? %>
                    <small class="text-muted fst-italic">No hay más usuarios disponibles.</small>
                    <% end %>
                </div>
            </div>
        </div>
        </div>

      


      




    </div>
  </div>
</div>

<script>
  document.addEventListener("turbo:load", function() {
    const ctx = document.getElementById('progressChart');
    
    if (ctx) {
      new Chart(ctx, {
        type: 'doughnut',
        data: {
          labels: <%= raw @projects_labels.to_json %>,
          datasets: [{
            label: 'Avance %',
            data: <%= raw @projects_progress.to_json %>,
            backgroundColor: [
              '#3b82f6', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6'
            ],
            hoverOffset: 4
          }]
        },
        options: {
          responsive: true,
          plugins: {
            legend: {
              position: 'bottom',
            }
          }
        }
      });
    }
  });
</script>