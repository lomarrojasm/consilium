<div class="leftside-menu" style="position: fixed; height: 100%; padding-bottom: 0;">

  <a href="<%= root_path %>" class="logo logo-light">
    <span class="logo-lg"><img src="<%= image_path("consilium_rec.png") %>" alt="logo"></span>
    <span class="logo-sm"><img src="<%= image_path("icono_consilium.jpg") %>" alt="small logo"></span>
  </a>

  <a href="<%= root_path %>" class="logo logo-dark">
    <span class="logo-lg"><img src="<%= image_path("consilium_rec.png") %>" alt="dark logo"></span>
    <span class="logo-sm"><img src="<%= image_path("icono_consilium.jpg") %>" alt="small logo"></span>
  </a>

  <div class="button-sm-hover" data-bs-toggle="tooltip" data-bs-placement="right" title="Show Full Sidebar">
    <i class="ri-checkbox-blank-circle-line align-middle"></i>
  </div>
  <div class="button-close-fullsidebar">
    <i class="ri-close-fill align-middle"></i>
  </div>

  <div class="h-100" id="leftside-menu-container" data-simplebar style="padding-bottom: 220px;">
    
    <div class="leftbar-user">
      <a href="<%= edit_user_registration_path %>">
        <img src="<%= image_path("users/avatar-1.jpg") %>" alt="user-image" height="42" class="rounded-circle shadow-sm">
        <span class="leftbar-user-name mt-2">
          <%= current_user&.first_name || 'Usuario' %>
        </span>
      </a>
    </div>

    <ul class="side-nav">
      <li class="side-nav-title">Módulos</li>

      <% if current_user.role == "admin" %>
        <li class="side-nav-item">
          <a data-bs-toggle="collapse" href="#sidebarDashboards" aria-expanded="false" aria-controls="sidebarDashboards" class="side-nav-link">
              <i class="uil-dashboard"></i>
              <span> Dashboards </span>
              <span class="menu-arrow"></span>
          </a>
          <div class="collapse" id="sidebarDashboards">
              <ul class="side-nav-second-level">
                  <li>
                      <%= link_to "Proyectos", projects_dashboards_path, data: { turbo: false } %>
                  </li>
                  <li>
                      <%= link_to admin_prospect_questionnaires_path, data: { turbo: false } do %>
                          <%# El contador ahora vive aquí, al lado del texto %>
                          <span> Leads & Diagnósticos </span>
                          <% count = ProspectQuestionnaire.where(status: 'Nuevo').count %>
                          <% if count > 0 %>
                              <span class="badge rounded-pill bg-danger float-end mt-1"><%= count %></span>
                          <% end %>
                      <% end %>
                  </li>
              </ul>
          </div>
      </li>

        <li class="side-nav-item">
          <%= link_to clients_path, data: { turbo: false }, class: "side-nav-link" do %>
            <i class="ri-building-line"></i>
            <span> Clientes </span>
          <% end %>
        </li>
        <li class="side-nav-title side-nav-item">Configuración</li>

        <li class="side-nav-item">
          <%= link_to users_path, class: "side-nav-link" do %>
            <i class="ri-group-line"></i>
            <span> Usuarios del Sistema </span>
          <% end %>
        </li>
        <li class="side-nav-item">
          <%= link_to admin_system_path, class: 'side-nav-link' do %>
            <i class="ri-server-line"></i>
            <span> Sistema </span>
          <% end %>
        </li>
      <% else %>
        <li class="side-nav-item">
          <a href="<%= client_dashboard_path %>" class="side-nav-link">
            <i class="uil-dashboard"></i>
            <span> Dashboard </span>
          </a>
        </li>
        <% if current_user.client %>
          <li class="side-nav-item">
            <a href="<%= client_path(current_user.client) %>" class="side-nav-link">
              <i class="uil-building"></i> <span> Mi Empresa </span>
            </a>
          </li>
        <% end %>
      <% end %>
    </ul>

    <div class="clearfix"></div>
  </div> 


  <div class="help-box text-white text-center" 
       style="position: absolute; bottom: 30px; left: 20px; right: 20px; z-index: 10; border-radius: 5px;">
        
        <img src="<%= image_path("consilium_blanco.png") %>" height="60" alt="Helper Icon Image" style="max-width: 100%;"/>
        
        <h5 class="mt-3">Soporte</h5>
        <p class="mb-3 font-13">¿Necesitas ayuda con el sistema?</p>
        
        <a href="javascript: void(0);" class="btn btn-success btn-sm w-100">Contactar</a>
  </div>

</div>