<% @page_title = "Admin Dashboard" %>

<%= render 'layouts/partials/page-title', page_title: "Panel de Control", sub_title: "Consilium Admin" %>

<div class="row">
  <div class="col-12">
    <div class="card widget-inline">
      <div class="card-body p-0">
        <div class="row g-0">
          <div class="col-sm-6 col-lg-3">
            <div class="card rounded-0 shadow-none m-0">
              <div class="card-body text-center">
                <i class="ri-community-line text-primary font-24"></i>
                <h3><span><%= @total_clients %></span></h3>
                <p class="text-muted font-15 mb-0">Clientes Totales</p>
              </div>
            </div>
          </div>

          <div class="col-sm-6 col-lg-3">
            <div class="card rounded-0 shadow-none m-0 border-start border-light">
              <div class="card-body text-center">
                <i class="ri-group-line text-success font-24"></i>
                <h3><span><%= @total_users %></span></h3>
                <p class="text-muted font-15 mb-0">Usuarios Totales</p>
              </div>
            </div>
          </div>

          <div class="col-sm-6 col-lg-3">
            <div class="card rounded-0 shadow-none m-0 border-start border-light">
              <div class="card-body text-center">
                <i class="ri-mail-send-line text-warning font-24"></i>
                <h3><span><%= @pending_invites %></span></h3>
                <p class="text-muted font-15 mb-0">Usiarios pendientes</p>
              </div>
            </div>
          </div>

          <div class="col-sm-6 col-lg-3">
            <div class="card rounded-0 shadow-none m-0 border-start border-light">
              <div class="card-body text-center">
                <i class="ri-todo-line text-info font-24"></i>
                <h3><span><%= @projects %></span></h3>
                <p class="text-muted font-15 mb-0">Total de Proyectos</p>
              </div>
            </div>
          </div>
        </div> 
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-12">
    <div class="card">
      <div class="card-header d-flex justify-content-between align-items-center">
        <h4 class="header-title">Proyectos por Cliente</h4>
        <span class="badge badge-soft-primary"><%= @client_names.size %> Clientes</span>
      </div>
      <div class="card-body">
        <div style="position: relative; height: 450px; overflow-y: auto;">
          <canvas id="client-projects-stacked-chart" 
                  data-labels="<%= @client_names.to_json %>" 
                  data-borrador="<%= @data_borrador.to_json %>"
                  data-activo="<%= @data_activo.to_json %>"
                  data-pausado="<%= @data_pausado.to_json %>"
                  data-finalizado="<%= @data_finalizado.to_json %>">
          </canvas>
        </div>
      </div>
    </div>
  </div>
</div>





  

<% content_for :javascript do %>
<script>
  document.addEventListener('turbo:load', function() {

    // --- 2. GRÁFICA DE BARRAS HORIZONTALES (PROYECTOS POR CLIENTE) ---
    const barElem = document.getElementById('client-projects-stacked-chart');
    if (barElem) {
      const ctx = barElem.getContext('2d');
      const labels = JSON.parse(barElem.getAttribute('data-labels'));

      // AJUSTE: Con barras de 17px, un multiplicador de 40px por cliente 
      // deja un "aire" perfecto entre cada barra.
      const dynamicHeight = Math.max(350, labels.length * 40); 
      barElem.height = dynamicHeight;
      barElem.style.height = dynamicHeight + 'px';

      if (window.myStackedBarChart instanceof Chart) { window.myStackedBarChart.destroy(); }

      window.myStackedBarChart = new Chart(ctx, {
        type: 'bar',
        data: {
          labels: labels,
          datasets: [
            {
              label: 'Borrador',
              backgroundColor: '#adb5bd',
              data: JSON.parse(barElem.getAttribute('data-borrador')),
              barThickness: 17, // AJUSTE SOLICITADO
              maxBarThickness: 17
            },
            {
              label: 'Activo',
              backgroundColor: '#3e60d5',
              data: JSON.parse(barElem.getAttribute('data-activo')),
              barThickness: 17,
              maxBarThickness: 17
            },
            {
              label: 'Pausado',
              backgroundColor: '#ffd43b',
              data: JSON.parse(barElem.getAttribute('data-pausado')),
              barThickness: 17,
              maxBarThickness: 17
            },
            {
              label: 'Finalizado',
              backgroundColor: '#0acf97',
              data: JSON.parse(barElem.getAttribute('data-finalizado')),
              barThickness: 17,
              maxBarThickness: 17
            }
          ]
        },
        options: {
          indexAxis: 'y',
          maintainAspectRatio: false,
          responsive: true,
          plugins: {
            legend: { position: 'top' },
            tooltip: { 
              mode: 'index', 
              intersect: false,
              backgroundColor: '#313a46',
              titleFontColor: '#fff',
              bodyFontColor: '#fff'
            }
          },
          scales: {
            x: { 
              stacked: true, 
              beginAtZero: true, 
              ticks: { stepSize: 1, color: '#98a6ad' },
              grid: { color: 'rgba(152, 166, 173, 0.1)' }
            },
            y: { 
              stacked: true, 
              grid: { display: false },
              ticks: {
                color: '#98a6ad',
                font: { size: 12 } 
              }
            }
          }
        }
      });
    }

  });
</script>
<% end %>