<%# app/views/activities/_activity_modal.html.erb %>

<div class="modal-header bg-primary text-white">
    <h5 class="modal-title font-16 fw-bold">
        <i class="ri-survey-line me-1"></i> Panel de Actividad: <%= activity.name %>
    </h5>
    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<div class="modal-body p-0">
    <div class="row g-0">
        <div class="col-md-7 border-end p-4 bg-white">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="m-0 font-13 fw-bold text-uppercase text-muted"><i class="ri-history-line me-1"></i> Línea de Tiempo</h5>
                <span class="badge bg-soft-primary text-primary font-11">Última act. <%= time_ago_in_words(activity.updated_at) %></span>
            </div>
            
            <div class="timeline-alt pb-0 pe-2" style="max-height: 500px; overflow-y: auto;" data-simplebar>
                <% if activity.activity_logs.any? %>
                    <% activity.activity_logs.order(created_at: :desc).each do |log| %>
                        <div class="timeline-item">
                            <% status_class = case log.status 
                                when 'approved' then 'success'
                                when 'rejected' then 'danger'
                                else 'warning'
                               end %>
                            
                            <% icon_class = log.comment.include?('📁') ? 'ri-file-upload-line' : (log.comment.include?('🛡️') ? 'ri-shield-check-line' : 'ri-record-circle-line') %>
                            <i class="<%= icon_class %> text-<%= status_class %> timeline-icon bg-white"></i>
                            
                            <div class="timeline-item-info border rounded p-2 shadow-none mb-3 bg-light bg-opacity-50">
                                <div class="d-flex justify-content-between mb-1">
                                    <h6 class="m-0 fw-bold text-dark"><%= log.user.full_name %></h6>
                                    <small class="text-muted"><%= log.created_at.strftime("%d/%m/%y %H:%M") %></small>
                                </div>
                                <p class="text-muted font-13 mb-1"><%= log.comment %></p>
                                
                                <% if log.attachments.attached? %>
                                    <div class="d-flex flex-wrap gap-2 mt-2">
                                        <% log.attachments.each do |file| %>
                                            <%= link_to rails_blob_path(file, disposition: "attachment"), class: "btn btn-xs btn-white border d-flex align-items-center py-1" do %>
                                                <i class="ri-attachment-line me-1 text-primary"></i>
                                                <span class="font-10 text-truncate" style="max-width: 120px;"><%= file.filename %></span>
                                            <% end %>
                                        <% end %>
                                    </div>
                                <% end %>
                            </div>
                        </div>
                    <% end %>
                <% else %>
                    <div class="text-center py-5">
                        <i class="ri-chat-history-line font-36 text-muted opacity-25 mb-2 d-block"></i>
                        <p class="text-muted font-13">La actividad no tiene registros aún.<br>Sube evidencia o añade un comentario para empezar.</p>
                    </div>
                <% end %>
            </div>
        </div>

        <div class="col-md-5 p-4 bg-light">
            <h5 class="mb-3 font-13 fw-bold text-uppercase text-muted"><i class="ri-git-merge-line me-1"></i> Flujo de Autorización</h5>
            
            <div class="card shadow-none border mb-2 <%= activity.evidence.attached? ? 'border-success' : 'border-secondary border-opacity-25' %>">
                <div class="card-body p-2 d-flex align-items-center">
                    <div class="avatar-sm me-2">
                        <span class="avatar-title rounded-circle <%= activity.evidence.attached? ? 'bg-success text-white' : 'bg-light text-muted' %> font-16">1</span>
                    </div>
                    <div class="flex-grow-1">
                        <h6 class="m-0 font-13 fw-bold <%= activity.evidence.attached? ? 'text-success' : 'text-muted' %>">Evidencia Formal</h6>
                        <% if activity.evidence.attached? %>
                            <small class="text-muted font-11"><i class="ri-check-line"></i> Cargada: <%= activity.evidence_uploaded_at&.strftime("%d/%m/%y") || 'Reciente' %></small>
                        <% else %>
                            <small class="text-danger font-11"><i class="ri-error-warning-line"></i> Requerida para aprobar</small>
                        <% end %>
                    </div>
                </div>
            </div>

            <div class="card shadow-none border mb-2 <%= activity.user_approved ? 'border-primary' : 'border-secondary border-opacity-25' %>">
                <div class="card-body p-2 d-flex align-items-center">
                    <div class="avatar-sm me-2">
                        <span class="avatar-title rounded-circle <%= activity.user_approved ? 'bg-primary text-white' : 'bg-light text-muted' %> font-16">2</span>
                    </div>
                    <div class="flex-grow-1">
                        <h6 class="m-0 font-13 fw-bold <%= activity.user_approved ? 'text-primary' : 'text-muted' %>">Visto Bueno Cliente</h6>
                        <% if activity.user_approved %>
                            <small class="text-muted font-11"><i class="ri-check-double-line"></i> Por: <%= activity.user.first_name %> (<%= activity.user_approved_at&.strftime("%d/%m/%y") %>)</small>
                        <% else %>
                            <small class="text-muted font-11"><%= activity.evidence.attached? ? 'Esperando validación' : 'Bloqueado (Falta evidencia)' %></small>
                        <% end %>
                    </div>
                    <div class="ms-2">
                        <%= form_with url: toggle_user_approval_client_project_activity_path(@client, @project, activity), method: :patch, local: false, class: "m-0" do %>
                            <div class="form-check form-switch m-0">
                                <%# Bloqueado si el admin ya aprobó (se debe desmarcar admin primero) %>
                                <input type="checkbox" class="form-check-input cursor-pointer" style="width: 2.5em; height: 1.2em;"
                                       <%= 'checked' if activity.user_approved %>
                                       onchange="this.form.submit()"
                                       <%= 'disabled' if (!activity.completed && !activity.evidence.attached?) || activity.admin_approved %>>
                            </div>
                        <% end %>
                    </div>
                </div>
            </div>

            <div class="card shadow-none border mb-4 <%= activity.admin_approved ? 'border-danger' : 'border-secondary border-opacity-25' %>">
                <div class="card-body p-2 d-flex align-items-center">
                    <div class="avatar-sm me-2">
                        <span class="avatar-title rounded-circle <%= activity.admin_approved ? 'bg-danger text-white' : 'bg-light text-muted' %> font-16">3</span>
                    </div>
                    <div class="flex-grow-1">
                        <h6 class="m-0 font-13 fw-bold <%= activity.admin_approved ? 'text-danger' : 'text-muted' %>">Validación Consilium</h6>
                        <% if activity.admin_approved %>
                            <small class="text-muted font-11"><i class="ri-shield-check-fill text-danger"></i> Cierre oficial (<%= activity.admin_approved_at&.strftime("%d/%m/%y") %>)</small>
                        <% else %>
                            <small class="text-muted font-11"><%= activity.user_approved ? 'Esperando al Admin' : 'Bloqueado (Falta V.B. Cliente)' %></small>
                        <% end %>
                    </div>
                    <div class="ms-2">
                        <%= form_with url: toggle_admin_approval_client_project_activity_path(@client, @project, activity), method: :patch, local: false, class: "m-0" do %>
                            <div class="form-check form-switch m-0">
                                <%# SEGURIDAD PERFECTA: Solo el admin real puede aprobar. En Impersonate esto estará gris y bloqueado %>
                                <input type="checkbox" class="form-check-input border-danger cursor-pointer" style="width: 2.5em; height: 1.2em;"
                                       <%= 'checked' if activity.admin_approved %>
                                       onchange="this.form.submit()"
                                       <%= 'disabled' unless current_user.role == 'admin' && activity.user_approved %>>
                            </div>
                        <% end %>
                    </div>
                </div>
            </div>

            <% if activity.admin_approved %>
                <div class="alert alert-success border-0 text-center">
                    <i class="ri-checkbox-circle-fill font-24 d-block mb-1"></i>
                    <strong>Actividad Finalizada</strong><br>
                    <small>Esta tarea ha sido cerrada formalmente y no admite nuevos comentarios. Para reabrirla, el administrador debe retirar el Visto Bueno.</small>
                </div>
            <% else %>
                <hr class="border-dashed mb-3">
                <h5 class="mb-3 font-13 fw-bold text-uppercase text-muted"><i class="ri-add-line me-1"></i> Añadir Seguimiento</h5>
                <%= form_with url: update_status_client_project_activity_path(@client, @project, activity), method: :patch, local: true, multipart: true do |f| %>
                    
                    <div class="mb-2">
                        <%= f.text_area :comment, class: "form-control form-control-sm", rows: 3, placeholder: "Detalla los avances o motivos de retraso...", required: true %>
                    </div>

                    <div class="mb-3">
                        <label class="font-11 text-muted fw-bold d-block mb-1">Archivos Adicionales (Opcional)</label>
                        <%= file_field_tag "attachments[]", multiple: true, class: "form-control form-control-sm" %>
                    </div>

                    <div class="btn-group w-100 mb-2" role="group">
                        <input type="radio" class="btn-check" name="status" id="st_pending" value="pending" <%= 'checked' if activity.status == 'pending' || activity.status.nil? %>>
                        <label class="btn btn-outline-warning btn-sm" for="st_pending">
                            En Proceso
                        </label>

                        <input type="radio" class="btn-check" name="status" id="st_deny" value="rejected" <%= 'checked' if activity.status == 'rejected' %>>
                        <label class="btn btn-outline-danger btn-sm" for="st_deny">
                            Rechazar
                        </label>
                    </div>
                    
                    <%= f.submit "Registrar Avance", class: "btn btn-primary w-100 btn-sm shadow-sm" %>
                <% end %>
            <% end %>
        </div>
    </div>
</div>

<style>
    .timeline-alt { padding: 5px 0; border-left: 2px solid #eef2f7; margin-left: 10px; }
    .timeline-item { position: relative; padding-left: 20px; padding-bottom: 20px; }
    .timeline-icon { position: absolute; left: -28px; top: 0; font-size: 18px; z-index: 2; border-radius: 50%; padding: 2px; }
    .cursor-pointer { cursor: pointer; }
    .btn-white { background-color: #fff; border-color: #eef2f7; color: #6c757d; }
    .btn-white:hover { background-color: #f8f9fa; }
</style>