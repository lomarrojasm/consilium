<%# app/views/activities/_form.html.erb %>
<%= form_with(model: [@client, @project, @activity], local: true, class: "needs-validation") do |f| %>
  
  <% if @activity.errors.any? %>
    <div class="alert alert-danger shadow-sm border-0 mb-4">
      <div class="d-flex">
        <i class="ri-error-warning-fill me-2 font-20"></i>
        <div>
          <h6 class="fw-bold">Por favor corrige los siguientes errores:</h6>
          <ul class="mb-0 font-13">
            <% @activity.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>


  <%# --- BLOQUE ADMIN: FECHA ORIGINAL (SUTIL) --- %>
  <% if current_user.role == 'admin' && !@activity.new_record? %>
    <div class="row mb-3">
      <div class="col-12">
        <div class="card border-dashed border-primary bg-light bg-opacity-10 shadow-none mb-0">
          <div class="card-body py-2 d-flex align-items-center justify-content-between">
            <div class="d-flex align-items-center">
              <i class="ri-calendar-check-line text-primary me-2 font-20"></i>
              <div>
                <h6 class="m-0 font-13 fw-bold text-primary">Fecha de Registro Original (Admin)</h6>
                <small class="text-muted">Ajusta la fecha histórica de esta actividad si es necesario.</small>
              </div>
            </div>
            <div style="width: 200px;">
              <%= f.date_field :created_at, 
                               value: @activity.created_at&.to_date, 
                               class: "form-control form-control-sm border-primary shadow-none" %>
            </div>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <%# DEFINICIÓN COMPARTIDA DE ETAPAS (Se usa en ambos formularios) %>
  <% 
    available_stages = @project.stages.order(:position).reject { |s| s.locked_for?(current_user) }
    available_stages << @activity.stage if @activity.stage && !available_stages.include?(@activity.stage)
  %>

  <%# ========================================================================= %>
  <%# BIFURCACIÓN DE LÓGICA: ¿Es un Proyecto de Metodología o uno Especial?     %>
  <%# ========================================================================= %>

  <% if @project.project_type == 'metodologia' || @project.project_type.blank? %>
    
    <%# ----------------------------------------------------------------------- %>
    <%# FORMULARIO A: METODOLOGÍA (Mantiene tu tabla de horas y scripts intactos) %>
    <%# ----------------------------------------------------------------------- %>
    <div class="row">
      <div class="col-lg-4">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-body">
            <h5 class="card-title mb-3 text-primary d-flex align-items-center">
              <i class="ri-information-fill me-1"></i> Información General
            </h5>

            <div class="form-floating mb-3">
              <%= f.collection_select :stage_id, available_stages, :id, :name, {}, { class: "form-select border-light-subtle", required: true } %>
              <%= f.label :stage_id, "Etapa del Proyecto" %>
              <% if available_stages.empty? && @activity.new_record? %>
                  <div class="form-text text-danger font-10 mt-1"><i class="ri-error-warning-line"></i> No hay etapas disponibles o todas están finalizadas.</div>
              <% end %>
            </div>

            <div class="form-floating mb-3">
              <%= f.text_area :name, class: "form-control border-light-subtle", placeholder: "Nombre", style: "height: 120px", required: true %>
              <%= f.label :name, "Nombre de la Actividad" %>
            </div>

            <div class="form-floating mb-3">
              <%= f.collection_select :responsible_id, @project.users.order(:first_name), :id, :full_name, { prompt: "" }, { class: "form-select border-light-subtle", required: true } %>
              <%= f.label :responsible_id, "Responsable de Ejecución" %>
            </div>

            <div class="form-floating mb-3">
              <%= f.text_field :document_ref, class: "form-control border-light-subtle", placeholder: "Referencia" %>
              <%= f.label :document_ref, "Documento / Entregable (Ref)" %>
            </div>

            <div class="form-floating mb-3">
              <%= f.select :area, ['Integral', 'Dirección', 'Finanzas', 'Procesos', 'Comercial', 'RH'], { include_blank: '' }, { class: "form-select border-light-subtle" } %>
              <%= f.label :area, "Área Interna" %>
            </div>

            <div class="bg-light p-2 rounded mb-3">
              <label class="form-label font-11 text-uppercase fw-bold text-muted ms-1 mb-2">Programación Temporal</label>
              <div class="row g-2">
                <div class="col-4">
                  <div class="form-floating">
                    <%= f.number_field :month, class: "form-control border-0", placeholder: "Mes" %>
                    <%= f.label :month, "Mes" %>
                  </div>
                </div>
                <div class="col-4">
                  <div class="form-floating">
                    <%= f.number_field :week, class: "form-control border-0", placeholder: "Semana" %>
                    <%= f.label :week, "Semana" %>
                  </div>
                </div>
                <div class="col-4">
                  <div class="form-floating">
                    <%= f.number_field :completed_day, class: "form-control border-0", placeholder: "Día" %>
                    <%= f.label :completed_day, "Día Fin" %>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="col-lg-8">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-body">
            <h5 class="card-title mb-3 text-primary d-flex align-items-center">
              <i class="ri-money-dollar-circle-fill me-1"></i> Presupuesto y Esfuerzo
            </h5>
            <div class="table-responsive">
              <table class="table table-centered mb-0 align-middle">
                <thead class="table-light">
                  <tr class="font-12 text-muted">
                    <th class="ps-3">ROL</th>
                    <th style="width: 20%;">HORAS</th>
                    <th style="width: 25%;">TARIFA ($/hr)</th>
                    <th style="width: 25%;" class="text-end pe-3">SUBTOTAL ($)</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td class="fw-bold text-dark ps-3">Líder</td>
                    <td><%= f.number_field :leader_hours, step: 0.5, class: "form-control form-control-sm calc-input", data: { role: 'leader', type: 'hours' }, placeholder: "0" %></td>
                    <td>
                      <div class="input-group input-group-sm">
                        <span class="input-group-text">$</span>
                        <%= f.number_field :leader_rate, step: 0.01, class: "form-control calc-input", data: { role: 'leader', type: 'rate' }, placeholder: "0" %>
                      </div>
                    </td>
                    <td class="text-end pe-3"><%= f.number_field :leader_cost, step: 0.01, class: "form-control form-control-sm bg-light text-end border-0 fw-bold", readonly: true, id: "total_leader" %></td>
                  </tr>
                  <tr>
                    <td class="fw-bold text-dark ps-3">Senior</td>
                    <td><%= f.number_field :senior_hours, step: 0.5, class: "form-control form-control-sm calc-input", data: { role: 'senior', type: 'hours' }, placeholder: "0" %></td>
                    <td>
                      <div class="input-group input-group-sm">
                        <span class="input-group-text">$</span>
                        <%= f.number_field :senior_rate, step: 0.01, class: "form-control calc-input", data: { role: 'senior', type: 'rate' }, placeholder: "0" %>
                      </div>
                    </td>
                    <td class="text-end pe-3"><%= f.number_field :senior_cost, step: 0.01, class: "form-control form-control-sm bg-light text-end border-0 fw-bold", readonly: true, id: "total_senior" %></td>
                  </tr>
                  <tr>
                    <td class="fw-bold text-dark ps-3">Analista</td>
                    <td><%= f.number_field :analyst_hours, step: 0.5, class: "form-control form-control-sm calc-input", data: { role: 'analyst', type: 'hours' }, placeholder: "0" %></td>
                    <td>
                      <div class="input-group input-group-sm">
                        <span class="input-group-text">$</span>
                        <%= f.number_field :analyst_rate, step: 0.01, class: "form-control calc-input", data: { role: 'analyst', type: 'rate' }, placeholder: "0" %>
                      </div>
                    </td>
                    <td class="text-end pe-3"><%= f.number_field :analyst_cost, step: 0.01, class: "form-control form-control-sm bg-light text-end border-0 fw-bold", readonly: true, id: "total_analyst" %></td>
                  </tr>
                  <tr class="bg-primary bg-opacity-10">
                      <td colspan="3" class="text-end fw-bold align-middle py-3">COSTO TOTAL DE LA ACTIVIDAD:</td>
                      <td class="text-end pe-3 align-middle">
                          <h3 class="my-0 text-primary fw-bold" id="grand_total">
                              <%= number_to_currency(@activity.activity_cost || 0) %>
                          </h3>
                          <%# Input oculto para asegurar que Rails reciba el total si no se calcula en el backend %>
                          <%= f.hidden_field :activity_cost, id: "hidden_activity_cost" %>
                      </td>
                  </tr>
                </tbody>
              </table>
            </div>
            <div class="alert alert-soft-info mt-3 mb-0 border-0 font-12">
              <i class="ri-information-fill me-1 font-16 align-middle"></i> El cálculo es automático: <strong>(Horas × Tarifa)</strong> por cada rol asignado.
            </div>
          </div>
        </div>
      </div>
      
      <div class="col-12 mt-3">
        <div class="card shadow-sm border-0">
          <div class="card-body">
             <h5 class="card-title mb-2 text-muted font-13 text-uppercase">Notas o Descripción de la Tarea</h5>
             <%= f.text_area :description, class: "form-control border-light-subtle", rows: 3, placeholder: "Instrucciones adicionales para el responsable..." %>
          </div>
        </div>
      </div>
    </div>

  <% else %>
    
    <%# ----------------------------------------------------------------------- %>
    <%# FORMULARIO B: PROYECTOS ESPECIALES (Simplificado + Costo Directo)       %>
    <%# ----------------------------------------------------------------------- %>
    <div class="row">
      <div class="col-lg-5">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-body">
            <h5 class="card-title mb-3 text-warning text-darken d-flex align-items-center">
              <i class="ri-information-fill me-1"></i> Información General (Especial)
            </h5>

            <div class="form-floating mb-3">
               <%= f.collection_select :stage_id, available_stages, :id, :name, {}, { class: "form-select border-light-subtle", required: true } %>
               <%= f.label :stage_id, "Etapa del Proyecto" %>
               <% if available_stages.empty? && @activity.new_record? %>
                  <div class="form-text text-danger font-10 mt-1"><i class="ri-error-warning-line"></i> No hay etapas disponibles o todas están finalizadas.</div>
               <% end %>
            </div>

            <div class="form-floating mb-3">
              <%= f.text_area :name, class: "form-control border-light-subtle", placeholder: "Nombre", style: "height: 120px", required: true %>
              <%= f.label :name, "Nombre de la Actividad" %>
            </div>

            <div class="form-floating mb-3">
              <%= f.collection_select :responsible_id, @project.users.order(:first_name), :id, :full_name, { prompt: "" }, { class: "form-select border-light-subtle", required: true } %>
              <%= f.label :responsible_id, "Responsable de Ejecución" %>
            </div>

            <div class="form-floating mb-3">
              <%= f.text_field :area, class: "form-control border-light-subtle", placeholder: "Ej: Desarrollo / Operaciones" %>
              <%= f.label :area, "Área o Departamento (Libre)" %>
            </div>

            <div class="form-floating mb-0">
              <%= f.text_field :document_ref, class: "form-control border-light-subtle", placeholder: "Referencia" %>
              <%= f.label :document_ref, "Documento / Entregable (Ref)" %>
            </div>

          </div>
        </div>
      </div>

      <div class="col-lg-7">
        <div class="card shadow-sm border-0">
          <div class="card-body">
            <h5 class="card-title mb-3 text-warning text-darken d-flex align-items-center">
              <i class="ri-money-dollar-circle-fill me-1"></i> Costo / Comisión
            </h5>
            
            <div class="alert alert-soft-warning border-0 font-13 mb-4">
              <i class="ri-information-line me-1"></i> Como este proyecto es de tipo <strong><%= @project.project_type.humanize.upcase %></strong>, no utiliza la calculadora por horas. Ingresa directamente la comisión o costo total acordado.
            </div>

            <div class="form-floating mb-3">
              <%= f.number_field :activity_cost, step: 0.01, class: "form-control border-warning border-opacity-50 shadow-sm fw-bold text-dark font-20", placeholder: "0.00", required: true %>
              <%= f.label :activity_cost, "Costo Total de la Actividad / Comisión ($)" %>
            </div>
          </div>
        </div>
        
        <div class="card shadow-sm border-0 mt-3">
          <div class="card-body">
             <h5 class="card-title mb-2 text-muted font-13 text-uppercase">Notas o Descripción de la Tarea</h5>
             <%= f.text_area :description, class: "form-control border-light-subtle", rows: 5, placeholder: "Instrucciones adicionales para el responsable o detalles del pago..." %>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <%# ========================================================================= %>
  <%# BOTONES DE GUARDADO (Común)                                               %>
  <%# ========================================================================= %>
  <div class="row mt-4 mb-5">
    <div class="col-12 text-end">
        <hr class="border-dashed opacity-50 mb-4">
        <%= link_to "Volver al Proyecto", client_project_path(@client, @project), class: "btn btn-light me-2 px-4 shadow-none" %>
        
        <% if available_stages.empty? && @activity.new_record? %>
            <button class="btn btn-primary px-5 shadow-sm fw-bold disabled" style="pointer-events: none;">Crear Actividad</button>
        <% else %>
            <%= f.submit @activity.new_record? ? "Crear Actividad" : "Guardar Cambios", class: "btn btn-primary px-5 shadow-sm fw-bold" %>
        <% end %>
    </div>
  </div>
<% end %>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const inputs = document.querySelectorAll(".calc-input");
        const hiddenActivityCost = document.getElementById("hidden_activity_cost");
        
        function calculate() {
            let grandTotal = 0;
            
            ['leader', 'senior', 'analyst'].forEach(role => {
                const hoursInput = document.querySelector(`input[data-role='${role}'][data-type='hours']`);
                const rateInput = document.querySelector(`input[data-role='${role}'][data-type='rate']`);
                const totalInput = document.getElementById(`total_${role}`);
                
                if (hoursInput && rateInput && totalInput) {
                    const hours = parseFloat(hoursInput.value) || 0;
                    const rate = parseFloat(rateInput.value) || 0;
                    const cost = hours * rate;
                    
                    totalInput.value = cost.toFixed(2);
                    grandTotal += cost;
                }
            });
            
            const totalElement = document.getElementById('grand_total');
            if (totalElement) {
                totalElement.innerText = new Intl.NumberFormat('en-US', {
                    style: 'currency',
                    currency: 'USD',
                }).format(grandTotal);
            }

            // Actualizamos el campo oculto para que el controlador reciba el total
            if (hiddenActivityCost) {
                hiddenActivityCost.value = grandTotal.toFixed(2);
            }
        }

        inputs.forEach(input => {
            input.addEventListener('input', calculate);
        });

        // Solo ejecutar si hay elementos calc-input (Metodología)
        if (inputs.length > 0) {
            calculate();
        }
    });
</script>