<%= form_with(model: [@client, @project, @activity], local: true, class: "needs-validation") do |f| %>
  
  <% if @activity.errors.any? %>
    <div class="alert alert-danger">
      <ul>
        <% @activity.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row">
    <div class="col-lg-4">
      <div class="card">
        <div class="card-body">
          <h5 class="card-title mb-3">Información General</h5>

          <div class="mb-3">
            <%= f.label :name, "Nombre de la Actividad", class: "form-label" %>
            <%= f.text_area :name, rows: 3, class: "form-control", required: true %>
          </div>

          <div class="mb-3">
            <%= f.label :document_ref, "Documento / Entregable (Ref)", class: "form-label" %>
            <%= f.text_field :document_ref, class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= f.label :area, "Área Responsable", class: "form-label" %>
            <%= f.select :area, 
                ['Integral', 'Dirección', 'Finanzas', 'Procesos', 'Comercial', 'RH'], 
                { include_blank: 'Seleccionar...' }, 
                class: "form-select" %>
          </div>

          <div class="row">
            <div class="col-4">
              <%= f.label :month, "Mes", class: "form-label" %>
              <%= f.number_field :month, class: "form-control" %>
            </div>
            <div class="col-4">
              <%= f.label :week, "Semana", class: "form-label" %>
              <%= f.number_field :week, class: "form-control" %>
            </div>
            <div class="col-4">
              <%= f.label :completed_day, "Día Fin", class: "form-label" %>
              <%= f.number_field :completed_day, class: "form-control", placeholder: "1-31" %>
            </div>
          </div>
          
          <div class="mt-3">
             <%= f.label :stage_id, "Etapa del Proyecto", class: "form-label" %>
             <%= f.collection_select :stage_id, @project.stages, :id, :name, {}, class: "form-select" %>
          </div>

        </div>
      </div>
    </div>

    <div class="col-lg-8">
      <div class="card">
        <div class="card-body">
          <h5 class="card-title mb-3">Presupuesto y Esfuerzo</h5>
          
          <div class="table-responsive">
            <table class="table table-bordered table-centered mb-0">
              <thead class="table-light">
                <tr>
                  <th>Rol</th>
                  <th style="width: 25%;">Horas</th>
                  <th style="width: 25%;">Tarifa ($/hr)</th>
                  <th style="width: 30%;">Costo Total ($)</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td class="fw-bold">Líder</td>
                  <td>
                    <%= f.number_field :leader_hours, step: 0.5, class: "form-control calc-input", data: { role: 'leader', type: 'hours' } %>
                  </td>
                  <td>
                    <div class="input-group input-group-sm">
                      <span class="input-group-text">$</span>
                      <%= f.number_field :leader_rate, step: 0.01, class: "form-control calc-input", data: { role: 'leader', type: 'rate' } %>
                    </div>
                  </td>
                  <td>
                    <div class="input-group input-group-sm">
                      <span class="input-group-text">$</span>
                      <%= f.number_field :leader_cost, step: 0.01, class: "form-control bg-light", readonly: true, id: "total_leader" %>
                    </div>
                  </td>
                </tr>

                <tr>
                  <td class="fw-bold">Senior</td>
                  <td>
                    <%= f.number_field :senior_hours, step: 0.5, class: "form-control calc-input", data: { role: 'senior', type: 'hours' } %>
                  </td>
                  <td>
                    <div class="input-group input-group-sm">
                      <span class="input-group-text">$</span>
                      <%= f.number_field :senior_rate, step: 0.01, class: "form-control calc-input", data: { role: 'senior', type: 'rate' } %>
                    </div>
                  </td>
                  <td>
                    <div class="input-group input-group-sm">
                      <span class="input-group-text">$</span>
                      <%= f.number_field :senior_cost, step: 0.01, class: "form-control bg-light", readonly: true, id: "total_senior" %>
                    </div>
                  </td>
                </tr>

                <tr>
                  <td class="fw-bold">Analista</td>
                  <td>
                    <%= f.number_field :analyst_hours, step: 0.5, class: "form-control calc-input", data: { role: 'analyst', type: 'hours' } %>
                  </td>
                  <td>
                    <div class="input-group input-group-sm">
                      <span class="input-group-text">$</span>
                      <%= f.number_field :analyst_rate, step: 0.01, class: "form-control calc-input", data: { role: 'analyst', type: 'rate' } %>
                    </div>
                  </td>
                  <td>
                    <div class="input-group input-group-sm">
                      <span class="input-group-text">$</span>
                      <%= f.number_field :analyst_cost, step: 0.01, class: "form-control bg-light", readonly: true, id: "total_analyst" %>
                    </div>
                  </td>
                </tr>
                
                <tr class="bg-light-subtle">
                    <td colspan="3" class="text-end fw-bold">Costo Total Actividad:</td>
                    <td>
                        <h4 class="my-0 text-primary" id="grand_total">
                            <%= number_to_currency(@activity.activity_cost || 0) %>
                        </h4>
                    </td>
                </tr>

              </tbody>
            </table>
          </div>
          
          <div class="alert alert-info mt-3 mb-0">
            <i class="mdi mdi-information-outline me-1"></i> 
            Los costos se calculan automáticamente: <strong>Horas × Tarifa = Costo</strong>.
          </div>

        </div>
      </div>
    </div>
  </div>

  <div class="row mt-3">
    <div class="col-12 text-end">
        <%= link_to "Cancelar", client_project_path(@client, @project), class: "btn btn-light me-2" %>
        <%= f.submit "Guardar Cambios", class: "btn btn-success px-4" %>
    </div>
  </div>
<% end %>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const inputs = document.querySelectorAll(".calc-input");
        
        function calculate() {
            let grandTotal = 0;
            
            ['leader', 'senior', 'analyst'].forEach(role => {
                // Seleccionar inputs por data attributes
                const hoursInput = document.querySelector(`input[data-role='${role}'][data-type='hours']`);
                const rateInput = document.querySelector(`input[data-role='${role}'][data-type='rate']`);
                const totalInput = document.getElementById(`total_${role}`);
                
                const hours = parseFloat(hoursInput.value) || 0;
                const rate = parseFloat(rateInput.value) || 0;
                const cost = hours * rate;
                
                // Actualizar input readonly
                totalInput.value = cost.toFixed(2);
                grandTotal += cost;
            });
            
            // Actualizar total visual
            document.getElementById('grand_total').innerText = "$" + grandTotal.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2});
        }

        // Escuchar cambios en todos los inputs relevantes
        inputs.forEach(input => {
            input.addEventListener('input', calculate);
        });
    });
</script>