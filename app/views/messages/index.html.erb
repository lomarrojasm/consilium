<%# app/views/messages/index.html.erb %>
<meta name="current-user-id" content="<%= current_user.id %>">

<%# 1. ENCABEZADO %>
<div class="row">
    <div class="col-12">
        <div class="page-title-box">
            <div class="page-title-right">
                <ol class="breadcrumb m-0">
                    <li class="breadcrumb-item"><%= link_to "Consilium", root_path %></li>
                    <li class="breadcrumb-item active">Chat Corporativo</li>
                </ol>
            </div>
            <h4 class="page-title">Mensajería</h4>
        </div>
    </div>
</div>

<div class="row">
    <%# --- COLUMNA IZQUIERDA: SIDEBAR --- %>
    <div class="col-xxl-3 col-xl-4">
        <div class="card shadow-sm border-0">
            <div class="card-body" data-controller="presence">
                <h4 class="header-title mb-1 text-primary">
                    <i class="ri-community-line me-1"></i> 
                    <%= @client.company_name %>
                </h4>

                <% if current_user.role == 'admin' || @company_users.include?(current_user) %>
                    <div class="mb-3 mt-2">
                        <button type="button" class="btn btn-sm btn-outline-primary w-100 d-flex align-items-center justify-content-center shadow-none" data-bs-toggle="modal" data-bs-target="#newGroupModal">
                            <i class="ri-group-line me-1 font-16"></i> Nuevo Grupo de Trabajo
                        </button>
                    </div>
                <% end %>

                <div class="mb-3">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-light border-light text-muted"><i class="ri-search-line"></i></span>
                        <input type="text" class="form-control border-light bg-light" placeholder="Buscar chat..." id="contact-search" onkeyup="filterContacts()">
                    </div>
                </div>

                <div class="p-0" style="max-height: 550px; overflow-y: auto;" data-simplebar>
                    <div id="contacts-list">
                        
                        <%# SECCIÓN DE GRUPOS %>
                        <% if @group_conversations&.any? %>
                            <h6 class="font-11 text-muted text-uppercase mt-2 mb-2 px-2">Grupos</h6>
                            <% @group_conversations.each do |group| %>
                                <%# Lógica de mensajes no leídos para grupos %>
                                <% participant = group.conversation_participants.find_by(user: current_user) %>
                                <% unread_count = participant&.unread_messages_count || 0 %>

                                <div class="d-flex align-items-center chat-row position-relative mb-1" id="sidebar-conv-<%= group.id %>">
                                    <a href="<%= client_conversation_messages_path(@client, group) %>" 
                                       class="contact-item flex-grow-1 text-body d-block p-2 rounded transition-all <%= 'active-chat border-start border-2 border-primary' if group == @conversation %>"
                                       data-name="<%= group.name.downcase %>">
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-sm me-2">
                                                <span class="avatar-title rounded-circle bg-warning text-white font-14 fw-bold shadow-sm">G</span>
                                            </div>
                                            <div class="flex-grow-1 overflow-hidden">
                                                <h5 class="mt-0 mb-0 font-14 fw-semibold text-truncate">
                                                    <%= group.name %>
                                                    <span class="badge bg-danger rounded-pill ms-1 <%= 'd-none' if unread_count == 0 %>" id="unread-count-<%= group.id %>">
                                                        <%= unread_count %>
                                                    </span>
                                                </h5>
                                                <p class="mb-0 text-muted font-11 text-truncate"><%= group.users.count %> miembros</p>
                                            </div>
                                        </div>
                                    </a>
                                    <% if current_user.role == 'admin' || group.sender_id == current_user.id %>
                                        <%= button_to client_conversation_path(@client, group), method: :delete, form: { data: { turbo_confirm: "¿Eliminar grupo para todos?" }, class: "d-inline" }, class: "btn-delete-sidebar text-danger border-0 bg-transparent p-0 me-2" do %>
                                            <i class="ri-delete-bin-line"></i>
                                        <% end %>
                                    <% end %>
                                </div>
                            <% end %>
                            <hr class="my-2 border-dashed">
                        <% end %>

                        <%# SECCIÓN DE CHATS INDIVIDUALES %>
                        <h6 class="font-11 text-muted text-uppercase mt-2 mb-2 px-2">Mensajes Directos</h6>
                        <% @company_users.each do |user| %>
                            <% conv_ind = @active_conversations.find { |c| !c.is_group? && (c.sender_id == user.id || c.recipient_id == user.id) } %>
                            <%# Lógica de mensajes no leídos para individuales %>
                            <% unread_count = 0 %>
                            <% if conv_ind %>
                                <% participant = conv_ind.conversation_participants.find_by(user: current_user) %>
                                <% unread_count = participant&.unread_messages_count || 0 %>
                            <% end %>

                            <div class="d-flex align-items-center chat-row position-relative mb-1" id="sidebar-user-<%= user.id %>">
                                <a href="<%= start_chat_client_conversations_path(@client, recipient_id: user.id) %>" 
                                   class="contact-item flex-grow-1 text-body d-block p-2 rounded transition-all <%= 'active-chat border-start border-2 border-primary' if user == @chat_partner && !@conversation.is_group? %>"
                                   data-name="<%= user.first_name.downcase %>">
                                    <div class="d-flex align-items-center">
                                        <div class="flex-shrink-0 position-relative">
                                            <% if user.avatar.attached? %>
                                                <%= image_tag url_for(user.avatar), class: "rounded-circle", height: "38", width: "38", style: "object-fit: cover;" %>
                                            <% else %>
                                                <div class="avatar-sm">
                                                    <span class="avatar-title rounded-circle bg-soft-primary text-primary font-13 fw-bold"><%= user.first_name[0] %></span>
                                                </div>
                                            <% end %>
                                            <span class="user-presence-dot <%= user.online ? 'bg-success' : 'bg-secondary' %> border border-white rounded-circle" id="presence-dot-<%= user.id %>"></span>
                                        </div>
                                        <div class="flex-grow-1 ms-2 overflow-hidden">
                                            <h5 class="mt-0 mb-0 font-14 fw-semibold text-truncate">
                                                <%= user.full_name %>
                                                <span class="badge bg-danger rounded-pill ms-1 <%= 'd-none' if unread_count == 0 %>" id="unread-count-<%= conv_ind&.id %>">
                                                    <%= unread_count %>
                                                </span>
                                            </h5>
                                            <p class="mb-0 text-muted font-11 text-truncate" id="presence-text-<%= user.id %>"><%= user.online ? 'En línea' : 'Desconectado' %></p>
                                        </div>
                                    </div>
                                </a>
                                <% if conv_ind && current_user.role == 'admin' %>
                                    <%= button_to client_conversation_path(@client, conv_ind), method: :delete, form: { data: { turbo_confirm: "¿Borrar historial?" }, class: "d-inline" }, class: "btn-delete-sidebar text-danger border-0 bg-transparent p-0 me-2" do %>
                                        <i class="ri-delete-bin-line"></i>
                                    <% end %>
                                <% end %>
                            </div>
                        <% end %>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <%# --- COLUMNA DERECHA: VENTANA DE CHAT --- %>
    <%# El ID 'chat-window-container' permite que Turbo Stream lo actualice tras borrar %>
    <div class="col-xxl-9 col-xl-8" id="chat-window-container">
        <div class="card shadow-sm border-0 h-100 mb-0" data-controller="chat" data-chat-id-value="<%= @conversation.id %>">
            
            <div class="card-header border-bottom border-dashed py-3 bg-white">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="d-flex align-items-center">
                        <div class="avatar-sm me-2">
                            <% if @conversation.is_group? %>
                                <span class="avatar-title rounded-circle bg-warning text-white font-16 shadow-sm"><i class="ri-group-fill"></i></span>
                            <% else %>
                                <% if @chat_partner&.avatar&.attached? %>
                                    <%= image_tag url_for(@chat_partner.avatar), class: "rounded-circle", height: "36", width: "36", style: "object-fit: cover;" %>
                                <% else %>
                                    <span class="avatar-title rounded-circle bg-info text-white font-14 fw-bold"><%= @chat_partner&.first_name&.at(0) %></span>
                                <% end %>
                            <% end %>
                        </div>
                        <div>
                            <h5 class="mt-0 mb-0 font-15 fw-bold"><%= @conversation.is_group? ? @conversation.name : @chat_partner&.full_name %></h5>
                            <p class="mt-1 lh-1 mb-0 text-muted font-12">
                                <%= @conversation.is_group? ? "#{@conversation.users.count} participantes" : @chat_partner&.role&.humanize %>
                            </p>
                        </div>
                    </div>

                    <%# Buscador de mensajes %>
                    <%= form_with url: client_conversation_messages_path(@client, @conversation), method: :get, html: { data: { chat_target: "searchForm" }, autocomplete: "off" } do |f| %>
                        <div class="input-group input-group-sm">
                            <%= f.search_field :q, class: "form-control border-light bg-light-subtle", placeholder: "Buscar mensaje...", data: { action: "input->chat#search" } %>
                            <span class="input-group-text bg-light border-light text-muted"><i class="ri-search-line"></i></span>
                        </div>
                    <% end %>
                </div>
            </div>
        
            <div class="card-body p-0">
                <ul class="conversation-list px-3 py-3 chat-conversation" data-chat-target="messages" style="height: 550px; overflow-y: auto;" data-simplebar>
                    <%= render partial: "message", collection: @messages, as: :msg, locals: { client: @client, conversation: @conversation } %>
                </ul>
            </div>

            <div class="card-body bg-light border-top">
                <div id="attachment-preview" data-chat-target="preview" class="d-flex flex-wrap gap-2 mb-2"></div>
                <%= form_with(model: [@client, @conversation, @message], data: { chat_target: "form", action: "submit->chat#send" }) do |f| %>
                    <div class="d-flex align-items-center">
                        <%= f.file_field :attachments, multiple: true, class: "d-none", id: "chat-file", data: { action: "change->chat#previewFiles" } %>
                        <label for="chat-file" class="btn btn-light mb-0 me-2 shadow-none border-0 bg-white"><i class="ri-attachment-2 font-18"></i></label>
                        <%= f.text_field :body, class: "form-control border-0 shadow-none bg-white", placeholder: "Escribe un mensaje...", data: { chat_target: "input" }, autocomplete: "off" %>
                        <button type="submit" class="btn btn-primary ms-2 shadow-none"><i class='ri-send-plane-2-fill'></i></button>
                    </div>
                <% end %>
            </div>
        </div>
    </div>
</div>

<%# --- MODAL NUEVO GRUPO --- %>
<div class="modal fade" id="newGroupModal" tabindex="-1">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title font-15"><i class="ri-group-add-line me-1"></i> Crear Grupo</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <%= form_with url: create_group_client_conversations_path(@client), method: :post do |f| %>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label font-12 fw-bold">Nombre del Grupo</label>
                        <%= f.text_field :group_name, class: "form-control form-control-sm", required: true, placeholder: "Ej. Equipo Comercial" %>
                    </div>
                    <label class="form-label font-12 fw-bold">Seleccionar Miembros</label>
                    <div class="bg-light p-2 rounded border" style="max-height: 200px; overflow-y: auto;">
                        <% @company_users.each do |user| %>
                            <div class="form-check mb-1">
                                <input class="form-check-input" type="checkbox" name="user_ids[]" value="<%= user.id %>" id="u_<%= user.id %>">
                                <label class="form-check-label font-13" for="u_<%= user.id %>"><%= user.full_name %></label>
                            </div>
                        <% end %>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <%= f.submit "Crear Chat Grupal", class: "btn btn-primary w-100 btn-sm shadow-none" %>
                </div>
            <% end %>
        </div>
    </div>
</div>

<style>
    .chat-row .btn-delete-sidebar { opacity: 0; transition: all 0.2s; position: absolute; right: 5px; z-index: 5; }
    .chat-row:hover .btn-delete-sidebar { opacity: 1; }
    .active-chat { background-color: rgba(62, 96, 213, 0.08) !important; }
    .user-presence-dot { position: absolute; bottom: 0; right: 0; width: 10px; height: 10px; }
    .chat-conversation .simplebar-content { display: flex; flex-direction: column; }
</style>

<script>
    function filterContacts() {
        const filter = document.getElementById('contact-search').value.toLowerCase();
        document.querySelectorAll('.contact-item').forEach(item => {
            const name = item.getAttribute('data-name');
            item.closest('.chat-row').style.display = name.includes(filter) ? "" : "none";
        });
    }
</script>