<%# app/views/messages/index.html.erb %>

<div class="row">
    <% if current_user.role == "admin" %>
        <div class="col-12">
            <div class="page-title-box">
                <div class="page-title-right">
                    <ol class="breadcrumb m-0">
                        <li class="breadcrumb-item"><a href="<%= root_path %>">Consilium</a></li>
                        <li class="breadcrumb-item"><a href="<%= clients_path %>">Clientes</a></li>
                        <li class="breadcrumb-item"><%= link_to @client.company_name, client_path(@client) %> </li>
                        <li class="breadcrumb-item">Chat</li>                 
                    </ol>
                </div>
                <h4 class="page-title">Conversación con:</h4>
            </div>
        </div>
    <% else %>
        <div class="col-12">
            <div class="page-title-box">
                <div class="page-title-right">
                    <ol class="breadcrumb m-0">
                        <li class="breadcrumb-item"><a href="<%= client_dashboard_path %>">Consilium</a></li>
                        <li class="breadcrumb-item"><a href="<%= client_dashboard_path %>">Regresar al Dashboard</a></li>                  
                    </ol>
                </div>
                <h4 class="page-title">Conversación con:</h4>
            </div>
        </div>
    <% end %>
</div>

<%# Calculamos quién es la "otra persona" %>
<% other_user = (@conversation.sender == current_user) ? @conversation.recipient : @conversation.sender %>

<div class="row">
    <div class="col-12">
        <div class="card h-100 overflow-hidden mb-0" 
             data-controller="chat" 
             data-chat-id-value="<%= @conversation.id %>">
             
            <div class="card-header border-bottom border-dashed">
                <div class="d-flex align-items-center gap-2">
                    <div class="d-flex align-items-center me-auto">
                        <%= link_to client_path(@client), class: "btn btn-light btn-sm px-2 me-3 d-inline-flex" do %>
                            <i class="mdi mdi-arrow-left font-18"></i>
                        <% end %>

                        <div class="d-flex align-items-center">
                            <% if other_user.avatar.attached? %>
                                <%= image_tag url_for(other_user.avatar), class: "me-2 rounded-circle", height: "36", width: "36", style: "object-fit: cover;" %>
                            <% else %>
                                <div class="avatar-sm me-2">
                                    <span class="avatar-title rounded-circle bg-primary text-white font-14">
                                        <%= other_user.first_name[0] %>
                                    </span>
                                </div>
                            <% end %>
                        
                            <div>
                                <h5 class="mt-0 mb-0 font-15">
                                    <%= link_to "#{other_user.first_name} #{other_user.last_name}", user_path(other_user), class: "text-reset" %>
                                </h5>
                                <p class="mt-1 lh-1 mb-0 text-muted font-12">
                                    <small class="mdi mdi-circle text-success"></small> <%= other_user.role&.humanize %>
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex align-items-center gap-2">
                        

                        <%= form_with url: client_conversation_messages_path(@client, @conversation), 
                                    method: :get, 
                                    html: { 
                                        data: { chat_target: "searchForm" }, 
                                        class: "d-flex",
                                        autocomplete: "off" # Desactiva el autocompletado a nivel formulario
                                    } do |f| %>
                            
                            <div class="input-group input-group-sm">
                                <%= f.search_field :q, 
                                    value: params[:q], 
                                    class: "form-control border-light bg-light-subtle", 
                                    placeholder: "Buscar mensaje, archivo, fecha o usuario...", 
                                    style: "width: 350px;",
                                    id: "query_field_#{SecureRandom.hex(4)}",
                                    # --- TRUCO MAESTRO PARA ELIMINAR SUGERENCIAS ---
                                    # Usar 'new-password' suena contradictorio, pero es lo que Chrome respeta mejor 
                                    # para decir "no me sugieras nada de lo que ya tienes guardado".
                                    autocomplete: "new-password", 
                                    
                                    data: { 
                                        chat_target: "searchInput",
                                        action: "input->chat#search",
                                        "ms-editor": "false",       # Bloquea Microsoft Editor (Causa de tus errores)
                                        "lpignore": "true",         # Bloquea LastPass
                                        "form-type": "other"        # Indica que no es un campo de datos personales
                                    },

                                    # --- OTROS BLOQUEOS ---
                                    spellcheck: "false",
                                    autocorrect: "off",
                                    autocapitalize: "none" %>

                                <div class="input-group-text bg-light border-light text-muted">
                                    <i class="ri-search-line font-16"></i>
                                </div>
                            </div>
                        <% end %>
                    </div>
                </div>
            </div>
        
            <div class="card-body p-0 pt-3">
                <%# Agregamos data-chat-target="messages" %>
                <ul class="conversation-list px-3 chat-conversation" 
                    data-chat-target="messages"
                    style="max-height: 600px; overflow-y: auto;">
                    
                    <% @messages.each do |msg| %>
                        <%= render "message", msg: msg, client: @client, conversation: @conversation %>
                    <% end %>
                </ul>
            </div>

            <% is_participant = (@conversation.sender == current_user || @conversation.recipient == current_user) %>
            <% is_admin = current_user.role == 'admin' %>

            <% if is_participant || is_admin %>
                <div class="card-body bg-light bg-opacity-50 border-top">
                    <%# Target para mostrar las etiquetas de archivos seleccionados %>
                    <div id="attachment-preview" 
                         data-chat-target="preview" 
                         class="d-flex flex-wrap gap-2 mb-2"></div>

                    <%= form_with(model: [@client, @conversation, @message], 
                                  local: true, 
                                  html: { 
                                      class: "needs-validation", 
                                      id: "chat-form",
                                      data: { 
                                        action: "submit->chat#send",
                                        chat_target: "form" 
                                      } 
                                  }) do |f| %>
                        <div class="d-flex align-items-center">
                            <%# Área de Adjuntos %>
                            <div class="me-2">
                                <label for="chat-attachment" class="btn btn-light mb-0 cursor-pointer text-muted shadow-none border-0" title="Adjuntar archivos">
                                    <i class="ri-attachment-2 font-20"></i>
                                </label>
                                <%# File field con targets y acciones para el controlador %>
                                <%= f.file_field :attachments, 
                                                multiple: true, 
                                                class: "d-none", 
                                                id: "chat-attachment",
                                                data: { 
                                                    chat_target: "fileInput",
                                                    action: "change->chat#previewFiles" 
                                                } %>
                            </div>

                            <%# Input de Texto %>
                            <div class="w-100 me-2">
                                <%= f.text_field :body, 
                                    class: "form-control border-0 bg-white", 
                                    placeholder: "Escribe tu mensaje aquí...", 
                                    autocomplete: "off",
                                    data: { chat_target: "input" } %>
                            </div>

                            <%# Botón Enviar %>
                            <div class="btn-group">
                                <button type="submit" class="btn btn-success chat-send">
                                    <i class='ri-send-plane-2-line'></i>
                                </button>
                            </div>
                        </div>
                    <% end %>
                </div>
            <% else %>
                <div class="alert alert-warning mt-2 text-center mx-3 mb-3">
                    <i class="mdi mdi-lock"></i> Solo lectura. No participas en este chat.
                </div>
            <% end %>
        </div>
    </div>
</div>