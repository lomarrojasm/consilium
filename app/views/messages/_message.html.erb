<% current_user_id = defined?(current_user) && current_user ? current_user.id : nil %>
<% is_admin = defined?(current_user) && current_user ? current_user.role == 'admin' : false %>
<% is_msg_owner = current_user_id == msg.user_id %>

<li class="clearfix <%= 'odd' if is_msg_owner %>" id="message-<%= msg.id %>" data-sender-id="<%= msg.user.id %>">
    <div class="chat-avatar">
        <% if msg.user.avatar.attached? %>
            <%= image_tag url_for(msg.user.avatar), class: "rounded-circle border-0", style: "width: 40px; height: 40px; object-fit: cover;" %>
        <% else %>
             <div class="avatar-xs">
                <span class="avatar-title rounded-circle bg-soft-primary text-primary font-12 fw-bold" style="width: 40px; height: 40px;">
                    <%= msg.user.first_name[0] %><%= msg.user.last_name[0] %>
                </span>
            </div>
        <% end %>
    </div>
    
    <div class="conversation-text">
        <div class="ctext-wrap">
            <div class="d-flex justify-content-between align-items-start mb-1" style="min-width: 180px;">
                <i class="fw-bold font-13 text-primary"><%= msg.user.first_name %></i>
                <div class="text-end ms-3">
                    <small class="text-muted d-block font-10"><%= msg.messaged_at.strftime("%d/%m/%Y") %></small>
                    <small class="text-muted d-block font-11 fw-semibold"><%= msg.messaged_at.strftime("%H:%M") %></small>
                </div>
            </div>
            
            <% if msg.body.present? %>
              <p class="mb-0"><%= defined?(params) && params[:q].present? ? highlight(msg.body, params[:q]) : msg.body %></p>
            <% end %>

            <% if msg.attachments.attached? %>
              <div class="row mt-2 g-2">
                <% msg.attachments.each do |attachment| %>
                  <div class="col-12">
                    <% if attachment.image? %>
                        <%= link_to url_for(attachment), target: "_blank", class: "d-block" do %>
                          <%= image_tag attachment.variant(resize_to_limit: [400, 400]), class: "img-fluid rounded border shadow-sm" %>
                        <% end %>
                    <% else %>
                      <div class="card mb-1 shadow-none border border-light bg-light bg-opacity-50">
                        <div class="p-2 d-flex align-items-center">
                            <i class="ri-file-text-line font-20 me-2"></i>
                            <div class="overflow-hidden me-auto">
                              <span class="text-dark fw-bold font-12 d-block text-truncate"><%= attachment.filename %></span>
                            </div>
                            <%= link_to rails_blob_path(attachment, disposition: "attachment"), class: "btn btn-link p-0 ms-2" do %>
                                <i class="ri-download-2-line font-18 text-muted"></i>
                            <% end %>
                        </div>
                      </div>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>
        </div>

        <div class="collapse mt-2 admin-only" id="edit-date-<%= msg.id %>" style="<%= 'display:none' unless is_admin %>">
            <%= form_with(model: [client, conversation, msg], local: true, class: "d-flex align-items-center bg-light p-1 rounded") do |f| %>
                <%= f.datetime_field :messaged_at, id: "dt_#{msg.id}", class: "form-control form-control-sm me-1", style: "font-size: 10px;" %>
                <button type="submit" class="btn btn-xs btn-success"><i class="ri-check-line"></i></button>
            <% end %>
        </div>
    </div>

    <div class="conversation-actions dropdown">
        <button class="btn btn-sm btn-link text-muted shadow-none" data-bs-toggle="dropdown" type="button">
            <i class='ri-more-2-fill'></i>
        </button>
        <div class="dropdown-menu dropdown-menu-end shadow border-0">
            <a class="dropdown-item py-2 admin-only-link" href="javascript:void(0);" data-bs-toggle="collapse" data-bs-target="#edit-date-<%= msg.id %>">
                <i class="ri-calendar-event-line me-2 text-primary"></i> Cambiar Fecha
            </a>
            <%= link_to client_conversation_message_path(client, conversation, msg), 
                        class: "dropdown-item py-2 text-danger",
                        data: { action: "click->chat#deleteMessage", message_id: msg.id } do %>
                <i class="ri-delete-bin-line me-2"></i> Eliminar Mensaje
            <% end %>
        </div>
    </div>
</li>