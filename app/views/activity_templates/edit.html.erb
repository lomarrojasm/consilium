<%# app/views/activity_templates/edit.html.erb %>
<div class="row wrapper border-bottom white-bg page-heading">
  <div class="col-lg-10">
    <h2>Editar Tarea: <%= @activity_template.name %></h2>
    <ol class="breadcrumb">
      <li class="breadcrumb-item"><%= link_to "Plantillas", project_templates_path %></li>
      <li class="breadcrumb-item"><%= link_to @activity_template.stage_template.project_template.name, @activity_template.stage_template.project_template %></li>
      <li class="breadcrumb-item active"><strong>Editar Tarea</strong></li>
    </ol>
  </div>
</div>

<div class="wrapper wrapper-content animated fadeInRight">
  <div class="row">
    <div class="col-lg-12">
      <div class="ibox">
        <div class="ibox-content p-4">
          <%# Aquí reciclamos tu formulario pero sin formato de tabla %>
          <%= form_with(model: @activity_template, class: "row g-3") do |f| %>
            <div class="col-md-6">
              <label class="form-label fw-bold">Nombre</label>
              <%= f.text_field :name, class: "form-control" %>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-bold">Documento Ref.</label>
              <%= f.text_field :document_ref, class: "form-control" %>
            </div>
            
            <hr class="my-4">
            
            <div class="col-md-4">
              <label class="form-label text-muted">Horas Líder</label>
              <%= f.number_field :leader_hours, step: :any, class: "form-control" %>
            </div>
            <div class="col-md-4">
              <label class="form-label text-muted">Horas Senior</label>
              <%= f.number_field :senior_hours, step: :any, class: "form-control" %>
            </div>
            <div class="col-md-4">
              <label class="form-label text-muted">Horas Analista</label>
              <%= f.number_field :analyst_hours, step: :any, class: "form-control" %>
            </div>

            <hr class="my-4">

            <div class="col-md-4">
              <label class="form-label text-muted">Tarifa Líder</label>
              <%= f.number_field :leader_rate, class: "form-control" %>
            </div>
            <div class="col-md-4">
              <label class="form-label text-muted">Tarifa Senior</label>
              <%= f.number_field :senior_rate, class: "form-control" %>
            </div>

            <div class="col-md-4">
                <label class="form-label text-muted">Tarifa Analista</label>
                <%= f.number_field :analyst_rate, class: "form-control" %>
            </div>

            <div class="col-12 text-end pt-3">
              <%= link_to "Cancelar", @activity_template.stage_template.project_template, class: "btn btn-light" %>
              <%= f.submit "Guardar Cambios", class: "btn btn-primary shadow" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>