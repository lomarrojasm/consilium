<%# app/views/financials/show.html.erb %>

<% 
  # =========================================================================
  # CEREBRO FINANCIERO: Cálculo Global de Abonos y Pagos Totales
  # =========================================================================
  @activity_payments = Hash.new(0.0) 
  @payment_consumed = Hash.new(0.0)  

  @payments.each do |p|
    consumed = 0.0

    # 1. Pagos Completos (Etiqueta REF)
    ref_m = p.notes.to_s.match(/\[REF:\s*([\d,\s]+)\]/)
    if ref_m
      ref_m[1].split(',').map(&:to_i).each do |act_id|
         activity = @accruals_by_stage.values.flatten.find { |a| a.id == act_id }
         if activity
           @activity_payments[act_id] += activity.amount.to_f
           consumed += activity.amount.to_f
         end
      end
    end

    # 2. Pagos Parciales / Abonos (Etiqueta PARTIAL)
    part_m = p.notes.to_s.match(/\[PARTIAL:\s*(.+?)\]/)
    if part_m
      part_m[1].split(',').each do |pair|
        id_str, amt_str = pair.strip.split('_')
        if id_str && amt_str
           @activity_payments[id_str.to_i] += amt_str.to_f
           consumed += amt_str.to_f
        end
      end
    end

    # 3. Legado (Nombres viejos)
    if !ref_m && !part_m
       name_m = p.notes.to_s.match(/\[Pago:\s*(.+?)\]/)
       if name_m
         names = name_m[1].split(',').map(&:strip)
         @accruals_by_stage.values.flatten.each do |activity|
            if names.include?(activity.concept_name.strip)
               @activity_payments[activity.id] += activity.amount.to_f
               consumed += activity.amount.to_f
            end
         end
       end
    end

    @payment_consumed[p.id] = consumed.round(2)
  end

  # =========================================================================
  # CEREBRO DE COTIZACIONES: Identificar estatus de cobro
  # =========================================================================
  @quoted_items_status = {}
  QuotationItem.joins(:quotation)
               .where(quotations: { project_id: @project.id })
               .includes(:quotation)
               .each do |item|
    @quoted_items_status[item.financial_accrual_id] = { 
      status: item.quotation.status.to_s, 
      quotation_id: item.quotation.id 
    }
  end
%>

<div class="container-fluid py-4">
  
  <%# --- ENCABEZADO Y BREADCRUMBS --- %>
  <div class="row mb-4">
    <div class="col-12">
      <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
          <h4 class="mb-1 fw-bold text-dark">
            <i class="ri-wallet-3-line text-primary me-2"></i>Finanzas y Cobranza
          </h4>
          <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-0 font-13">
              <li class="breadcrumb-item"><%= link_to "Proyectos", client_projects_path(@client), class: "text-muted text-decoration-none" %></li>
              <li class="breadcrumb-item"><%= link_to @project.name, client_project_path(@client, @project), class: "text-muted text-decoration-none" %></li>
              <li class="breadcrumb-item active fw-bold" aria-current="page">Control Financiero</li>
            </ol>
          </nav>
        </div>

        <div class="d-flex align-items-center gap-2">
          <%= link_to client_project_path(@client, @project), class: "btn btn-soft-secondary btn-sm rounded-pill shadow-sm px-3 fw-medium" do %>
            <i class="ri-arrow-left-line me-1 align-middle"></i> Volver al Proyecto
          <% end %>

          <%= link_to client_project_billing_authorization_path(@client, @project), class: "btn btn-outline-primary shadow-sm rounded-pill font-13 fw-bold bg-white" do %>
            <i class="ri-shield-check-fill me-1 text-success"></i> Expediente Legal
          <% end %>

          <% if current_user.role == 'admin' && @accruals_by_stage.any? %>
            <% can_reset = @project.payments.empty? && @project.quotations.empty? %>
            
            <% if can_reset %>
              <%= button_to reset_template_client_project_financials_path(@client, @project), 
                  method: :delete, 
                  form: { style: "margin: 0;", data: { turbo_confirm: "⚠️ ¿Estás seguro? Esto borrará el presupuesto de devengos y pagos." } }, 
                  class: "btn btn-outline-danger btn-sm rounded-pill shadow-sm px-3" do %>
                <i class="ri-refresh-line me-1 align-middle"></i> Reiniciar Matriz
              <% end %>
            <% else %>
              <span tabindex="0" data-bs-toggle="tooltip" title="No se puede reiniciar: Existen cotizaciones o pagos vinculados a este presupuesto.">
                <button type="button" class="btn btn-outline-secondary btn-sm rounded-pill shadow-sm px-3" disabled style="pointer-events: none;">
                  <i class="ri-lock-line me-1 align-middle"></i> Matriz Bloqueada
                </button>
              </span>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <%# --- KPIs FINANCIEROS --- %>
  <% total_planned_amount = @accruals_by_stage.values.flatten.sum(&:amount) rescue 0 %>
  
  <div class="row mb-4">
    <div class="col-xl-3 col-md-6 mb-3 mb-xl-0">
      <div class="card shadow-sm border-0 border-start border-4 border-primary h-100">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <p class="text-muted text-uppercase font-11 fw-bold mb-1">Presupuesto Total</p>
              <h3 class="text-dark fw-bold mb-0"><%= number_to_currency(total_planned_amount) %></h3>
              <small class="text-muted font-12">Valor total del proyecto</small>
            </div>
            <div class="avatar-sm">
              <span class="avatar-title bg-primary-subtle text-primary rounded-circle font-24">
                <i class="ri-stack-line"></i>
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-3 mb-xl-0">
      <div class="card shadow-sm border-0 border-start border-4 border-info h-100">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <p class="text-muted text-uppercase font-11 fw-bold mb-1">Trabajo Devengado</p>
              <h3 class="text-dark fw-bold mb-0"><%= number_to_currency(@project.total_accrued) %></h3>
              <small class="text-muted font-12">Lo que el equipo ya trabajó</small>
            </div>
            <div class="avatar-sm">
              <span class="avatar-title bg-info-subtle text-info rounded-circle font-24">
                <i class="ri-briefcase-4-line"></i>
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-3 mb-xl-0">
      <div class="card shadow-sm border-0 border-start border-4 border-success h-100">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <p class="text-muted text-uppercase font-11 fw-bold mb-1">Cobranza Real</p>
              <h3 class="text-dark fw-bold mb-0"><%= number_to_currency(@project.total_paid) %></h3>
              <small class="text-muted font-12">Dinero ingresado a la cuenta</small>
            </div>
            <div class="avatar-sm">
              <span class="avatar-title bg-success-subtle text-success rounded-circle font-24">
                <i class="ri-money-dollar-circle-line"></i>
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <% balance = @project.financial_balance %>
    <% balance_color = balance < 0 ? 'danger' : (balance > 0 ? 'success' : 'secondary') %>
    <% balance_text = balance < 0 ? 'Saldo a favor (Adeudo)' : (balance > 0 ? 'Saldo a favor del Cliente' : 'Cuentas en cero') %>
    
    <div class="col-xl-3 col-md-6">
      <div class="card shadow-sm border-0 border-start border-4 border-<%= balance_color %> h-100">
        <div class="card-body p-4">
          <div class="d-flex justify-content-between align-items-center">
            <div>
              <p class="text-muted text-uppercase font-11 fw-bold mb-1">Balance General</p>
              <h3 class="text-<%= balance_color %> fw-bold mb-0"><%= number_to_currency(balance.abs) %></h3>
              <small class="text-muted font-12"><%= balance_text %></small>
            </div>
            <div class="avatar-sm">
              <span class="avatar-title bg-<%= balance_color %>-subtle text-<%= balance_color %> rounded-circle font-24">
                <i class="ri-scales-3-line"></i>
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <% if @accruals_by_stage.empty? %>
    <div class="card shadow-sm border-0 mb-4 bg-light">
      <div class="card-body text-center py-5">
        <div class="mb-3">
          <i class="ri-magic-line text-primary display-4"></i>
        </div>
        <h4 class="fw-bold text-dark">Control Financiero</h4>
        <% if current_user.role == 'admin' %>
          <p class="text-muted mx-auto" style="max-width: 500px;">
            Haz clic en el botón para sincronizar la matriz financiera con el plan de trabajo operativo.
          </p>
          <%= button_to generate_template_client_project_financials_path(@client, @project), 
              method: :post, class: "btn btn-primary rounded-pill px-4 py-2 mt-2 shadow", data: { turbo: false } do %>
            <i class="ri-refresh-line me-1"></i> Sincronizar Presupuesto Operativo
          <% end %>
        <% else %>
          <p class="text-muted mx-auto" style="max-width: 500px;">
            La matriz financiera aún no ha sido inicializada por el administrador.
          </p>
        <% end %>
      </div>
    </div>
  <% else %>

    <div class="row">
      <%# --- COLUMNA IZQUIERDA: PLAN DE DEVENGO Y COTIZACIONES --- %>
      <div class="col-lg-7">
        
        <%= form_with url: client_project_quotations_path(@client, @project), method: :post, local: true, id: "form-generate-quote" do |f| %>
          
          <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
              <div class="d-flex align-items-center">
                <h5 class="card-title mb-0 fw-bold"><i class="ri-task-line text-primary me-2"></i>Estado de Cuenta</h5>
                
                <% if current_user.role == 'admin' %>
                  <button type="submit" class="btn btn-sm btn-primary rounded-pill shadow-sm ms-3 scale-in" id="btn-generate-quote" disabled style="transition: all 0.2s;">
                    <i class="ri-file-list-3-line me-1"></i> Generar Cotización
                    <span id="quote-count-badge" class="badge bg-white text-primary ms-1" style="display:none;">0</span>
                  </button>
                <% end %>
              </div>

              <div class="input-group input-group-sm shadow-sm" style="max-width: 250px;">
                <span class="input-group-text bg-light border-end-0"><i class="ri-search-line text-muted"></i></span>
                <input type="text" id="global-activity-search" class="form-control border-start-0 bg-light" placeholder="Buscar actividad o monto...">
              </div>
            </div>

            <div class="card-body p-3">
              <div class="accordion" id="accrualsAccordion">
                <% @accruals_by_stage.sort_by { |stage_name, accruals_array| accruals_array.map(&:id).min }.each_with_index do |(stage, accruals), index| %>
                  
                  <% 
                    stage_total = accruals.sum(&:amount)
                    stage_paid = accruals.sum do |accrual|
                      [@activity_payments[accrual.id], accrual.amount.to_f].min 
                    end
                    stage_balance = stage_total - stage_paid
                  %>

                  <div class="accordion-item border mb-2 rounded shadow-none stage-accordion-item">
                    <h2 class="accordion-header" id="heading<%= index %>">
                      <button class="accordion-button <%= 'collapsed' if index > 0 %> fw-bold bg-light py-2" type="button" data-bs-toggle="collapse" data-bs-target="#collapse<%= index %>">
                        <span class="text-truncate me-2" style="max-width: 35%;"><%= stage %></span>
                        <div class="ms-auto d-flex text-end gap-3 gap-md-4 font-12 align-items-center me-2 me-md-4">
                          <div class="d-none d-sm-block">
                            <span class="d-block text-muted font-9 text-uppercase tracking-wider lh-1 mb-1">Total</span>
                            <span class="fw-bold text-dark lh-1"><%= number_to_currency(stage_total) %></span>
                          </div>
                          <div class="d-none d-sm-block border-start ps-3 ps-md-4">
                            <span class="d-block text-muted font-9 text-uppercase tracking-wider lh-1 mb-1">Pagado</span>
                            <span class="fw-bold text-success lh-1"><%= number_to_currency(stage_paid) %></span>
                          </div>
                          <div class="border-start-sm ps-sm-3 ps-md-4">
                            <span class="d-block text-muted font-9 text-uppercase tracking-wider lh-1 mb-1">Restante</span>
                            <span class="fw-bold <%= stage_balance > 0.01 ? 'text-primary' : 'text-muted' %> lh-1"><%= number_to_currency(stage_balance) %></span>
                          </div>
                        </div>
                      </button>
                    </h2>
                    <div id="collapse<%= index %>" class="accordion-collapse collapse <%= 'show' if index == 0 %>" data-bs-parent="#accrualsAccordion">
                      <div class="accordion-body p-0">
                        <table class="table table-hover table-centered mb-0 font-13">
                          <thead class="table-light">
                            <tr>
                              <th style="width: 5%;" class="text-center">
                                <i class="ri-checkbox-multiple-line text-muted" title="Seleccionar para cotizar" data-bs-toggle="tooltip"></i>
                              </th>
                              <th>Concepto</th>
                              <th class="text-end">Importe</th>
                              <th class="text-center">Estatus</th>
                            </tr>
                          </thead>
                          <tbody class="accrual-tbody">
                            <% accruals.sort_by(&:id).each do |accrual| %>
                              <% 
                                 paid = @activity_payments[accrual.id]
                                 cost = accrual.amount.to_f
                                 is_fully_paid = paid >= (cost - 0.01)
                                 is_partially_paid = paid > 0.01 && !is_fully_paid
                                 
                                 quote_info = @quoted_items_status[accrual.id]
                                 is_quoted = quote_info.present?
                                 quote_status = is_quoted ? quote_info[:status] : nil
                                 
                                 can_be_quoted = current_user.role == 'admin' && accrual.status == 'accrued' && !is_fully_paid && !is_quoted
                              %>
                              
                              <tr class="accrual-row <%= 'bg-light bg-opacity-50' if accrual.status == 'accrued' && is_fully_paid %>">
                                
                                <td class="text-center align-middle">
                                  <% if can_be_quoted %>
                                    <div class="form-check d-flex justify-content-center m-0 p-0">
                                      <input type="checkbox" name="accrual_ids[]" value="<%= accrual.id %>" class="form-check-input quote-checkbox border-secondary cursor-pointer" style="width: 18px; height: 18px;" title="Seleccionar para cotizar">
                                    </div>
                                  <% end %>
                                </td>

                                <td class="fw-medium text-dark accrual-concept" style="max-width: 250px; white-space: normal;">
                                  <%= accrual.concept_name %>
                                </td>
                                <td class="text-end fw-bold text-dark accrual-amount">
                                  <%= number_to_currency(cost) %>
                                </td>
                                <td class="text-center">
                                <% if ['accrued', 'invoiced'].include?(accrual.status) %>
                                  <% if is_fully_paid %>
                                    <span class="badge bg-primary text-white rounded-pill px-2 py-1 shadow-sm">
                                      <i class="ri-check-double-line me-1"></i>Pagado
                                    </span>
                                  <% elsif is_partially_paid %>
                                    <span class="badge bg-warning text-dark border border-warning rounded-pill px-2 py-1 shadow-sm" title="Abono de <%= number_to_currency(paid) %>">
                                      <i class="ri-pie-chart-2-line me-1"></i>Abono
                                    </span>
                                  <% elsif is_quoted %>
                                    <% if quote_status == 'pagado' %>
                                      <%= link_to client_project_quotation_path(@client, @project, quote_info[:quotation_id]), class: "badge bg-primary text-white rounded-pill px-2 py-1 shadow-sm text-decoration-none hover-primary" do %>
                                        <i class="ri-checkbox-circle-fill me-1"></i>Liquidado
                                      <% end %>
                                    <% elsif quote_status == 'facturado' %>
                                      <%= link_to client_project_quotation_path(@client, @project, quote_info[:quotation_id]), class: "badge bg-success text-white rounded-pill px-2 py-1 shadow-sm text-decoration-none hover-primary" do %>
                                        <i class="ri-file-paper-2-line me-1"></i>Facturado
                                      <% end %>
                                    <% elsif quote_status == 'aceptado' %>
                                      <%= link_to client_project_quotation_path(@client, @project, quote_info[:quotation_id]), class: "badge bg-warning text-dark border border-warning rounded-pill px-2 py-1 shadow-sm text-decoration-none hover-primary" do %>
                                        <i class="ri-bill-line me-1"></i>Listo p/Facturar
                                      <% end %>
                                    <% else %>
                                      <%= link_to client_project_quotation_path(@client, @project, quote_info[:quotation_id]), class: "badge bg-info-subtle text-info border border-info-subtle rounded-pill px-2 py-1 text-decoration-none hover-primary" do %>
                                        <i class="ri-file-list-3-line me-1"></i>Cotizado
                                      <% end %>
                                    <% end %>
                                  <% else %>
                                    <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-2 py-1">
                                      <i class="ri-check-line me-1"></i>Devengado
                                    </span>
                                  <% end %>
                                <% else %>
                                  <span class="badge bg-light text-secondary rounded-pill px-2 py-1 border">Pendiente</span>
                                <% end %>
                              </td>
                              </tr>
                            <% end %>
                          </tbody>
                        </table>
                      </div>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>

      <%# --- COLUMNA DERECHA: HISTORIAL DE PAGOS --- %>
      <div class="col-lg-5">
        <div class="card shadow-sm border-0">
          <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
            <h5 class="card-title mb-0 fw-bold"><i class="ri-bank-card-line text-success me-2"></i>Historial de Pagos</h5>
            <% if current_user.role == 'admin' %>
              <button class="btn btn-sm btn-success rounded-pill shadow-sm" data-bs-toggle="modal" data-bs-target="#newPaymentModal">
                <i class="ri-add-line me-1"></i> Registrar Ingreso
              </button>
            <% end %>
          </div>
          
          <div class="card-body p-0">
            <% if @payments.any? %>
              <div class="list-group list-group-flush">
                <% @payments.each do |payment| %>
                  
                  <% 
                    available_amount = (payment.amount.to_f - @payment_consumed[payment.id]).round(2)
                  %>

                  <div class="list-group-item p-3">
                    <div class="d-flex justify-content-between align-items-start mb-1">
                      <div>
                        <h4 class="text-success fw-bold m-0"><%= number_to_currency(payment.amount) %></h4>
                        <span class="badge bg-light text-dark border font-11"><%= payment.payment_date.strftime("%d %b, %Y") %></span>
                      </div>
                      
                      <% if current_user.role == 'admin' %>
                        <div class="d-flex gap-1">
                          <button class="btn btn-xs btn-outline-primary" data-bs-toggle="modal" data-bs-target="#editPaymentModal<%= payment.id %>" title="Editar">
                            <i class="ri-pencil-line"></i>
                          </button>
                          <%= button_to destroy_payment_client_project_financials_path(@client, @project, payment_id: payment.id), 
                              method: :delete, 
                              form: { style: "display: inline-block;", data: { turbo_confirm: "¿Eliminar este pago del historial?" } }, 
                              class: "btn btn-xs btn-outline-danger", title: "Eliminar" do %>
                            <i class="ri-delete-bin-line"></i>
                          <% end %>
                        </div>
                      <% end %>
                    </div>
                    
                    <% if available_amount > 0.01 %>
                      <div class="mt-2 mb-1">
                        <span class="badge bg-info-subtle text-info border border-info-subtle px-2 py-1 font-11 shadow-sm">
                          <i class="ri-wallet-3-line me-1"></i> Disponible por asignar: <%= number_to_currency(available_amount) %>
                        </span>
                      </div>
                    <% end %>

                    <div class="mt-2 text-muted font-12 bg-light p-2 rounded">
                      <% if payment.invoice_number.present? %>
                        <strong>Folio:</strong> <%= payment.invoice_number %> <br>
                      <% end %>
                      <%= payment.notes %>
                    </div>
                    
                    <% if payment.receipt.attached? %>
                      <div class="mt-2">
                        <%= link_to rails_blob_path(payment.receipt, disposition: "attachment"), class: "btn btn-xs btn-secondary rounded-pill font-11" do %>
                          <i class="ri-attachment-line me-1"></i> Descargar Comprobante
                        <% end %>
                      </div>
                    <% end %>
                  </div>

                  <% if current_user.role == 'admin' %>
                    <%= render partial: "payment_modal", locals: { modal_id: "editPaymentModal#{payment.id}", payment: payment, title: "Editar Ingreso", url: update_payment_client_project_financials_path(@client, @project, payment_id: payment.id), method: :patch } %>
                  <% end %>

                <% end %>
              </div>
            <% else %>
              <div class="text-center py-5 text-muted">
                <i class="ri-wallet-3-line display-4 opacity-50 mb-2"></i>
                <p class="mb-0">Aún no hay pagos registrados.</p>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>

<% if current_user.role == 'admin' %>
  <%= render partial: "payment_modal", locals: { modal_id: "newPaymentModal", payment: Payment.new, title: "Registrar Nuevo Ingreso", url: create_payment_client_project_financials_path(@client, @project), method: :post } %>
<% end %>

<% content_for :javascript do %>
  <script>
    document.addEventListener("turbo:load", function() {
      // BUSCADOR GLOBAL
      const globalSearch = document.getElementById('global-activity-search');
      if (globalSearch) {
        globalSearch.addEventListener('input', function() {
          const searchTerm = this.value.toLowerCase();
          document.querySelectorAll('.stage-accordion-item').forEach(accordionItem => {
            let hasVisibleRows = false;
            const rows = accordionItem.querySelectorAll('.accrual-row');
            const collapsePanel = accordionItem.querySelector('.accordion-collapse');
            
            rows.forEach(row => {
              if (row.textContent.toLowerCase().includes(searchTerm)) {
                row.style.display = '';
                hasVisibleRows = true;
              } else {
                row.style.display = 'none';
              }
            });
            
            if (hasVisibleRows || searchTerm === '') {
              accordionItem.style.display = '';
              if (searchTerm !== '' && collapsePanel && !collapsePanel.classList.contains('show')) {
                 new bootstrap.Collapse(collapsePanel, { toggle: false }).show();
              }
            } else {
              accordionItem.style.display = 'none';
            }
          });
        });
      }

      // BOTÓN GENERAR COTIZACIÓN
      const quoteCheckboxes = document.querySelectorAll('.quote-checkbox');
      const btnGenerateQuote = document.getElementById('btn-generate-quote');
      const quoteCountBadge = document.getElementById('quote-count-badge');

      if (quoteCheckboxes.length > 0 && btnGenerateQuote) {
        quoteCheckboxes.forEach(cb => {
          cb.addEventListener('change', function() {
            const checkedCount = document.querySelectorAll('.quote-checkbox:checked').length;
            btnGenerateQuote.disabled = checkedCount === 0;
            
            if (quoteCountBadge) {
              quoteCountBadge.innerText = checkedCount;
              quoteCountBadge.style.display = checkedCount > 0 ? 'inline-block' : 'none';
            }
          });
        });
      }

      // MODAL PAGOS
      function initPaymentModals() {
        document.querySelectorAll('.payment-form-container').forEach(container => {
          const typeRadios = container.querySelectorAll('.payment-type-radio');
          const activitiesBox = container.querySelector('.specific-activities-box');
          const checkboxes = container.querySelectorAll('.activity-checkbox');
          const amountInput = container.querySelector('.payment-amount-input');
          const notesInput = container.querySelector('.payment-notes-input');
          const searchInput = container.querySelector('.activity-search-input');
          const autoApplyBtns = container.querySelectorAll('.auto-apply-btn');
          const balanceBox = container.querySelector('.general-payment-balance-box');
          const balanceText = container.querySelector('.payment-remaining-balance');
          const balanceContainerNode = balanceBox ? balanceBox.querySelector('.balance-container') : null;
          
          let currentMode = 'specific'; 

          function updateMode() {
            const checkedRadio = container.querySelector('.payment-type-radio:checked');
            if(checkedRadio) {
              currentMode = checkedRadio.value;
              if (activitiesBox) activitiesBox.style.display = 'block';
              
              if(currentMode === 'specific') {
                if (amountInput) {
                  amountInput.readOnly = true;
                  amountInput.classList.remove('bg-white');
                  amountInput.classList.add('bg-light');
                }
                if (balanceBox) balanceBox.style.display = 'none'; 
                autoApplyBtns.forEach(btn => btn.style.display = 'none');
                calculateSum(); 
              } else {
                if (amountInput) {
                  amountInput.readOnly = false;
                  amountInput.classList.remove('bg-light');
                  amountInput.classList.add('bg-white');
                }
                if (balanceBox) balanceBox.style.display = 'block'; 
                autoApplyBtns.forEach(btn => btn.style.display = 'inline-block');
                calculateSum(false); 
              }
            }
          }

          function getCheckedTotal() {
            let total = 0;
            checkboxes.forEach(cb => {
              if(cb.checked) {
                let cost = parseFloat(cb.dataset.amount || 0);
                let applied = parseFloat(cb.dataset.applied || cost);
                total += applied;
              }
            });
            return Math.round(total * 100) / 100;
          }

          function calculateSum(updateAmount = true) {
            let total = getCheckedTotal();
            let selectedNames = [];
            let full_ids = [];
            let partial_pairs = [];

            checkboxes.forEach(cb => {
              if(cb.checked) {
                selectedNames.push(cb.value);
                let originalCost = parseFloat(cb.dataset.originalAmount || cb.dataset.amount);
                let applied = parseFloat(cb.dataset.applied || originalCost);
                
                if (Math.abs(applied - originalCost) < 0.01) {
                  full_ids.push(cb.dataset.id);
                } else {
                  partial_pairs.push(`${cb.dataset.id}_${applied.toFixed(2)}`);
                }
              }
            });

            if(updateAmount && currentMode === 'specific' && amountInput) {
              amountInput.value = total > 0 ? total.toFixed(2) : '';
            }

            if (currentMode === 'general' && balanceText && amountInput && balanceContainerNode) {
              let limit = parseFloat(amountInput.value) || 0;
              limit = Math.round(limit * 100) / 100;
              let remaining = Math.round((limit - total) * 100) / 100;
              
              const balanceLabel = balanceContainerNode.querySelector('span:first-child');
              
              if (remaining === 0 && limit > 0) {
                balanceLabel.innerHTML = '<i class="ri-check-double-line me-1"></i> Pago cuadrado:';
                balanceText.innerText = '$0.00';
                balanceContainerNode.className = 'balance-container d-flex justify-content-between align-items-center bg-success-subtle text-success px-3 py-2 rounded border border-success-subtle transition-all';
              } else if (remaining < 0) {
                balanceLabel.innerHTML = '<i class="ri-error-warning-line me-1"></i> Monto excedido:';
                balanceText.innerText = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(remaining);
                balanceContainerNode.className = 'balance-container d-flex justify-content-between align-items-center bg-danger-subtle text-danger px-3 py-2 rounded border border-danger-subtle transition-all';
              } else {
                balanceLabel.innerHTML = '<i class="ri-wallet-3-line me-1"></i> Saldo por asignar:';
                balanceText.innerText = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(remaining);
                balanceContainerNode.className = 'balance-container d-flex justify-content-between align-items-center bg-info-subtle text-info px-3 py-2 rounded border border-info-subtle transition-all';
              }
            }

            if (notesInput) {
              let oldNotes = notesInput.value
                 .replace(/\[REF: .*?\]\n?/g, '')
                 .replace(/\[PARTIAL: .*?\]\n?/g, '')
                 .replace(/\[Pago: .*?\]\n?/g, '')
                 .replace(/\[.*?\]\n?/g, '').trim();
              
              if(selectedNames.length > 0) {
                let refStr = full_ids.length > 0 ? `[REF: ${full_ids.join(',')}]\n` : '';
                let partStr = partial_pairs.length > 0 ? `[PARTIAL: ${partial_pairs.join(',')}]\n` : '';
                notesInput.value = `${refStr}${partStr}[Pago: ${selectedNames.join(', ')}]\n${oldNotes}`.trim();
              } else {
                const checkedRadio = container.querySelector('.payment-type-radio:checked');
                let prefix = checkedRadio && checkedRadio.nextElementSibling ? checkedRadio.nextElementSibling.innerText.trim() : 'Pago';
                notesInput.value = `[${prefix}]\n${oldNotes}`.trim();
              }
            }
          }

          typeRadios.forEach(radio => radio.addEventListener('change', updateMode));

          checkboxes.forEach(cb => {
            cb.addEventListener('change', function(e) {
              if (currentMode === 'specific') {
                this.dataset.applied = this.dataset.amount; 
                calculateSum();
              } else {
                if (!this.checked) {
                  this.dataset.applied = this.dataset.amount; 
                  calculateSum(false);
                  return;
                }

                let total = getCheckedTotal();
                let limit = parseFloat(amountInput.value) || 0;
                limit = Math.round(limit * 100) / 100;
                
                if (limit === 0) {
                    if(typeof Swal !== 'undefined') Swal.fire({icon:'warning', title:'Aviso', text:'Primero ingresa el monto total del pago general.', confirmButtonColor: '#fa5c7c'});
                    else alert("Primero ingresa el monto total del pago general.");
                    this.checked = false;
                    return;
                }

                if (total > (limit + 0.01)) { 
                  let cost = parseFloat(this.dataset.amount);
                  let excess = total - limit;
                  let availableForThis = Math.round((cost - excess) * 100) / 100;

                  this.checked = false; 
                  calculateSum(false);

                  if (availableForThis > 0.01) {
                      let msg = `El saldo disponible ($${availableForThis}) no cubre el costo pendiente de la actividad ($${cost}). ¿Deseas aplicar el saldo como un ABONO PARCIAL?`;
                      
                      if(typeof Swal !== 'undefined') {
                          Swal.fire({
                              title: 'Abono Parcial',
                              text: msg,
                              icon: 'question',
                              showCancelButton: true,
                              confirmButtonText: 'Sí, aplicar abono',
                              cancelButtonText: 'Cancelar',
                              confirmButtonColor: '#10c469',
                              cancelButtonColor: '#6c757d'
                          }).then((result) => {
                              if (result.isConfirmed) {
                                  this.checked = true;
                                  this.dataset.applied = availableForThis;
                                  calculateSum(false);
                              }
                          });
                      } else {
                          if (confirm(msg)) {
                              this.checked = true;
                              this.dataset.applied = availableForThis;
                              calculateSum(false);
                          }
                      }
                  } else {
                      if(typeof Swal !== 'undefined') Swal.fire({icon: 'error', title: 'Límite Excedido', text: 'No queda saldo disponible en este pago.', confirmButtonColor: '#fa5c7c'});
                      else alert("No queda saldo disponible en este pago general.");
                  }
                } else {
                  this.dataset.applied = this.dataset.amount; 
                  calculateSum(false);
                }
              }
            });
          });

          autoApplyBtns.forEach(btn => {
            btn.addEventListener('click', function(e) {
              e.preventDefault();
              let limit = parseFloat(amountInput.value) || 0;
              limit = Math.round(limit * 100) / 100;
              
              if (limit <= 0) {
                if(typeof Swal !== 'undefined') Swal.fire({icon:'warning', title:'Aviso', text:'Ingresa un monto válido primero.', confirmButtonColor: '#fa5c7c'});
                else alert("Ingresa un monto válido primero.");
                return;
              }

              let total = getCheckedTotal();
              let remaining = Math.round((limit - total) * 100) / 100;

              if (remaining <= 0) {
                if(typeof Swal !== 'undefined') Swal.fire({icon:'warning', title:'Saldo agotado', text:'No tienes saldo suficiente para asignar.', confirmButtonColor: '#fa5c7c'});
                else alert('No hay saldo suficiente.');
                return;
              }

              const stageGroup = this.closest('.stage-group');
              const stageCheckboxes = stageGroup.querySelectorAll('.activity-checkbox:not(:disabled):not(:checked)');
              
              let appliedFull = false;
              let nextPartialCb = null;

              stageCheckboxes.forEach(cb => {
                if (remaining > 0.01) {
                  let cost = parseFloat(cb.dataset.amount || 0);
                  cost = Math.round(cost * 100) / 100;
                  
                  if (remaining >= (cost - 0.01)) { 
                    cb.checked = true;
                    cb.dataset.applied = cost;
                    remaining = Math.round((remaining - cost) * 100) / 100;
                    appliedFull = true;
                  } else if (!nextPartialCb) {
                    nextPartialCb = cb;
                  }
                }
              });

              if (appliedFull) calculateSum(false);

              if (remaining > 0.01 && nextPartialCb) {
                 let cbName = nextPartialCb.value;
                 let msg = appliedFull ? `Se aplicaron las tareas completas. Queda un saldo de $${remaining.toFixed(2)}. ¿Deseas aplicarlo como ABONO a la actividad "${cbName}"?` : `Queda un saldo de $${remaining.toFixed(2)}. ¿Deseas aplicarlo como ABONO a la actividad "${cbName}"?`;
                 
                 if(typeof Swal !== 'undefined') {
                   Swal.fire({
                      title: 'Saldo Sobrante',
                      text: msg,
                      icon: 'question',
                      showCancelButton: true,
                      confirmButtonText: 'Sí, aplicar abono',
                      cancelButtonText: 'No',
                      confirmButtonColor: '#10c469',
                      cancelButtonColor: '#6c757d'
                   }).then((result) => {
                      if (result.isConfirmed) {
                         nextPartialCb.checked = true;
                         nextPartialCb.dataset.applied = remaining;
                         calculateSum(false);
                      }
                   });
                 } else {
                   if(confirm(msg)) {
                       nextPartialCb.checked = true;
                       nextPartialCb.dataset.applied = remaining;
                       calculateSum(false);
                   }
                 }
              } else if (!appliedFull && !nextPartialCb) {
                 if(typeof Swal !== 'undefined') Swal.fire({icon:'info', title:'Sin actividades', text:'Todas las actividades de esta etapa ya están cubiertas.', confirmButtonColor: '#39afd1'});
                 else alert('Todas las actividades de esta etapa ya están cubiertas.');
              }
            });
          });

          if (amountInput) {
            amountInput.addEventListener('input', function() {
               if(currentMode === 'general') {
                  calculateSum(false); 
                  let total = getCheckedTotal();
                  let limit = parseFloat(amountInput.value) || 0;
                  limit = Math.round(limit * 100) / 100;
                  
                  if (total > (limit + 0.01) && total > 0) {
                    amountInput.classList.add('is-invalid', 'border-danger');
                  } else {
                    amountInput.classList.remove('is-invalid', 'border-danger');
                  }
               }
            });
          }

          if (searchInput) {
            searchInput.addEventListener('input', function() {
              const searchTerm = this.value.toLowerCase();
              container.querySelectorAll('.modal-stage-accordion-item').forEach(accItem => {
                let hasVisible = false;
                const items = accItem.querySelectorAll('.activity-item');
                const collapsePanel = accItem.querySelector('.accordion-collapse');

                items.forEach(item => {
                  if (item.textContent.toLowerCase().includes(searchTerm)) {
                    item.style.display = '';
                    hasVisible = true;
                  } else {
                    item.style.display = 'none';
                  }
                });

                if (hasVisible || searchTerm === '') {
                  accItem.style.display = '';
                  if (searchTerm !== '' && collapsePanel && !collapsePanel.classList.contains('show')) {
                     new bootstrap.Collapse(collapsePanel, { toggle: false }).show();
                  }
                } else {
                  accItem.style.display = 'none';
                }
              });
            });
          }

          updateMode();
        });
      }

      initPaymentModals();
    });
  </script>
<% end %>