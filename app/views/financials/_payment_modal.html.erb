<%# app/views/financials/_payment_modal.html.erb %>

<div class="modal fade" id="<%= modal_id %>" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content shadow-lg border-0">
      
      <div class="modal-header bg-success text-white p-3">
        <h5 class="modal-title mb-0 fw-bold"><i class="ri-checkbox-circle-line me-1"></i> Conciliación y Liquidación de Facturas</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      
      <%= form_with model: payment, url: url, method: method, local: true, multipart: true, class: "payment-form-container needs-validation" do |f| %>
        
        <%# CAMPO OCULTO: El monto se calcula vía JS al seleccionar facturas %>
        <%= f.hidden_field :amount, class: "payment-amount-input" %>

        <%# ===================================================================== %>
        <%# MOTOR CONTABLE: Cálculo de Saldos Insolutos por Factura              %>
        <%# ===================================================================== %>
        <% 
           activity_payments_hash = defined?(@activity_payments) && @activity_payments ? @activity_payments.dup : Hash.new(0.0)
           item_balances = {} 
           
           if @accruals_by_stage.present?
             @accruals_by_stage.values.flatten.each do |accrual|
               paid_so_far = activity_payments_hash[accrual.id] || 0.0
               q_items = QuotationItem.joins(:quotation)
                                      .where(financial_accrual_id: accrual.id)
                                      .order('quotations.created_at ASC', 'quotations.id ASC')
               q_items.each do |qi|
                 q_amt = (qi.amount.present? ? qi.amount.to_f : accrual.amount.to_f)
                 if paid_so_far >= (q_amt - 0.01)
                   paid_so_far -= q_amt
                   item_balances[qi.id] = 0.0
                 else
                   item_balances[qi.id] = (q_amt - paid_so_far).round(2)
                   paid_so_far = 0.0
                 end
               end
             end
           end

           pending_quotes = []
           Quotation.where(project_id: @project.id, status: ['facturado', 'pagado', 'aceptado'])
                    .order(created_at: :asc, id: :asc).each do |q_record|
             q_pending_total = 0.0
             q_activities = []
             q_record.quotation_items.order(id: :asc).each do |qi|
                accrual = qi.financial_accrual
                next unless accrual
                pending = item_balances[qi.id] || 0.0
                next unless pending > 0.01
                q_pending_total += pending
                q_activities << { id: accrual.id, name: accrual.concept_name, pending: pending, quoted: (qi.amount.present? ? qi.amount.to_f : accrual.amount.to_f) }
             end
             if q_pending_total > 0.01
                pending_quotes << { id: q_record.id, date: q_record.created_at.strftime("%d/%m/%Y"), total_pending: q_pending_total.round(2), activities: q_activities }
             end
           end
        %>

        <div class="modal-body p-4">
          
          <div class="alert alert-primary bg-primary-subtle text-primary border-0 font-13 mb-4 d-flex align-items-center shadow-sm">
            <i class="ri-checkbox-multiple-line font-24 me-2"></i>
            <div>
              <strong>Instrucciones:</strong> Marca las facturas que el cliente ha liquidado. El sistema sumará los montos de forma automática para garantizar que el ingreso bancario cuadre con lo facturado.
            </div>
          </div>

          <div class="row g-3 mb-4">
            <div class="col-md-6">
              <label class="form-label fw-bold font-13 text-dark text-uppercase tracking-wider">Fecha del Depósito / Transferencia</label>
              <div class="input-group">
                <span class="input-group-text bg-light border-end-0 text-muted"><i class="ri-calendar-check-line"></i></span>
                <%= f.date_field :payment_date, class: "form-control border-start-0 shadow-none", required: true, value: payment.payment_date || Date.current %>
              </div>
            </div>

            <div class="col-md-6">
              <label class="form-label fw-bold font-13 text-dark text-uppercase tracking-wider">Referencia Bancaria / Folio SPEI</label>
              <div class="input-group">
                <span class="input-group-text bg-light border-end-0 text-muted"><i class="ri-bank-card-line"></i></span>
                <%= f.text_field :invoice_number, class: "form-control border-start-0 shadow-none", placeholder: "Ej. TRANS-8821" %>
              </div>
            </div>
          </div>

          <div class="specific-activities-box mb-4">
            <h6 class="fw-bold font-14 text-dark mb-3"><i class="ri-file-list-3-line text-success me-1"></i> Selecciona Facturas a Liquidar</h6>
            
            <div class="border border-dark border-opacity-10 rounded shadow-sm bg-white overflow-hidden">
              <% if pending_quotes.any? %>
                <div class="list-group list-group-flush" id="invoices-list" style="max-height: 400px; overflow-y: auto;">
                  <% pending_quotes.each do |data| %>
                    <div class="list-group-item bg-light border-bottom invoice-group-container p-0">
                       <div class="p-3 d-flex justify-content-between align-items-center cursor-pointer hover-bg-light" data-bs-toggle="collapse" data-bs-target="#collapse_quote_<%= modal_id %>_<%= data[:id] %>">
                          <div class="form-check form-switch mb-0 d-flex align-items-center" onclick="event.stopPropagation();">
                             <input type="checkbox" class="form-check-input invoice-selector-cb cursor-pointer mt-0 me-3" style="width: 42px; height: 22px;" data-pending="<%= data[:total_pending] %>" data-quote-id="<%= data[:id] %>" id="quote_cb_<%= modal_id %>_<%= data[:id] %>">
                             <label class="form-check-label fw-bold text-dark cursor-pointer font-15" for="quote_cb_<%= modal_id %>_<%= data[:id] %>">
                               Folio: <span class="text-primary">#COT-<%= data[:id] %></span>
                               <span class="text-muted font-11 fw-normal ms-2">(<%= data[:date] %>)</span>
                             </label>
                          </div>
                          <div class="text-end">
                             <span class="badge bg-white text-dark border shadow-sm font-14 fw-bold px-3 py-1">
                                <%= number_to_currency(data[:total_pending]) %>
                             </span>
                             <i class="ri-arrow-down-s-line ms-2 text-muted"></i>
                          </div>
                       </div>
                       
                       <div id="collapse_quote_<%= modal_id %>_<%= data[:id] %>" class="collapse bg-white">
                          <div class="p-3 border-top bg-white">
                              <p class="text-muted font-10 text-uppercase tracking-wider fw-bold mb-2">Desglose de la factura:</p>
                              <% data[:activities].each do |act| %>
                                 <div class="activity-data-item d-flex justify-content-between align-items-center mb-1 pb-1 border-bottom border-light" data-id="<%= act[:id] %>" data-name="<%= act[:name] %>" data-pending="<%= act[:pending] %>">
                                    <span class="font-12 text-dark pe-2 text-truncate" style="max-width: 75%;">
                                       <i class="ri-subtract-line me-1 text-muted"></i><%= act[:name] %>
                                    </span>
                                    <span class="font-12 fw-bold font-monospace text-muted">
                                       <%= number_to_currency(act[:pending]) %>
                                    </span>
                                 </div>
                              <% end %>
                          </div>
                       </div>
                    </div>
                  <% end %>
                </div>
              <% else %>
                <div class="p-5 text-center text-muted font-14 bg-light">
                  <i class="ri-checkbox-circle-fill font-40 text-success d-block mb-2"></i>
                  <h5 class="fw-bold text-dark">Sin Deudas Pendientes</h5>
                  <p class="mb-0">Todas las facturas emitidas han sido conciliadas.</p>
                </div>
              <% end %>
            </div>
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold font-13 text-dark">Registro Contable (Auto-generado)</label>
            <%= f.text_area :notes, class: "form-control payment-notes-input bg-light border-light-subtle font-monospace font-11 text-primary shadow-none", rows: 4, placeholder: "Selecciona una factura para generar el desglose...", readonly: true %>
          </div>

          <div class="mb-0">
            <label class="form-label fw-bold font-13 text-dark">Comprobante Bancario (Anexo)</label>
            <%= f.file_field :receipt, class: "form-control shadow-none" %>
          </div>

        </div>
        
        <div class="modal-footer bg-light p-3 border-top-0 d-flex justify-content-between align-items-center">
          <div>
            <span class="text-muted font-11 d-block">Monto Total a Conciliar:</span>
            <h4 class="text-success fw-bold mb-0" id="visual-total-<%= modal_id %>">$0.00</h4>
          </div>
          <div>
            <button type="button" class="btn btn-outline-secondary rounded-pill px-4 me-1" data-bs-dismiss="modal">Cancelar</button>
            <%= f.submit "Procesar Pago", class: "btn btn-success rounded-pill px-4 shadow fw-bold", id: "btn-submit-payment-#{modal_id}", disabled: true %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<style>
  .hover-bg-light:hover { background-color: #f1f3f7 !important; }
  .form-switch .form-check-input:checked { background-color: #10c469; border-color: #10c469; }
</style>

<script>
  document.addEventListener("turbo:load", function() {
      const container = document.getElementById('<%= modal_id %>');
      if (!container) return;

      const invoiceCbs = container.querySelectorAll('.invoice-selector-cb');
      const hiddenAmountInput = container.querySelector('.payment-amount-input');
      const notesInput = container.querySelector('.payment-notes-input');
      const visualTotal = document.getElementById('visual-total-<%= modal_id %>');
      const submitBtn = document.getElementById('btn-submit-payment-<%= modal_id %>');

      function formatMXN(val) {
          return new Intl.NumberFormat('es-MX', { style: 'currency', currency: 'MXN' }).format(val);
      }

      function updateReconciliation() {
          let total = 0.0;
          let selectedInvoices = [];
          let partialPairs = [];
          let humanTexts = [];

          invoiceCbs.forEach(cb => {
              if (cb.checked) {
                  let qId = cb.dataset.quoteId;
                  let qPending = parseFloat(cb.dataset.pending);
                  total += qPending;
                  selectedInvoices.push(`#COT-${qId}`);

                  let invGroup = cb.closest('.invoice-group-container');
                  let activities = invGroup.querySelectorAll('.activity-data-item');

                  activities.forEach(act => {
                      let actId = act.dataset.id;
                      let actName = act.dataset.name;
                      let actAmt = parseFloat(act.dataset.pending);
                      partialPairs.push(`${actId}_${actAmt.toFixed(2)}`);
                      humanTexts.push(`✔ ${actName} (Factura #COT-${qId}): ${formatMXN(actAmt)}`);
                  });
              }
          });

          // Actualizar datos para el servidor
          hiddenAmountInput.value = total > 0 ? total.toFixed(2) : 0;
          
          // Actualizar interfaz
          visualTotal.innerText = formatMXN(total);
          submitBtn.disabled = total <= 0.01;

          // Generar Nota de Auditoría
          if (notesInput) {
              if (total > 0) {
                  let partStr = `[PARTIAL: ${partialPairs.join(',')}]\n`;
                  let humanNote = `[Liquidación Comercial de Facturas: ${selectedInvoices.join(', ')}]\n\n--- DETALLE DE AMORTIZACIÓN ---\n${humanTexts.join("\n")}\n--- FIN ---`;
                  notesInput.value = partStr + humanNote;
              } else {
                  notesInput.value = "";
              }
          }
      }

      invoiceCbs.forEach(cb => {
          cb.addEventListener('change', updateReconciliation);
      });
  });
</script>